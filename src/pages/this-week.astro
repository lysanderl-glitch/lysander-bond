---
// PLS (Plain-Language Surface) — versioned content collection host.
// Shows the latest weekly entry in full; links to historical archive below.
// Each week's content lives in src/content/weekly/YYYY-MM-DD.md
// History URL pattern: /weekly/YYYY-MM-DD/
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allEntries = await getCollection('weekly');

// Sort descending by date string (YYYY-MM-DD lexicographic sort is safe)
allEntries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const latest = allEntries[0];
const historical = allEntries.slice(1);

const { Content } = await render(latest);
---

<Layout
  title="这周怎么样 | Lysander"
  description="给总裁的 Synapse 本周快报：这周更新了什么 · 现在能让 Synapse 做什么 · 上周运行得怎么样。"
  lang="zh"
  darkContent={false}
>
  <!-- Hero -->
  <section class="pt-24 pb-10 px-6 border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#FCAD2A]/10 border border-[#FCAD2A]/30 text-[#FCAD2A] text-xs font-semibold mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#FCAD2A] animate-pulse"></span>
        本周快报 · 更新于 {latest.data.date}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-3" style="font-family: var(--font-display, 'Fraunces', Georgia, serif); letter-spacing: -0.02em;">
        这周怎么样
      </h1>
      <p class="text-base md:text-lg text-[var(--color-text-light)] leading-relaxed max-w-2xl">
        给总裁的一页质朴汇报：这周改了什么、现在您能让 Synapse 做哪些事、上周整体跑得怎么样。
      </p>
      <div class="flex items-center gap-4 mt-3 flex-wrap">
        {latest.data.window_label && (
          <p class="text-xs text-[var(--color-muted)] font-mono">
            数据窗口 {latest.data.window_label} · 每周日晚自动刷新
          </p>
        )}
        {latest.data.health_score && (
          <span class="text-xs font-semibold text-[#28a745]">健康分 {latest.data.health_score}/100</span>
        )}
      </div>
    </div>
  </section>

  <!-- Latest entry content -->
  <article class="py-14 px-6">
    <div class="max-w-4xl mx-auto weekly-content">
      <Content />
    </div>
  </article>

  <!-- Historical archive -->
  {historical.length > 0 && (
    <section class="py-10 px-6 border-t border-[var(--color-border)] bg-[#F7F8FA]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-sm font-bold uppercase tracking-wider text-[var(--color-muted)] mb-5">往期快报</h2>
        <ul class="space-y-3">
          {historical.map((entry) => (
            <li class="flex items-baseline gap-4">
              <span class="text-xs font-mono text-[var(--color-muted)] w-24 shrink-0">{entry.data.date}</span>
              <a
                href={`/weekly/${entry.data.date}/`}
                class="text-sm text-[#028CDC] hover:underline leading-snug"
              >
                {entry.data.summary ?? entry.data.title}
              </a>
              {entry.data.health_score && (
                <span class="text-xs text-[#28a745] font-mono shrink-0">{entry.data.health_score}/100</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Footer note -->
  <section class="py-10 px-6 border-t border-[var(--color-border)] bg-[#F7F8FA]">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-xs text-[var(--color-muted)] leading-relaxed">
        每周一条 dated entry，历史永久保留。<br>
        本周 <span class="font-mono">{latest.data.date}</span> — <a href={`/weekly/${latest.data.date}/`} class="text-[#028CDC] hover:underline">固定链接</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .weekly-content h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }
  .weekly-content h2:first-child {
    margin-top: 0;
  }
  .weekly-content strong {
    color: var(--color-text);
  }
  .weekly-content p {
    color: var(--color-text-light);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .weekly-content em {
    color: var(--color-muted);
    font-style: normal;
    font-size: 0.875rem;
  }
  .weekly-content hr {
    border-color: var(--color-border);
    margin: 2rem 0;
  }
  .weekly-content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.5rem 0;
  }
  .weekly-content th,
  .weekly-content td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .weekly-content th {
    background: #F7F8FA;
    font-weight: 600;
    color: var(--color-text);
  }
  .weekly-content td {
    color: var(--color-text-light);
  }
</style>
