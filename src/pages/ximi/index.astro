function $(id){return document.getElementById(id);}
function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));$(id).classList.add('active');}
function saveGame(){localStorage.setItem(SAVE,JSON.stringify({day:curDay,scores}));}
function loadSave(){const d=localStorage.getItem(SAVE);return d?JSON.parse(d):null;}

function startNew(){localStorage.removeItem(SAVE);curDay=1;scores=[];showBrief();}
function loadGame(){const s=loadSave();if(!s){startNew();return;}curDay=s.day;scores=s.scores;showBrief();}

window.onload=()=>{const s=loadSave();if(s&&s.day>1)$('btn-cont').style.display='';};

function showBrief(){
  const d=DAYS[curDay-1];
  $('br-label').textContent=`DAY ${d.n}`;
  $('br-title').textContent=d.sub;
  $('br-theme').textContent=d.theme;
  const tt=$('br-targets');tt.innerHTML='';
  d.targets.forEach(id=>{const e=EM[id];const t=document.createElement('div');t.className='em-tag';t.textContent=e.emoji+' '+e.name;t.style.cssText=`background:${e.bg};border-color:${e.border};color:#fff;`;tt.appendChild(t);});
  const av=$('br-avoids');av.innerHTML='';
  d.avoids.forEach(id=>{const e=EM[id];const t=document.createElement('div');t.className='em-tag';t.textContent=e.emoji+' '+e.name;t.style.cssText=`background:${e.bg};border-color:${e.border};color:#aaa;`;av.appendChild(t);});
  const prog=$('br-progress');
  prog.innerHTML='';
  for(let i=1;i<=7;i++){
    const dot=document.createElement('div');
    const done=scores[i-1]!==undefined;
    const current=i===curDay;
    dot.style.cssText=`width:${current?12:8}px;height:${current?12:8}px;border-radius:50%;background:${done?'var(--pk)':current?'rgba(255,0,128,0.5)':'rgba(255,255,255,0.15)'};border:1px solid ${current?'var(--pk)':'transparent'};transition:all .3s;`;
    prog.appendChild(dot);
  }
  show('sb');
}

function startGame(){
  const d=DAYS[curDay-1];
  energy=0;combo=0;bubbles=[];isPaused=false;spawnCount=0;
  $('g-daylabel').textContent=`DAY ${d.n} · ${d.sub}`;
  updateHUD();
  updateComboBadge();
  show('sg');
  timeLeft=d.time;
  $('g-timer').textContent=timeLeft;
  $('g-timer').classList.remove('warn');
  $('pause-overlay').style.display='none';
  clearAllBubbles();
  spawnTimer=setInterval(()=>spawnBubble(d),d.spawn);
  countTimer=setInterval(tick,1000);
  rafId=requestAnimationFrame(()=>animFrame(d));
  startDanmakuSpawner(d);
}

document.addEventListener('visibilitychange',()=>{
  if(document.hidden){pauseGame();}else{resumeGame();}
});

function pauseGame(){
  if(!rafId&&!spawnTimer)return;
  isPaused=true;
  clearInterval(spawnTimer);spawnTimer=null;
  clearInterval(countTimer);countTimer=null;
  cancelAnimationFrame(rafId);rafId=null;
  clearTimeout(danmakuTimer);danmakuTimer=null;
  const overlay=$('pause-overlay');
  if(overlay)overlay.style.display='flex';
}

function resumeGame(){
  if(!isPaused)return;
  isPaused=false;
  const overlay=$('pause-overlay');
  if(overlay)overlay.style.display='none';
  const d=DAYS[curDay-1];
  spawnTimer=setInterval(()=>spawnBubble(d),d.spawn);
  countTimer=setInterval(tick,1000);
  rafId=requestAnimationFrame(()=>animFrame(d));
  startDanmakuSpawner(d);
}
window.resumeGame=resumeGame;

function tick(){
  timeLeft--;
  $('g-timer').textContent=timeLeft;
  if(timeLeft<=10)$('g-timer').classList.add('warn');
  if(timeLeft<=0)endGame();
}

function animFrame(d){
  const field=$('g-field');
  const fw=field.clientWidth;
  bubbles=bubbles.filter(b=>{
    if(!b.el.parentNode)return false;
    b.y-=(d.speed/60)*b.speedMod;
    b.x+=b.dx;
    if(b.x<130||b.x>fw-60)b.dx*=-1;
    b.el.style.top=b.y+'px';
    b.el.style.left=b.x+'px';
    if(b.y<-80){
      b.el.remove();
      if(curDay>=3&&EM[b.id]&&EM[b.id].type==='good'){
        energy=Math.max(0,energy-1);
        updateHUD();
        const bar=$('g-bar');
        bar.classList.add('shake-small');
        setTimeout(()=>bar.classList.remove('shake-small'),300);
      }
      return false;
    }
    return true;
  });
  rafId=requestAnimationFrame(()=>animFrame(d));
}

function buildPool(d){
  const pool=[];
  d.targets.forEach(id=>{pool.push(id,id);});
  d.avoids.forEach(id=>{pool.push(id,id);});
  return pool;
}

function spawnBubble(d){
  const field=$('g-field');
  if(bubbles.length>=d.max)return;
  spawnCount++;
  let id;
  if(spawnCount%15===0&&Math.random()<0.7){
    const specials=['magpie','bouquet','rose'];
    id=specials[Math.floor(Math.random()*specials.length)];
  } else {
    const pool=buildPool(d);
    id=pool[Math.floor(Math.random()*pool.length)];
  }
  const em=EM[id];
  const size=50+Math.floor(Math.random()*18);
  const fw=field.clientWidth;
  const minX=135,maxX=Math.max(minX+60,fw-size-10);
  const x=minX+Math.random()*(maxX-minX);
  const y=field.clientHeight-size-5;
  const el=document.createElement('div');
  el.className='bubble';
  // Special bubbles get a pulsing border
  const specialStyle=em.type==='special'?`;animation:pulse-badge .8s ease infinite alternate`:'';
  el.style.cssText=`width:${size}px;height:${size}px;left:${x}px;top:${y}px;background:${em.bg};border-color:${em.border};box-shadow:0 0 10px ${em.glow}${specialStyle};`;
  el.innerHTML=`<div class="b-emoji">${em.emoji}</div><div class="b-name">${em.name}</div>`;
  const speedMod=0.7+Math.random()*0.6;
  const dx=(Math.random()-0.5)*0.6;
  const finalDx=em.type==='bad'?dx*1.8:dx;
  el.addEventListener('click',e=>{e.stopPropagation();clickBubble(el,em,x+size/2,y+size/2);});
  field.appendChild(el);
  bubbles.push({el,y,x,id,dx:finalDx,speedMod});
}

// ═══ FIREWORK EFFECTS ═══
function launchFirework(x, y) {
  const field = $('g-field');
  if (!field) return;
  const colors = ['#ff0080','#ff6eb4','#ffd700','#ff4499','#c8a0d4','#90ee90'];
  for (let i = 0; i < 24; i++) {
    const p = document.createElement('div');
    const angle = (i / 24) * Math.PI * 2;
    const dist = 60 + Math.random() * 60;
    const color = colors[Math.floor(Math.random() * colors.length)];
    const size = 4 + Math.random() * 6;
    p.style.cssText = `position:absolute;width:${size}px;height:${size}px;border-radius:50%;background:${color};left:${x}px;top:${y}px;pointer-events:none;z-index:50;transform:translate(-50%,-50%);box-shadow:0 0 6px ${color};transition:all 0.7s cubic-bezier(0.25,0.46,0.45,0.94);opacity:1;`;
    field.appendChild(p);
    requestAnimationFrame(() => {
      p.style.left = (x + Math.cos(angle) * dist) + 'px';
      p.style.top = (y + Math.sin(angle) * dist) + 'px';
      p.style.opacity = '0';
      p.style.transform = 'translate(-50%,-50%) scale(0)';
    });
    setTimeout(() => p.remove(), 750);
  }
}

function launchOverlayFirework(container, x, y) {
  const colors = ['#ff0080','#ffd700','#ff6eb4','#c8a0d4','#90ee90','#ffffff'];
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div');
    const angle = (i / 20) * Math.PI * 2;
    const dist = 80 + Math.random() * 80;
    const color = colors[Math.floor(Math.random() * colors.length)];
    p.style.cssText = `position:absolute;width:6px;height:6px;border-radius:50%;background:${color};left:${x}px;top:${y}px;pointer-events:none;z-index:150;transform:translate(-50%,-50%);transition:all 0.8s ease;opacity:1;`;
    container.appendChild(p);
    requestAnimationFrame(() => {
      p.style.left = (x + Math.cos(angle) * dist) + 'px';
      p.style.top = (y + Math.sin(angle) * dist) + 'px';
      p.style.opacity = '0';
    });
    setTimeout(() => p.remove(), 850);
  }
}

function clickBubble(el,em,cx,cy){
  if(!el.parentNode)return;
  const idx=bubbles.findIndex(b=>b.el===el);
  if(idx>-1)bubbles.splice(idx,1);
  el.classList.add('burst');
  setTimeout(()=>el.remove(),300);
  const port=$('g-portrait');
  if(em.type==='good'){
    clearTimeout(comboTimer);
    combo++;
    comboTimer=setTimeout(()=>{combo=0;updateComboBadge();},1500);
    const mult=combo>=5?3:combo>=3?2:1;
    const gain=6*mult;
    energy=energy+gain; // no cap
    port.classList.remove('hit-good','hit-bad');void port.offsetWidth;port.classList.add('hit-good');
    showPop(cx,cy,`+${gain}${combo>=3?' x'+mult:''}`,combo>=5?'#ffd700':combo>=3?'#ff6eb4':'#90ee90');
    spawnParticles(cx,cy,em.glow);
    updateComboBadge();
    if(combo===3){
      const toast=document.createElement('div');
      toast.style.cssText='position:absolute;top:20px;left:50%;transform:translateX(-50%);font-size:24px;letter-spacing:6px;animation:pop-up 1.5s ease forwards;z-index:40;pointer-events:none;text-shadow:0 0 12px #ff6eb4;';
      toast.textContent='👍🪙⭐';
      const field=$('g-field');
      field.appendChild(toast);
      setTimeout(()=>toast.remove(),1550);
      // Firework at center for combo 3
      launchFirework(field.clientWidth/2, field.clientHeight/2);
    }
  } else if(em.type==='special'){
    combo++;
    clearTimeout(comboTimer);
    comboTimer=setTimeout(()=>{combo=0;updateComboBadge();},1500);
    const mult=combo>=5?3:combo>=3?2:1;
    const gain=15*mult;
    energy=energy+gain;
    port.classList.remove('hit-good','hit-bad');void port.offsetWidth;port.classList.add('hit-good');
    showPop(cx,cy,`+${gain} ${em.name}！`,'#ffd700');
    launchFirework(cx, cy);
    updateHUD();
    updateComboBadge();
  } else {
    combo=0;
    energy=Math.max(0,energy-5);
    port.classList.remove('hit-good','hit-bad');void port.offsetWidth;port.classList.add('hit-bad');
    showPop(cx,cy,'-5','#ff4444');
    updateComboBadge();
  }
  updateHUD();
}

function updateComboBadge(){
  const b=$('combo-badge');
  if(!b)return;
  b.className='';
  if(combo===0){b.style.display='none';return;}
  b.style.display='';
  if(combo>=5){b.className='c5';b.textContent='⚡ x3+';}
  else if(combo>=3){b.className='c3';b.textContent='🔥 x2';}
  else{b.className='c2';b.textContent='🔥 x'+combo;}
}

function spawnParticles(x,y,color){
  const field=$('g-field');
  for(let i=0;i<6;i++){
    const p=document.createElement('div');
    const angle=(i/6)*Math.PI*2;
    const dist=30+Math.random()*20;
    p.style.cssText=`position:absolute;width:6px;height:6px;border-radius:50%;background:${color};left:${x}px;top:${y}px;pointer-events:none;z-index:25;transform:translate(-50%,-50%);transition:all .5s ease;opacity:1;`;
    field.appendChild(p);
    requestAnimationFrame(()=>{
      p.style.left=(x+Math.cos(angle)*dist)+'px';
      p.style.top=(y+Math.sin(angle)*dist)+'px';
      p.style.opacity='0';
      p.style.transform='translate(-50%,-50%) scale(0)';
    });
    setTimeout(()=>p.remove(),520);
  }
}

function spawnDanmaku(d){
  const field=$('g-field');
  const fh=field.clientHeight;
  const y=40+Math.random()*(fh*0.6);
  const el=document.createElement('div');
  const msg=DANMAKU_MSGS[Math.floor(Math.random()*DANMAKU_MSGS.length)];
  el.style.cssText=`position:absolute;left:-120px;top:${y}px;background:rgba(255,0,128,0.18);border:1px solid rgba(255,0,128,0.4);border-radius:20px;padding:4px 12px;color:#fde8f0;font-size:12px;white-space:nowrap;cursor:pointer;z-index:15;pointer-events:auto;`;
  el.textContent='💬 '+msg;
  el.addEventListener('click',e=>{
    e.stopPropagation();
    energy=energy+10; // no cap
    updateHUD();
    showPop(field.clientWidth/2,y,'+10 弹幕！','#ff6eb4');
    const port=$('g-portrait');
    port.classList.remove('hit-good','hit-bad');void port.offsetWidth;port.classList.add('hit-good');
    // Firework at click position
    const rect=field.getBoundingClientRect();
    launchFirework(field.clientWidth/2, y);
    el.remove();
  });
  field.appendChild(el);
  let lx=-120;
  const speed=3.0;
  function moveDanmaku(){
    lx+=speed;
    el.style.left=lx+'px';
    if(lx<field.clientWidth+20&&el.parentNode){
      requestAnimationFrame(moveDanmaku);
    } else {
      if(el.parentNode)el.remove();
    }
  }
  requestAnimationFrame(moveDanmaku);
}

function startDanmakuSpawner(d){
  function scheduleNext(){
    const delay=8000+Math.random()*4000;
    danmakuTimer=setTimeout(()=>{
      if(!isPaused)spawnDanmaku(d);
      scheduleNext();
    },delay);
  }
  scheduleNext();
}

function showPop(x,y,txt,color){
  const field=$('g-field');
  const p=document.createElement('div');
  p.className='score-pop';
  p.textContent=txt;
  p.style.cssText=`left:${x}px;top:${y}px;color:${color};transform:translateX(-50%);`;
  field.appendChild(p);
  setTimeout(()=>p.remove(),950);
}

function updateHUD(){
  const barEl=$('g-bar');
  const pctEl=$('g-pct');
  const barWidth=Math.min(100,energy);
  barEl.style.width=barWidth+'%';
  // Remove all level classes
  barEl.classList.remove('lv2','lv3','lv4');
  if(energy>=200)barEl.classList.add('lv4');
  else if(energy>=150)barEl.classList.add('lv3');
  else if(energy>=100)barEl.classList.add('lv2');
  pctEl.textContent=Math.round(energy);
}

function clearAllBubbles(){
  bubbles.forEach(b=>{if(b.el.parentNode)b.el.remove();});
  bubbles=[];
}

function endGame(){
  clearInterval(spawnTimer);spawnTimer=null;
  clearInterval(countTimer);countTimer=null;
  cancelAnimationFrame(rafId);rafId=null;
  clearTimeout(danmakuTimer);danmakuTimer=null;
  clearAllBubbles();
  scores[curDay-1]=Math.round(energy);
  saveGame();
  checkGiftReward(Math.round(energy));
}

// ═══ GIFT REWARD SYSTEM ═══
function checkGiftReward(score){
  if(score>=250)showGiftReward('castle');
  else if(score>=200)showGiftReward('rocket');
  else if(score>=150)showGiftReward('car');
  else if(score>=100)showGiftReward('firework');
  else showDialogue();
}

function showGiftReward(type){
  const overlay=document.createElement('div');
  overlay.id='gift-overlay';
  overlay.style.cssText='position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(10,0,16,0.92);animation:screenIn .5s ease both;';

  const GIFTS={
    firework:{ emoji:'🎆', label:'烟花秀',    color:'#ff6eb4', msg:'100分！送你一场烟花秀！' },
    car:     { emoji:'🏎️', label:'超级跑车',  color:'#ffd700', msg:'150分！超级跑车登场！' },
    rocket:  { emoji:'🚀', label:'火箭',      color:'#c8a0d4', msg:'200分！火箭升空！' },
    castle:  { emoji:'🏰', label:'梦幻城堡',  color:'#ff0080', msg:'250分！梦幻城堡！' },
  };

  const g=GIFTS[type];
  overlay.innerHTML=`
    <div style="font-size:80px;animation:float 1s ease-in-out infinite;margin-bottom:16px">${g.emoji}</div>
    <div style="font-size:22px;color:${g.color};letter-spacing:4px;text-shadow:0 0 20px ${g.color};margin-bottom:8px">${g.label}</div>
    <div style="font-size:14px;color:#fde8f0;margin-bottom:24px">${g.msg}</div>
    <button class="btn" onclick="document.getElementById('gift-overlay').remove();showDialogue()">继续 ▶</button>
  `;
  document.body.appendChild(overlay);

  // Firework bursts for high scores
  if(type==='firework'||type==='car'||type==='rocket'||type==='castle'){
    const count=type==='castle'?8:5;
    for(let f=0;f<count;f++){
      setTimeout(()=>{
        const rect=overlay.getBoundingClientRect();
        launchOverlayFirework(overlay, Math.random()*rect.width, Math.random()*rect.height*0.6);
      },f*300);
    }
  }
}

function showDialogue(){
  const sc=scores[curDay-1];
  let pool;
  if(sc>=70)pool=DLG_GOOD[Math.min(curDay-1,DLG_GOOD.length-1)];
  else if(sc>=40)pool=DLG_OK[Math.floor(Math.random()*DLG_OK.length)];
  else pool=DLG_LOW[Math.floor(Math.random()*DLG_LOW.length)];
  dlgLines=pool;dlgIdx=0;
  renderLine();
  show('sdlg');
}

function renderLine(){
  const l=dlgLines[dlgIdx];
  $('dlg-speaker').textContent=l.s;
  $('dlg-text').textContent=l.t;
}

window.nextLine=function(){
  dlgIdx++;
  if(dlgIdx<dlgLines.length){renderLine();return;}
  showSummary();
};

function showSummary(){
  const sc=scores[curDay-1];
  $('sum-label').textContent=`DAY ${curDay} 完成`;
  $('sum-pct').textContent=sc;
  $('sum-stars').textContent=sc>=200?'★★★':sc>=120?'★★☆':sc>=70?'★☆☆':'☆☆☆';
  const msgs={200:'传说级！汐落星满血复活！',120:'超棒！汐落星的光又亮了一大格。',70:'不错！继续保持。',0:'今天有点难……但汐弥还在。'};
  const keys=Object.keys(msgs).map(Number).sort((a,b)=>b-a);
  $('sum-msg').textContent=msgs[keys.find(k=>sc>=k)??0];
  if(curDay===7)$('sum-btn').textContent='查看结局 ✦';
  else $('sum-btn').textContent=`第${curDay+1}天继续 →`;
  show('ssum');
}

window.sumNext=function(){
  if(curDay===7){showEnding();return;}
  curDay++;
  saveGame();
  showBrief();
};

// ═══ ENDING: DUBAI PHOTO SLIDESHOW ═══
function showEnding(){
  endPhotoIdx=0;
  if(endAutoTimer){clearInterval(endAutoTimer);endAutoTimer=null;}

  const photosDiv=$('end-photos');
  photosDiv.innerHTML='';

  DUBAI_PHOTOS.forEach((photo,i)=>{
    if(photo.orientation==='portrait'){
      // Blurred background for portrait photos
      const bgImg=document.createElement('img');
      bgImg.src=photo.src;
      bgImg.style.cssText=`position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:blur(20px) brightness(0.4);opacity:${i===0?1:0};transition:opacity 1.2s ease;z-index:0;`;
      bgImg.dataset.photoIdx=i;
      bgImg.dataset.isBg='1';
      photosDiv.appendChild(bgImg);
    }
    const img=document.createElement('img');
    img.src=photo.src;
    img.style.cssText=`position:absolute;inset:0;width:100%;height:100%;object-fit:${photo.orientation==='portrait'?'contain':'cover'};object-position:center;opacity:${i===0?1:0};transition:opacity 1.2s ease;z-index:1;`;
    img.dataset.photoIdx=i;
    photosDiv.appendChild(img);
  });

  // Progress dots
  const dotsDiv=$('end-dots');
  dotsDiv.innerHTML='';
  DUBAI_PHOTOS.forEach((_,i)=>{
    const d=document.createElement('div');
    d.dataset.dot=i;
    d.style.cssText=`width:${i===0?10:6}px;height:${i===0?10:6}px;border-radius:50%;background:${i===0?'#ff0080':'rgba(255,255,255,0.3)'};transition:all .4s;`;
    dotsDiv.appendChild(d);
  });

  // Hide final elements until last photo
  $('end-fin').style.display='none';
  $('end-replay-btn').style.display='none';

  renderEndLetter(0);
  show('send');

  // Auto-advance every 5s
  endAutoTimer=setInterval(nextEndPhoto,5000);

  // Click to advance (remove old listener by using named function replacement)
  const sendScreen=$('send');
  sendScreen.onclick=function(){
    if(endPhotoIdx<DUBAI_PHOTOS.length-1){
      clearInterval(endAutoTimer);
      nextEndPhoto();
      endAutoTimer=setInterval(nextEndPhoto,5000);
    }
  };
}

function renderEndLetter(idx){
  const letter=$('end-letter');
  const data=LOVE_LETTER[idx];
  letter.style.opacity='0';
  letter.style.transform='translateY(20px)';

  setTimeout(()=>{
    letter.innerHTML=data.lines.map(line=>
      line
        ? `<div style="font-size:${line.startsWith('❤')?'18px':'15px'};line-height:2.2;color:${line.startsWith('❤')?'#ff6eb4':'#f0d8e8'};letter-spacing:1px;">${line}</div>`
        : '<div style="height:12px"></div>'
    ).join('');
    letter.style.opacity='1';
    letter.style.transform='translateY(0)';
  },200);

  // Update photo visibility
  document.querySelectorAll('#end-photos img').forEach(el=>{
    if(el.dataset.photoIdx!==undefined){
      el.style.opacity=parseInt(el.dataset.photoIdx)===idx?'1':'0';
    }
  });

  // Update dots
  document.querySelectorAll('#end-dots [data-dot]').forEach(d=>{
    const i=parseInt(d.dataset.dot);
    d.style.width=i===idx?'10px':'6px';
    d.style.height=i===idx?'10px':'6px';
    d.style.background=i===idx?'#ff0080':i<idx?'rgba(255,0,128,0.4)':'rgba(255,255,255,0.3)';
  });

  // Last photo: show final elements + fireworks
  if(idx===DUBAI_PHOTOS.length-1){
    clearInterval(endAutoTimer);endAutoTimer=null;
    setTimeout(()=>{
      $('end-fin').style.display='block';
      $('end-replay-btn').style.display='inline-block';
      const sendEl=$('send');
      for(let f=0;f<8;f++){
        setTimeout(()=>{
          launchOverlayFirework(sendEl, Math.random()*window.innerWidth, Math.random()*window.innerHeight*0.5);
        },f*400);
      }
    },2000);
  }
}

function nextEndPhoto(){
  if(endPhotoIdx<DUBAI_PHOTOS.length-1){
    endPhotoIdx++;
    renderEndLetter(endPhotoIdx);
  } else {
    clearInterval(endAutoTimer);endAutoTimer=null;
  }
}

// Keyboard support
document.addEventListener('keydown',e=>{
  if(e.key===' '||e.key==='Enter'){
    e.preventDefault();
    const dlgScreen=$('sdlg');
    if(dlgScreen.classList.contains('active')){nextLine();return;}
    const sumScreen=$('ssum');
    if(sumScreen.classList.contains('active')){sumNext();return;}
  }
});

window.startNew=startNew;
window.loadGame=loadGame;
window.startGame=startGame;
window.showDialogue=showDialogue;
</script>
</body>
</html>
