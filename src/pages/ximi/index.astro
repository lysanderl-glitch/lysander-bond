<script is:inline>
// ═══ BACKGROUND PARTICLE SYSTEM ═══
(function() {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, particles = [], mouse = {x: -999, y: -999};

  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
  window.addEventListener('touchmove', e => { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; }, {passive:true});

  const SYMBOLS = ['✦','♡','✧','·','★','°'];

  function createParticle() {
    return {
      x: Math.random() * W,
      y: H + 10,
      size: 8 + Math.random() * 14,
      speed: 0.3 + Math.random() * 0.6,
      opacity: 0.1 + Math.random() * 0.35,
      symbol: SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)],
      hue: Math.random() < 0.6 ? 330 : Math.random() < 0.5 ? 280 : 50,
      drift: (Math.random() - 0.5) * 0.4,
      wobble: Math.random() * Math.PI * 2,
      wobbleSpeed: 0.01 + Math.random() * 0.02,
    };
  }

  for (let i = 0; i < 40; i++) {
    const p = createParticle();
    p.y = Math.random() * H;
    particles.push(p);
  }

  function drawBg() {
    ctx.clearRect(0, 0, W, H);

    const grad = ctx.createRadialGradient(W/2, H, 0, W/2, H, H * 0.7);
    grad.addColorStop(0, 'rgba(255,0,128,0.06)');
    grad.addColorStop(0.5, 'rgba(140,0,200,0.03)');
    grad.addColorStop(1, 'transparent');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, H);

    const mGrad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 120);
    mGrad.addColorStop(0, 'rgba(255,0,128,0.07)');
    mGrad.addColorStop(1, 'transparent');
    ctx.fillStyle = mGrad;
    ctx.fillRect(0, 0, W, H);

    particles.forEach((p, i) => {
      p.y -= p.speed;
      p.wobble += p.wobbleSpeed;
      p.x += p.drift + Math.sin(p.wobble) * 0.3;

      const dx = p.x - mouse.x, dy = p.y - mouse.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 80) {
        p.x += (dx / dist) * 0.8;
        p.y += (dy / dist) * 0.8;
      }

      ctx.save();
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle = `hsl(${p.hue}, 80%, 70%)`;
      ctx.font = `${p.size}px serif`;
      ctx.textAlign = 'center';
      ctx.fillText(p.symbol, p.x, p.y);
      ctx.restore();

      if (p.y < -20) particles[i] = createParticle();
    });

    requestAnimationFrame(drawBg);
  }
  drawBg();
})();

