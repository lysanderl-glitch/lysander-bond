<!-- Ximi Game v4.3 - Full Overhaul: Difficulty + Gift System + Dubai Ending + Interactive BG 2026-05-31 -->
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0"/>
  <title>以情感为食 · 汐弥的七天情感收集</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&display=swap" rel="stylesheet">
  <style is:global>
    :root{--pk:#FF0080;--pks:#F4A0C0;--lav:#C8A0D4;--gold:#F0C840;--dark:#0a0010;--dark2:#120018;--glow:rgba(255,0,128,0.5);}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--dark);color:#fde8f0;font-family:'Noto Serif SC','PingFang SC','Microsoft YaHei',serif;overflow:hidden;user-select:none;}
    body{height:100vh;}
    @supports (height:100dvh){body{height:100dvh;}}

    /* BG */
    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,0,128,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,0,128,0.05) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}
    body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.08) 2px,rgba(0,0,0,0.08) 4px);pointer-events:none;z-index:0;}

    /* SCREENS */
    .screen{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;padding:20px;z-index:10;}
    @supports (height:100dvh){.screen{height:100dvh;}}
    .screen.active{display:flex;animation:screenIn .5s ease both;}
    @keyframes screenIn{0%{opacity:0;filter:brightness(1.8) saturate(0);}100%{opacity:1;filter:brightness(1) saturate(1);}}

    /* TITLE */
    .title-bg{position:absolute;inset:0;overflow:hidden;}
    .title-bg img{width:100%;height:100%;object-fit:cover;filter:blur(3px) brightness(0.35);}
    .title-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 20%,rgba(10,0,16,0.7) 100%);pointer-events:none;}
    .title-content{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:12px;}
    .av-ring{width:144px;height:144px;border-radius:50%;border:3px solid var(--pk);box-shadow:0 0 24px var(--glow),0 0 60px var(--glow);overflow:hidden;animation:float 3s ease-in-out infinite;flex-shrink:0;}
    .av-ring img{width:100%;height:100%;object-fit:cover;}
    .av-fallback{width:100%;height:100%;background:radial-gradient(circle,#ff6eb4,#8b0057);display:flex;align-items:center;justify-content:center;}
    .av-fallback svg{width:72px;height:72px;}
    @keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-10px);}}
    .t-main{font-size:28px;font-weight:600;color:#fff;text-shadow:0 0 20px var(--glow);letter-spacing:4px;text-align:center;}
    .t-sub{font-size:14px;color:var(--pks);letter-spacing:2px;}
    .btn-row{display:flex;gap:12px;margin-top:8px;}
    .btn{padding:10px 28px;border:1.5px solid var(--pk);background:rgba(255,0,128,0.12);color:#fff;font-family:inherit;font-size:14px;letter-spacing:2px;cursor:pointer;border-radius:4px;transition:.2s;}
    .btn:hover{background:rgba(255,0,128,0.3);box-shadow:0 0 12px var(--glow);}
    .btn.sec{border-color:var(--lav);background:rgba(200,160,212,0.1);color:var(--lav);}
    .btn.sec:hover{background:rgba(200,160,212,0.25);}

    /* BRIEF */
    .brief-box{background:rgba(18,0,24,0.9);border:1px solid rgba(255,0,128,0.3);border-radius:12px;padding:28px 32px;max-width:480px;width:100%;text-align:center;}
    .day-label{font-size:11px;letter-spacing:3px;color:var(--pk);text-transform:uppercase;margin-bottom:6px;}
    .day-title{font-size:22px;color:#fff;margin-bottom:4px;}
    .day-theme{font-size:13px;color:var(--pks);margin-bottom:20px;}
    .brief-section{text-align:left;margin-bottom:14px;}
    .brief-section h4{font-size:11px;letter-spacing:2px;color:var(--lav);margin-bottom:8px;}
    .em-tags{display:flex;flex-wrap:wrap;gap:6px;}
    .em-tag{padding:4px 10px;border-radius:20px;font-size:12px;border:1px solid;}

    /* GAME */
    #sg{padding:0;flex-direction:column;}
    .hud{flex-shrink:0;padding:10px 16px;background:rgba(10,0,16,0.85);border-bottom:1px solid rgba(255,0,128,0.2);z-index:20;}
    .hud-row1{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
    .hud-day{font-size:12px;color:var(--pks);letter-spacing:1px;}
    .hud-timer{font-size:18px;font-weight:600;color:#fff;transition:color .3s;}
    .hud-timer.warn{color:#ff3333;animation:blink .6s step-end infinite;}
    @keyframes blink{50%{opacity:0;}}
    .energy-bar-wrap{height:8px;background:rgba(255,255,255,0.1);border-radius:4px;overflow:hidden;}
    .energy-bar-fill{height:100%;background:linear-gradient(90deg,var(--pk),var(--pks));border-radius:4px;transition:width .3s;box-shadow:0 0 8px var(--glow);}
    .energy-bar-fill.lv2{background:linear-gradient(90deg,#ffd700,#ffaa00);box-shadow:0 0 8px rgba(255,215,0,0.6);}
    .energy-bar-fill.lv3{background:linear-gradient(90deg,#c8a0d4,#8b00ff);box-shadow:0 0 8px rgba(200,160,212,0.6);}
    .energy-bar-fill.lv4{background:linear-gradient(90deg,#ff0080,#ffd700,#00ff88,#0088ff);background-size:200%;animation:rainbow-bar 1s linear infinite;box-shadow:0 0 12px rgba(255,0,128,0.8);}
    @keyframes rainbow-bar{0%{background-position:0%}100%{background-position:200%}}
    .hud-row3{display:flex;justify-content:space-between;margin-top:4px;}
    .hud-label{font-size:10px;color:#8a6070;letter-spacing:1px;}
    .hud-pct{font-size:10px;color:var(--pk);}
    .game-field{flex:1;width:100%;position:relative;overflow:hidden;}
    .portrait{position:absolute;bottom:0;left:0;width:110px;height:150px;z-index:5;pointer-events:none;overflow:hidden;-webkit-mask-image:linear-gradient(180deg,black 50%,transparent 100%);mask-image:linear-gradient(180deg,black 50%,transparent 100%);}
    .portrait img{width:100%;height:100%;object-fit:cover;object-position:top center;}
    .portrait-fallback{width:100%;height:100%;background:linear-gradient(180deg,#8b0057,#400028);display:flex;align-items:center;justify-content:center;}
    .portrait-fallback svg{width:60px;height:60px;}
    .portrait.hit-good{animation:glow-good .4s ease;}
    .portrait.hit-bad{animation:shake .4s ease;}
    @keyframes glow-good{0%,100%{filter:none;}50%{filter:drop-shadow(0 0 14px #ff6eb4);}}
    @keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}

    /* BUBBLES */
    .bubble{position:absolute;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;border:1.5px solid;transition:transform .1s;z-index:10;}
    .bubble:hover{transform:scale(1.08);}
    .bubble .b-emoji{font-size:18px;line-height:1;}
    .bubble .b-name{font-size:9px;margin-top:2px;opacity:.8;}
    .bubble.burst{animation:burst .3s ease forwards;pointer-events:none;}
    @keyframes burst{0%{transform:scale(1);opacity:1;}100%{transform:scale(2.2);opacity:0;}}

    /* SCORE POPUP */
    .score-pop{position:absolute;font-size:13px;font-weight:600;pointer-events:none;z-index:30;animation:pop-up .9s ease forwards;}
    @keyframes pop-up{0%{opacity:1;transform:translateY(0);}100%{opacity:0;transform:translateY(-50px);}}

    /* COMBO BADGE */
    #combo-badge{padding:2px 8px;border-radius:10px;transition:all .2s;}
    #combo-badge.c2{color:#fff;background:rgba(255,0,128,0.2);border:1px solid rgba(255,0,128,0.4);}
    #combo-badge.c3{color:#ff6eb4;background:rgba(255,0,128,0.3);animation:pulse-badge .6s ease infinite alternate;}
    #combo-badge.c5{color:#ffd700;background:rgba(255,215,0,0.2);border:1px solid rgba(255,215,0,0.5);animation:pulse-badge .4s ease infinite alternate;}
    @keyframes pulse-badge{from{box-shadow:0 0 4px currentColor;}to{box-shadow:0 0 12px currentColor;}}

    /* ENERGY SHAKE */
    @keyframes shake-small{0%,100%{transform:translateX(0);}33%{transform:translateX(-3px);}66%{transform:translateX(3px);}}
    .shake-small{animation:shake-small .3s ease;}

    /* DIALOGUE */
    .dlg-box{background:rgba(12,0,18,0.95);border:1px solid rgba(255,0,128,0.35);border-radius:12px;max-width:500px;width:100%;padding:0;overflow:hidden;}
    .dlg-head{display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid rgba(255,0,128,0.15);}
    .dlg-av{width:48px;height:48px;border-radius:50%;overflow:hidden;border:2px solid var(--pk);flex-shrink:0;}
    .dlg-av img{width:100%;height:100%;object-fit:cover;}
    .dlg-speaker{font-size:13px;color:var(--pk);letter-spacing:1px;}
    .dlg-body{padding:16px 20px;min-height:70px;}
    .dlg-text{font-size:15px;color:#f0d8e8;line-height:1.8;}
    .dlg-foot{padding:12px 20px;text-align:right;}

    /* SUMMARY */
    .sum-box{background:rgba(12,0,18,0.95);border:1px solid rgba(255,0,128,0.3);border-radius:12px;max-width:420px;width:100%;padding:32px;text-align:center;}
    .sum-pct{font-size:56px;font-weight:600;color:var(--pk);text-shadow:0 0 24px var(--glow);}
    .sum-stars{font-size:28px;letter-spacing:4px;margin:8px 0;}
    .sum-msg{font-size:13px;color:var(--pks);margin-bottom:20px;}

    /* ENDING */
    .end-fin{font-size:20px;color:var(--gold);letter-spacing:6px;text-shadow:0 0 20px rgba(240,200,64,0.8),0 0 40px rgba(255,0,128,0.4);animation:float 2s ease-in-out infinite;}
  </style>
</head>
