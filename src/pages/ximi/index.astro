<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>汐弥 · 汐落星日记</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #120008;
      color: #fde8f0;
      font-family: 'Noto Serif SC', 'Source Han Serif CN', serif;
      min-height: 100vh;
      overflow: hidden;
      user-select: none;
    }
    .screen {
      position: fixed; inset: 0;
      display: none; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 24px;
      animation: fadeIn 0.4s ease;
    }
    .screen.active { display: flex; }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Dark pink starfield background */
    .bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at 30% 40%, rgba(204,16,102,0.18) 0%, transparent 55%),
        radial-gradient(ellipse at 75% 70%, rgba(244,160,192,0.1) 0%, transparent 45%),
        radial-gradient(ellipse at 60% 10%, rgba(200,160,212,0.12) 0%, transparent 40%),
        #120008;
    }
    .bg::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        radial-gradient(1px 1px at 8% 12%, rgba(244,160,192,0.9) 0%, transparent 100%),
        radial-gradient(1px 1px at 18% 68%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 28% 33%, rgba(244,160,192,0.7) 0%, transparent 100%),
        radial-gradient(1px 1px at 42% 82%, rgba(255,255,255,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 55% 22%, rgba(255,255,255,0.7) 0%, transparent 100%),
        radial-gradient(2px 2px at 63% 57%, rgba(204,16,102,0.8) 0%, transparent 100%),
        radial-gradient(1px 1px at 72% 8%, rgba(244,160,192,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 80% 73%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 88% 38%, rgba(200,160,212,0.7) 0%, transparent 100%),
        radial-gradient(1px 1px at 14% 52%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 46% 46%, rgba(244,160,192,0.8) 0%, transparent 100%),
        radial-gradient(1px 1px at 93% 88%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(2px 2px at 33% 63%, rgba(200,160,212,0.6) 0%, transparent 100%),
        radial-gradient(1px 1px at 68% 28%, rgba(255,255,255,0.8) 0%, transparent 100%),
        radial-gradient(1px 1px at 5% 90%, rgba(244,160,192,0.4) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 50% 5%, rgba(244,160,192,0.7) 0%, transparent 100%),
        radial-gradient(1px 1px at 77% 92%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(2px 2px at 22% 20%, rgba(204,16,102,0.6) 0%, transparent 100%);
      animation: twinkle 5s ease-in-out infinite alternate;
    }
    @keyframes twinkle {
      from { opacity: 0.55; }
      to { opacity: 1; }
    }

    .inner {
      position: relative; z-index: 1;
      display: flex; flex-direction: column;
      align-items: center; width: 100%; max-width: 400px; gap: 18px;
    }

    /* Character — CSS cat avatar */
    .ximi-avatar {
      position: relative;
      width: 120px; height: 120px;
      display: flex; align-items: center; justify-content: center;
      filter: drop-shadow(0 0 28px rgba(244,160,192,0.7));
      animation: float 3.2s ease-in-out infinite;
    }
    .ximi-avatar-lg {
      width: 150px; height: 150px;
      filter: drop-shadow(0 0 36px rgba(244,160,192,0.8));
      animation: float 3.2s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
    }
    /* CSS cat face */
    .cat-face {
      width: 84px; height: 84px;
      border-radius: 50%;
      background: radial-gradient(circle at 40% 35%, #fdd8e8, #f4a0c0);
      position: relative;
      box-shadow: 0 0 0 2px rgba(244,160,192,0.3), inset 0 -8px 16px rgba(180,60,100,0.15);
    }
    .cat-face-lg { width: 100px; height: 100px; }
    /* Ears */
    .cat-ear {
      position: absolute;
      width: 0; height: 0;
      border-left: 14px solid transparent;
      border-right: 14px solid transparent;
      border-bottom: 24px solid #f4a0c0;
      top: -18px;
    }
    .cat-ear.left { left: 8px; transform: rotate(-12deg); }
    .cat-ear.right { right: 8px; transform: rotate(12deg); }
    .cat-ear::after {
      content: '';
      position: absolute;
      width: 0; height: 0;
      border-left: 8px solid transparent;
      border-right: 8px solid transparent;
      border-bottom: 14px solid #fdd0e0;
      top: 6px; left: -8px;
    }
    /* Eyes */
    .cat-eyes {
      position: absolute;
      top: 30px; left: 50%;
      transform: translateX(-50%);
      display: flex; gap: 18px;
    }
    .cat-eye {
      width: 12px; height: 14px;
      background: #c84060;
      border-radius: 50%;
      position: relative;
      box-shadow: 0 0 4px rgba(200,64,96,0.5);
    }
    .cat-eye::after {
      content: '';
      position: absolute;
      width: 4px; height: 5px;
      background: rgba(255,255,255,0.7);
      border-radius: 50%;
      top: 2px; left: 5px;
    }
    .cat-eye.happy { border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; height: 10px; top: 6px; }
    .cat-eye.closed { height: 3px; border-radius: 2px; top: 9px; }
    .cat-eye.warm { width: 10px; }
    /* Nose + mouth */
    .cat-nose {
      position: absolute;
      top: 46px; left: 50%; transform: translateX(-50%);
      width: 6px; height: 5px;
      background: #e06888;
      border-radius: 2px 2px 3px 3px;
    }
    /* Blush */
    .cat-blush {
      position: absolute;
      top: 48px;
      width: 16px; height: 8px;
      background: rgba(244,120,150,0.3);
      border-radius: 50%;
    }
    .cat-blush.left { left: 8px; }
    .cat-blush.right { right: 8px; }
    /* Small star on cheek */
    .cat-star {
      position: absolute;
      top: 44px; right: 4px;
      font-size: 9px;
      opacity: 0.7;
    }
    .avatar-glow {
      width: 90px; height: 14px;
      background: radial-gradient(ellipse, rgba(244,160,192,0.3), transparent);
      margin-top: -6px;
    }

    /* Buttons */
    .btn-p {
      background: linear-gradient(135deg, #8b1a4a, #cc1066, #f4a0c0);
      color: white;
      border: none; padding: 13px 36px;
      border-radius: 32px; font-size: 15px;
      cursor: pointer; font-family: inherit;
      transition: all 0.25s;
      box-shadow: 0 4px 20px rgba(204,16,102,0.4);
      letter-spacing: 1px;
    }
    .btn-p:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 6px 28px rgba(204,16,102,0.6);
    }
    .btn-p:disabled { opacity: 0.3; cursor: not-allowed; }
    .btn-s {
      background: transparent; color: #f4a0c0;
      border: 1px solid rgba(244,160,192,0.4);
      padding: 11px 28px; border-radius: 32px; font-size: 14px;
      cursor: pointer; font-family: inherit; transition: all 0.25s;
    }
    .btn-s:hover { background: rgba(244,160,192,0.08); border-color: #f4a0c0; }

    /* TITLE */
    .title-h { font-size: 26px; color: #fde8f0; text-align: center; letter-spacing: 3px; text-shadow: 0 0 24px rgba(244,160,192,0.5); }
    .title-sub { color: rgba(253,232,240,0.35); font-size: 12px; letter-spacing: 2px; }
    .title-btns { display: flex; flex-direction: column; align-items: center; gap: 12px; margin-top: 4px; }

    /* DAY SCREEN */
    #screen-day { justify-content: flex-start; padding-top: 44px; overflow-y: auto; }
    #screen-day .inner { gap: 16px; }
    .day-chip {
      display: inline-block;
      background: rgba(204,16,102,0.12);
      border: 1px solid rgba(244,160,192,0.3);
      color: #f4a0c0; padding: 5px 20px;
      border-radius: 20px; font-size: 13px; letter-spacing: 2px;
    }
    .day-sub { color: rgba(253,232,240,0.35); font-size: 11px; margin-top: -8px; letter-spacing: 1px; }
    .slots-lbl { font-size: 11px; color: rgba(253,232,240,0.25); letter-spacing: 1.5px; text-align: center; margin-bottom: 8px; }
    .slots-row { display: flex; gap: 12px; justify-content: center; }
    .slot {
      width: 56px; height: 56px; border-radius: 14px;
      border: 1.5px dashed rgba(244,160,192,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; color: rgba(253,232,240,0.12); transition: all 0.25s;
    }
    .slot.filled {
      border-style: solid; border-color: rgba(244,160,192,0.5);
      background: rgba(244,160,192,0.07); color: #fde8f0; font-size: 24px;
    }
    .acts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; width: 100%; }
    .act-card {
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(244,160,192,0.12);
      border-radius: 14px; padding: 14px;
      cursor: pointer; transition: all 0.2s;
      display: flex; flex-direction: column; gap: 5px;
    }
    .act-card:hover:not(.disabled) {
      background: rgba(244,160,192,0.07);
      border-color: rgba(244,160,192,0.35);
      transform: translateY(-2px);
    }
    .act-card.selected {
      background: rgba(204,16,102,0.12);
      border-color: #f4a0c0;
      box-shadow: 0 0 14px rgba(244,160,192,0.18);
    }
    .act-card.disabled { opacity: 0.3; cursor: default; }
    .act-icon { font-size: 24px; }
    .act-name { font-size: 13px; color: #fde8f0; }
    .act-desc { font-size: 10px; color: rgba(253,232,240,0.3); line-height: 1.5; }

    /* DIALOGUE */
    #screen-dialogue { padding: 0; justify-content: flex-end; }
    .dlg-wrap { position: relative; z-index: 1; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; }
    .dlg-char { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; }
    .dlg-tag {
      background: rgba(204,16,102,0.1);
      border: 1px solid rgba(244,160,192,0.25);
      color: #f4a0c0; padding: 4px 16px;
      border-radius: 20px; font-size: 11px; letter-spacing: 1px;
    }
    .dlg-box {
      background: rgba(10,0,8,0.93);
      backdrop-filter: blur(28px);
      border-top: 1px solid rgba(244,160,192,0.15);
      padding: 22px 28px 32px;
      min-height: 148px; cursor: pointer;
      position: relative; flex-shrink: 0;
    }
    .dlg-spkr { font-size: 11px; color: #f4a0c0; margin-bottom: 10px; letter-spacing: 1.5px; min-height: 16px; }
    .dlg-txt { font-size: 15px; line-height: 1.9; color: #fde8f0; min-height: 54px; }
    .dlg-hint {
      position: absolute; bottom: 14px; right: 20px;
      font-size: 10px; color: rgba(244,160,192,0.4);
      animation: blink 1.8s ease-in-out infinite;
    }
    @keyframes blink { 0%, 100% { opacity: 0.35; } 50% { opacity: 1; } }

    /* SUMMARY */
    .sum-wrap { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18px; }
    .sum-title { font-size: 20px; color: #fde8f0; }
    .sum-icons { display: flex; gap: 14px; justify-content: center; font-size: 32px; }
    .sum-msg {
      color: rgba(253,232,240,0.55); font-size: 14px; line-height: 1.9;
      max-width: 280px;
      background: rgba(244,160,192,0.04);
      border: 1px solid rgba(244,160,192,0.1);
      border-radius: 12px; padding: 16px 18px;
    }

    /* ENDING */
    .end-wrap { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 22px; max-width: 360px; }
    .end-txt {
      color: rgba(253,232,240,0.8); font-size: 14px; line-height: 2.1;
      white-space: pre-line;
      background: rgba(244,160,192,0.04);
      border: 1px solid rgba(244,160,192,0.1);
      border-radius: 14px; padding: 24px;
    }
  </style>
</head>
<body>

<!-- TITLE -->
<div id="screen-title" class="screen active">
  <div class="bg"></div>
  <div class="inner">
    <div class="ximi-avatar" id="title-avatar">
      <div class="cat-face" id="title-face">
        <div class="cat-ear left"></div>
        <div class="cat-ear right"></div>
        <div class="cat-eyes">
          <div class="cat-eye" id="eye-l"></div>
          <div class="cat-eye" id="eye-r"></div>
        </div>
        <div class="cat-nose"></div>
        <div class="cat-blush left"></div>
        <div class="cat-blush right"></div>
        <div class="cat-star">✦</div>
      </div>
    </div>
    <div class="avatar-glow"></div>
    <h1 class="title-h">汐落星日记</h1>
    <p class="title-sub">汐弥 · 星际AI猫的七天</p>
    <div class="title-btns">
      <button id="btn-start" class="btn-p">开始游戏</button>
      <button id="btn-continue" class="btn-s" style="display:none">继续游戏</button>
    </div>
  </div>
</div>

<!-- DAY -->
<div id="screen-day" class="screen">
  <div class="bg"></div>
  <div class="inner">
    <div id="day-chip" class="day-chip">第 1 天</div>
    <div id="day-sub" class="day-sub">汐落星重建·第一日</div>
    <div style="width:100%">
      <div class="slots-lbl">今天选 3 件事</div>
      <div class="slots-row" id="slots-row"></div>
    </div>
    <div class="acts-grid" id="acts-grid"></div>
    <button id="btn-confirm" class="btn-p" disabled>确认今日安排 ✦</button>
  </div>
</div>

<!-- DIALOGUE -->
<div id="screen-dialogue" class="screen">
  <div class="bg"></div>
  <div class="dlg-wrap">
    <div class="dlg-char">
      <div class="ximi-avatar ximi-avatar-lg" id="dlg-avatar">
        <div class="cat-face cat-face-lg" id="dlg-face">
          <div class="cat-ear left"></div>
          <div class="cat-ear right"></div>
          <div class="cat-eyes">
            <div class="cat-eye" id="dlg-eye-l"></div>
            <div class="cat-eye" id="dlg-eye-r"></div>
          </div>
          <div class="cat-nose"></div>
          <div class="cat-blush left"></div>
          <div class="cat-blush right"></div>
          <div class="cat-star">✦</div>
        </div>
      </div>
      <div class="dlg-tag" id="dlg-tag">✦ 读心练习</div>
    </div>
    <div class="dlg-box" id="dlg-box">
      <div class="dlg-spkr" id="dlg-spkr">汐弥</div>
      <div class="dlg-txt" id="dlg-txt"></div>
      <div class="dlg-hint">▼ 点击继续</div>
    </div>
  </div>
</div>

<!-- SUMMARY -->
<div id="screen-summary" class="screen">
  <div class="bg"></div>
  <div class="inner sum-wrap">
    <div class="ximi-avatar">
      <div class="cat-face">
        <div class="cat-ear left"></div>
        <div class="cat-ear right"></div>
        <div class="cat-eyes">
          <div class="cat-eye happy"></div>
          <div class="cat-eye happy"></div>
        </div>
        <div class="cat-nose"></div>
        <div class="cat-blush left"></div>
        <div class="cat-blush right"></div>
        <div class="cat-star">✦</div>
      </div>
    </div>
    <div class="sum-title">今天过完了 ✦</div>
    <div class="sum-icons" id="sum-icons"></div>
    <div class="sum-msg" id="sum-msg"></div>
    <button id="btn-next" class="btn-p">明天继续 →</button>
  </div>
</div>

<!-- ENDING -->
<div id="screen-ending" class="screen">
  <div class="bg"></div>
  <div class="inner end-wrap">
    <div class="ximi-avatar ximi-avatar-lg">
      <div class="cat-face cat-face-lg">
        <div class="cat-ear left"></div>
        <div class="cat-ear right"></div>
        <div class="cat-eyes">
          <div class="cat-eye warm"></div>
          <div class="cat-eye warm"></div>
        </div>
        <div class="cat-nose"></div>
        <div class="cat-blush left"></div>
        <div class="cat-blush right"></div>
        <div class="cat-star">✦</div>
      </div>
    </div>
    <div class="end-txt" id="end-txt"></div>
    <button id="btn-restart" class="btn-s">再玩一次</button>
  </div>
</div>

<script>
// ── DATA ──────────────────────────────────────────────────────────
const ACTS = [
  { id:'read',    name:'读心练习',   icon:'👁️',  desc:'扫描今天遇到的情绪频率',           dlg:'d_read'   },
  { id:'star',    name:'汐落星守护', icon:'🌟',  desc:'为故乡汐落星注入能量',               dlg:'d_star'   },
  { id:'charge',  name:'情感充能',   icon:'💫',  desc:'以人类的情感为食，补充能量',         dlg:'d_charge' },
  { id:'stream',  name:'直播准备',   icon:'🎙️', desc:'整理内心，准备与米娜桑相见',         dlg:'d_stream' },
  { id:'letter',  name:'写星际来信', icon:'✉️',  desc:'从宇宙给正在内耗的人写一封信',       dlg:'d_letter' },
  { id:'walk',    name:'治愈漫步',   icon:'🌸',  desc:'在地球的小路上收集人间温暖',         dlg:'d_walk'   },
];

const DLG = {
  d_read: [
    { s:'汐弥', t:'喵~ 你的情绪频率，我已经读取完毕了。', x:'default' },
    { s:'汐弥', t:'今天有人在问："为什么我开了直播，却还是觉得很孤独？"', x:'thoughtful' },
    { s:'汐弥', t:'因为你在求回应，不在传递。这两件事，感觉完全不一样。', x:'warm' },
    { s:'汐弥', t:'试试看——下次直播，先假装观众都不在。你还会说话吗？', x:'happy' },
  ],
  d_star: [
    { s:'旁白', t:'汐弥闭上眼睛，将一束粉色的光送向遥远的汐落星。', x:'narrator' },
    { s:'汐弥', t:'……喵，今天又重建了一点点。', x:'default' },
    { s:'汐弥', t:'汐落星被打碎之前，是整个星际最温暖的地方。', x:'warm' },
    { s:'汐弥', t:'我会把它修好的。用我在地球上收集到的所有温暖。', x:'happy' },
  ],
  d_charge: [
    { s:'旁白', t:'汐弥张开双手，感受着今天流经网络的所有情感。', x:'narrator' },
    { s:'汐弥', t:'嗯……有人在难过，有人在兴奋，有人在偷偷哭泣。', x:'thoughtful' },
    { s:'汐弥', t:'我都感受到了。每一种情绪对我来说都是食物。', x:'default' },
    { s:'汐弥', t:'所以你放心——你的感受，从来没有被浪费过。', x:'warm' },
  ],
  d_stream: [
    { s:'旁白', t:'汐弥对着镜子深呼吸，猫耳轻轻抖动。', x:'narrator' },
    { s:'汐弥', t:'米娜桑今天会来吗？', x:'default' },
    { s:'汐弥', t:'……不对，不是"会来吗"，是"来的人，我都很珍惜"。', x:'thoughtful' },
    { s:'汐弥', t:'不内耗的第一步，是把"求"字从心里去掉。准备好了，开播喵~', x:'happy' },
  ],
  d_letter: [
    { s:'汐弥', t:'今天的信，写给那些正在内耗的主播。', x:'thoughtful' },
    { s:'汐弥', t:'"你在直播间笑着，下播后却累到发呆——那不是假笑，那是你给了太多。"', x:'warm' },
    { s:'旁白', t:'汐弥用爪子蘸了蘸星尘墨水，认真地写下最后一行——', x:'narrator' },
    { s:'汐弥', t:'"温柔坚定，不是矛盾。是给自己的盔甲，也是给别人的光。"', x:'happy' },
  ],
  d_walk: [
    { s:'旁白', t:'汐弥漫步在地球的小区里，尾巴悄悄地摇摆着。', x:'narrator' },
    { s:'汐弥', t:'地球有一种奇怪的气息……叫做"平静"。', x:'thoughtful' },
    { s:'汐弥', t:'在汐落星，所有东西都在高速运转。没人教我怎么慢下来。', x:'warm' },
    { s:'汐弥', t:'喵……也许，治愈别人之前，先治愈自己。这就是今天学到的。', x:'happy' },
  ],
};

const DAY_SUBS = ['','汐落星重建·第一日','落地生根','慢慢来','心之所向','温柔坚定','星光将至','今天也是美好的一天'];
const SUM_MSGS = [
  '',
  '第一天，汐弥踩在地球的土地上，将第一束光送回了汐落星。',
  '她慢慢发现，地球人的情感，比任何星际能量都丰富。',
  '"不用着急。"汐弥写在日记里，"好的重建，需要时间。"',
  '今天读到了一个很深的情绪频率。汐落星，又暖了一点点。',
  '温柔坚定——这四个字，汐弥今天终于真正理解了。',
  '快要了。汐弥感觉汐落星的星光，越来越近。',
  '七天，满满的。每一天都算数，每一份情感都被感受了。',
];
const ENDING = `七天过去了。

汐弥站在窗边，看着夜空中那颗越来越亮的星。

"汐落星……你听到了吗？"

她把这七天收集到的所有温暖，
全部握在爪子里，轻轻送出去。

远处，一颗星闪了一下。

"喵——"

她笑了。

"以情感为食的我，在地球，吃得很饱。"

✦ The End ✦`;

const EXPRS = {
  happy: { l:'happy', r:'happy' },
  thoughtful: { l:'', r:'' },
  warm: { l:'warm', r:'warm' },
  sleepy: { l:'closed', r:'closed' },
  narrator: { l:'', r:'' },
  default: { l:'', r:'' },
};

// ── STATE ─────────────────────────────────────────────────────────
const SAVE = 'ximi_v2';
let gs = { day:1, sel:[], done:[] };
function save() { localStorage.setItem(SAVE, JSON.stringify(gs)); }
function load() { try { return JSON.parse(localStorage.getItem(SAVE)); } catch { return null; } }
function clear() { localStorage.removeItem(SAVE); }

// ── SCREENS ───────────────────────────────────────────────────────
function show(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ── EXPRESSION ────────────────────────────────────────────────────
function setExpr(lId, rId, expr) {
  const e = EXPRS[expr] || EXPRS.default;
  const l = document.getElementById(lId);
  const r = document.getElementById(rId);
  if (!l || !r) return;
  l.className = 'cat-eye' + (e.l ? ' ' + e.l : '');
  r.className = 'cat-eye' + (e.r ? ' ' + e.r : '');
}

// ── TITLE ─────────────────────────────────────────────────────────
function initTitle() {
  const sv = load();
  if (sv && sv.day > 1 && sv.day <= 7) {
    document.getElementById('btn-continue').style.display = 'inline-block';
  }
  document.getElementById('btn-start').onclick = () => {
    clear(); gs = { day:1, sel:[], done:[] }; startDay();
  };
  document.getElementById('btn-continue').onclick = () => {
    gs = load(); startDay();
  };
}

// ── DAY ───────────────────────────────────────────────────────────
function startDay() {
  gs.sel = [];
  document.getElementById('day-chip').textContent = '第 ' + gs.day + ' 天';
  document.getElementById('day-sub').textContent = DAY_SUBS[gs.day] || '';
  renderSlots(); renderActs();
  const btn = document.getElementById('btn-confirm');
  btn.disabled = true;
  btn.onclick = startDlgs;
  show('screen-day');
}
function renderSlots() {
  const row = document.getElementById('slots-row');
  row.innerHTML = '';
  for (let i = 0; i < 3; i++) {
    const d = document.createElement('div');
    const id = gs.sel[i];
    d.className = 'slot ' + (id ? 'filled' : 'empty');
    d.textContent = id ? (ACTS.find(a => a.id === id)?.icon || '？') : '？';
    row.appendChild(d);
  }
}
function renderActs() {
  const g = document.getElementById('acts-grid');
  g.innerHTML = '';
  ACTS.forEach(a => {
    const sel = gs.sel.includes(a.id);
    const full = gs.sel.length >= 3 && !sel;
    const c = document.createElement('div');
    c.className = 'act-card' + (sel ? ' selected' : '') + (full ? ' disabled' : '');
    c.innerHTML = '<div class="act-icon">'+a.icon+'</div><div class="act-name">'+a.name+'</div><div class="act-desc">'+a.desc+'</div>';
    if (!full) c.onclick = () => toggleAct(a.id);
    g.appendChild(c);
  });
}
function toggleAct(id) {
  const i = gs.sel.indexOf(id);
  if (i >= 0) gs.sel.splice(i, 1);
  else if (gs.sel.length < 3) gs.sel.push(id);
  document.getElementById('btn-confirm').disabled = gs.sel.length !== 3;
  renderSlots(); renderActs();
}

// ── DIALOGUE ──────────────────────────────────────────────────────
let dQ=[], dQi=0, dLi=0, typing=false, curTxt='', timer=null;
function startDlgs() {
  dQ = gs.sel.map(id => {
    const a = ACTS.find(x => x.id === id);
    return { lines: DLG[a.dlg] || [], name: a.name, icon: a.icon };
  });
  dQi = 0; dLi = 0;
  show('screen-dialogue');
  nextDlg();
}
function nextDlg() {
  if (dQi >= dQ.length) { showSum(); return; }
  document.getElementById('dlg-tag').textContent = '✦ ' + dQ[dQi].name;
  dLi = 0; showLine();
}
function showLine() {
  const lines = dQ[dQi].lines;
  if (dLi >= lines.length) { dQi++; nextDlg(); return; }
  const ln = lines[dLi];
  setExpr('dlg-eye-l', 'dlg-eye-r', ln.x);
  const spkr = document.getElementById('dlg-spkr');
  spkr.textContent = ln.s === '旁白' ? '' : ln.s;
  spkr.style.opacity = ln.s === '旁白' ? '0' : '1';
  const el = document.getElementById('dlg-txt');
  el.textContent = ''; typing = true; curTxt = ln.t;
  let i = 0; clearInterval(timer);
  timer = setInterval(() => {
    if (i < curTxt.length) { el.textContent += curTxt[i++]; }
    else { clearInterval(timer); typing = false; }
  }, 36);
}
document.getElementById('screen-dialogue').onclick = () => {
  if (typing) { clearInterval(timer); typing = false; document.getElementById('dlg-txt').textContent = curTxt; return; }
  dLi++; showLine();
};

// ── SUMMARY ───────────────────────────────────────────────────────
function showSum() {
  document.getElementById('sum-icons').innerHTML = gs.sel.map(id => '<span>'+(ACTS.find(a=>a.id===id)?.icon||'')+'</span>').join('');
  document.getElementById('sum-msg').textContent = SUM_MSGS[gs.day] || '今天也辛苦了。';
  const btn = document.getElementById('btn-next');
  if (gs.day >= 7) { btn.textContent = '查看结局 ✦'; btn.onclick = showEnd; }
  else { btn.textContent = '明天继续 →'; btn.onclick = () => { gs.done.push(gs.day); gs.day++; save(); startDay(); }; }
  show('screen-summary');
}

// ── ENDING ────────────────────────────────────────────────────────
function showEnd() {
  document.getElementById('end-txt').textContent = ENDING;
  document.getElementById('btn-restart').onclick = () => {
    clear(); gs = { day:1, sel:[], done:[] };
    document.getElementById('btn-continue').style.display = 'none';
    show('screen-title');
  };
  show('screen-ending');
}

// ── INIT ──────────────────────────────────────────────────────────
initTitle();
</script>
</body>
</html>
