      { id: "uat_test_expert", name: "UAT测试专家", score: 92, desc: "用户验收测试策略，缺陷管理流程，测试报告撰写" },
      { id: "training_expert", name: "培训专家", score: 90, desc: "用户培训体系设计，操作手册编写，上线支持" },
