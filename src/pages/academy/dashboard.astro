---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="会员中心 — Synapse 学院（即将推出）">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0A1628 0%, #0d1f3c 100%); padding: 72px 0 56px;">
    <div class="grid-dots"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <a href="/academy" class="inline-flex items-center gap-1.5 text-white/40 text-sm hover:text-white/70 transition-colors mb-6">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        学院首页
      </a>
      <p class="text-xs font-semibold tracking-widest text-[var(--color-muted)] uppercase mb-3">DASHBOARD</p>
      <h1 class="text-4xl font-extrabold text-white mb-4">会员中心</h1>
      <p class="text-white/60 text-lg">版本状态 · 升级历史 · 账户管理</p>
    </div>
  </section>

  <div class="glow-line"></div>

  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <div class="w-16 h-16 rounded-full bg-[#F7F8FA] border-2 border-[var(--color-border)] flex items-center justify-center mx-auto mb-6">
      <svg width="28" height="28" fill="none" stroke="#94A3B8" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    </div>
    <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">即将推出</h2>
    <p class="text-[var(--color-text-light)] mb-8 max-w-md mx-auto">会员中心正在开发中，将支持版本状态追踪、升级历史查看和 Evolution 订阅管理。</p>

    <div class="grid md:grid-cols-3 gap-4 mb-10 text-left">
      {[
        { icon: "📊", title: "版本状态", desc: "当前安装版本 vs 最新版本，一键查看差异" },
        { icon: "📋", title: "升级历史", desc: "每次升级的变更记录，Agent能力进化时间线" },
        { icon: "⚡", title: "Evolution 管理", desc: "订阅状态、自动同步设置、账单管理" },
      ].map(f => (
        <div class="p-4 bg-[#F7F8FA] border border-[var(--color-border)] rounded-xl opacity-60">
          <div class="text-xl mb-2">{f.icon}</div>
          <h3 class="font-semibold text-[var(--color-text)] text-sm mb-1">{f.title}</h3>
          <p class="text-xs text-[var(--color-muted)]">{f.desc}</p>
        </div>
      ))}
    </div>

    <p class="text-sm text-[var(--color-muted)] mb-6">当前版本：对 AI CEO 说 <code class="bg-[#F7F8FA] border border-[var(--color-border)] px-2 py-0.5 rounded font-mono">"升级 Synapse"</code> 查看版本状态</p>

    <div class="flex justify-center gap-4">
      <a href="/academy" class="px-6 py-2.5 border border-[var(--color-border)] rounded-lg text-sm font-semibold text-[var(--color-text)] hover:border-[#028CDC] hover:text-[#028CDC] transition-colors">返回学院</a>
      <a href="/academy/get-synapse" class="px-6 py-2.5 bg-[#FCAD2A] text-[#0A1628] rounded-lg text-sm font-bold hover:opacity-90 transition-opacity">获取 Synapse</a>
    </div>
  </div>
</Layout>
