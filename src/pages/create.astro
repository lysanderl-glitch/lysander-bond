---
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>AI 游戏工厂 · Synapse</title>
  <meta name="description" content="告诉我你想要什么游戏，Synapse 来帮你做"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --pk: #FF0080;
      --pks: #F4A0C0;
      --lav: #C8A0D4;
      --dark: #0a0010;
      --dark2: #120018;
      --card-bg: rgba(18, 0, 24, 0.9);
      --glow: rgba(255, 0, 128, 0.5);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--dark);
      color: #fde8f0;
      font-family: 'Noto Serif SC', 'PingFang SC', 'Microsoft YaHei', serif;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,0,128,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,0,128,0.05) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
      pointer-events: none;
      z-index: 0;
    }

    .page {
      position: relative;
      z-index: 1;
      max-width: 680px;
      margin: 0 auto;
      padding: 60px 24px 80px;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 48px;
      animation: fadeUp 0.8s ease both;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--pks);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      opacity: 0.7;
      margin-bottom: 32px;
      transition: opacity 0.2s;
    }
    .back-link:hover { opacity: 1; }

    .header-icon {
      font-size: 3rem;
      margin-bottom: 16px;
      display: block;
      filter: drop-shadow(0 0 20px var(--glow));
    }

    .header h1 {
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 700;
      background: linear-gradient(135deg, #fff 0%, var(--pks) 50%, var(--lav) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.2;
      margin-bottom: 12px;
    }

    .header p {
      font-size: 0.95rem;
      color: var(--lav);
      opacity: 0.8;
      font-weight: 300;
      letter-spacing: 0.08em;
    }

    .header-divider {
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, var(--pk), var(--lav));
      margin: 20px auto 0;
      border-radius: 2px;
    }

    /* Form card */
    .form-card {
      background: var(--card-bg);
      border: 1px solid rgba(255, 0, 128, 0.3);
      border-radius: 16px;
      padding: 40px 36px;
      animation: fadeUp 1s ease 0.15s both;
    }

    .field {
      margin-bottom: 24px;
    }

    label {
      display: block;
      font-size: 0.88rem;
      letter-spacing: 0.12em;
      color: var(--pks);
      margin-bottom: 8px;
      font-weight: 600;
    }

    input[type="text"],
    textarea {
      width: 100%;
      background: rgba(10, 0, 16, 0.7);
      border: 1px solid rgba(255, 0, 128, 0.25);
      border-radius: 8px;
      color: #fde8f0;
      font-family: inherit;
      font-size: 0.95rem;
      padding: 12px 16px;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    input[type="text"]::placeholder,
    textarea::placeholder {
      color: rgba(253, 232, 240, 0.3);
    }

    input[type="text"]:focus,
    textarea:focus {
      border-color: rgba(255, 0, 128, 0.6);
      box-shadow: 0 0 16px rgba(255, 0, 128, 0.15);
    }

    textarea {
      min-height: 160px;
      resize: vertical;
      line-height: 1.6;
    }

    .submit-btn {
      width: 100%;
      padding: 14px 28px;
      background: var(--pk);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      cursor: pointer;
      transition: box-shadow 0.2s, opacity 0.2s, transform 0.15s;
      margin-top: 8px;
    }

    .submit-btn:hover:not(:disabled) {
      box-shadow: 0 0 28px rgba(255, 0, 128, 0.6), 0 0 60px rgba(255, 0, 128, 0.2);
      transform: translateY(-1px);
    }

    .submit-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Status */
    .status-box {
      display: none;
      border-radius: 12px;
      padding: 24px 28px;
      margin-top: 24px;
      animation: fadeUp 0.5s ease both;
    }

    .status-box.success {
      background: rgba(0, 200, 80, 0.08);
      border: 1px solid rgba(0, 200, 80, 0.4);
    }

    .status-box.error {
      background: rgba(255, 60, 60, 0.08);
      border: 1px solid rgba(255, 60, 60, 0.4);
    }

    .status-box.show { display: block; }

    .status-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .status-box.success .status-title { color: #4ade80; }
    .status-box.error .status-title { color: #f87171; }

    .status-body {
      font-size: 0.88rem;
      color: rgba(253, 232, 240, 0.7);
      line-height: 1.6;
    }

    .job-id {
      font-family: 'Courier New', monospace;
      background: rgba(255, 0, 128, 0.15);
      color: var(--pks);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.9em;
    }

    /* History */
    .history-section {
      margin-top: 48px;
      animation: fadeUp 1s ease 0.3s both;
    }

    .history-title {
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      color: var(--lav);
      text-transform: uppercase;
      margin-bottom: 16px;
      opacity: 0.7;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .history-empty {
      background: rgba(18, 0, 24, 0.5);
      border: 1px dashed rgba(255, 0, 128, 0.15);
      border-radius: 12px;
      padding: 28px;
      text-align: center;
      color: rgba(253, 232, 240, 0.3);
      font-size: 0.88rem;
      letter-spacing: 0.06em;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .form-card { padding: 28px 20px; }
    }
  </style>
</head>
<body>
  <div class="page">

    <!-- Header -->
    <header class="header">
      <a href="/games" class="back-link">← 返回游戏画廊</a>
      <span class="header-icon">🎮</span>
      <h1>AI 游戏工厂</h1>
      <p>告诉我你想要什么游戏，Synapse 来帮你做</p>
      <div class="header-divider"></div>
    </header>

    <!-- Form Card -->
    <div class="form-card">
      <form id="game-form">
        <div class="field">
          <label for="game-title">游戏名称</label>
          <input
            type="text"
            id="game-title"
            name="game_title"
            placeholder="如：泡泡射击、星际跑酷..."
            required
          />
        </div>
        <div class="field">
          <label for="game-body">游戏需求</label>
          <textarea
            id="game-body"
            name="requirement_body"
            placeholder="详细描述你想要的游戏玩法、主题、特色..."
            required
          ></textarea>
        </div>
        <button type="submit" class="submit-btn" id="submit-btn">提交需求 →</button>
      </form>

      <!-- Success state -->
      <div class="status-box success" id="status-success">
        <div class="status-title">✅ 已提交！</div>
        <div class="status-body">
          Job ID: <span class="job-id" id="job-id-display"></span><br/>
          Synapse 正在执行，预计 5-15 分钟后完成<br/>
          完成后将通过 Slack 通知你
        </div>
      </div>

      <!-- Error state -->
      <div class="status-box error" id="status-error">
        <div class="status-title">⚠️ 提交失败</div>
        <div class="status-body" id="error-message"></div>
      </div>
    </div>

    <!-- History Section -->
    <section class="history-section">
      <div class="history-title">📋 最近的游戏</div>
      <div class="history-empty">暂无记录</div>
    </section>

  </div>

  <!-- N8N_WEBHOOK: replace PLACEHOLDER_N8N_WEBHOOK_URL with actual n8n webhook URL -->
  <script>
    const N8N_WEBHOOK = 'PLACEHOLDER_N8N_WEBHOOK_URL';

    const form = document.getElementById('game-form');
    const btn = document.getElementById('submit-btn');
    const successBox = document.getElementById('status-success');
    const errorBox = document.getElementById('status-error');
    const jobIdDisplay = document.getElementById('job-id-display');
    const errorMessage = document.getElementById('error-message');

    function showSuccess(jobId) {
      successBox.classList.add('show');
      errorBox.classList.remove('show');
      jobIdDisplay.textContent = jobId;
      form.reset();
    }

    function showError(msg) {
      errorBox.classList.add('show');
      successBox.classList.remove('show');
      errorMessage.textContent = msg;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = '提交中...';
      successBox.classList.remove('show');
      errorBox.classList.remove('show');

      const titleInput = document.getElementById('game-title');
      const bodyInput = document.getElementById('game-body');

      try {
        const res = await fetch(N8N_WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            game_title: titleInput.value.trim(),
            requirement_body: bodyInput.value.trim(),
            timestamp: new Date().toISOString(),
            submitted_by: 'president'
          })
        });

        if (res.ok) {
          const data = await res.json().catch(() => ({}));
          const jobId = data.job_id || ('job-' + Date.now());
          showSuccess(jobId);
        } else {
          showError('提交失败，请重试（HTTP ' + res.status + '）');
        }
      } catch (err) {
        showError('网络错误：' + err.message);
      }

      btn.disabled = false;
      btn.textContent = '提交需求 →';
    });
  </script>
</body>
</html>
