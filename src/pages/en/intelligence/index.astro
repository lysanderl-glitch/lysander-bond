---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dailyPosts = (await getCollection('intelligence-daily'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const decisions = (await getCollection('intelligence-decisions'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const results = (await getCollection('intelligence-results'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<Layout
  title="Self-improve Pipeline | Lysander"
  description="Synapse's evolution layer. A daily 5-step closed loop that turns external signals into verified capability improvements."
  lang="en"
  darkContent={true}
>
  <!-- Hero -->
  <section class="pt-24 pb-12 px-6">
    <div class="max-w-4xl mx-auto text-center hero-stagger">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-400 text-sm font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
        Synapse Evolution Layer · Daily Cycle
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: var(--font-display, 'Fraunces', Georgia, serif); letter-spacing: -0.02em;">Self-improve Pipeline</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        Synapse's evolution layer. A daily 5-step closed loop that turns external signals into verified capability improvements. Not a newsletter — a system upgrade log.
      </p>
    </div>
  </section>

  <!-- 5-Step Self-improve Cycle -->
  <section class="py-4 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-5 gap-2 md:gap-3">
        {[
          { step: '01', en: 'Scan', sub: 'Capture signals' },
          { step: '02', en: 'Bulletin', sub: 'Daily report' },
          { step: '03', en: 'Decision', sub: 'VACE scoring' },
          { step: '04', en: 'Track', sub: 'Dispatch & log' },
          { step: '05', en: 'Evolve', sub: 'Close the loop' },
        ].map(s => (
          <div class="flex flex-col items-center text-center p-3 rounded-lg bg-white/5 border border-white/10">
            <span class="text-xs text-white/30 mb-1">{s.step}</span>
            <span class="text-sm font-semibold text-[#fcad2a]">{s.en}</span>
            <span class="text-xs text-white/50 mt-0.5">{s.sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Three-column content -->
  <section class="py-8 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">

      <!-- Daily Intel -->
      <div data-reveal="left">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-sky-400">📡</span> Daily Intel
          </h2>
          <a href="/en/intelligence/daily" class="text-sm text-sky-400 hover:text-sky-300">All reports →</a>
        </div>
        <div class="space-y-3">
          {dailyPosts.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No reports yet.</div>
          ) : dailyPosts.map(post => (
            <a href={`/en/intelligence/daily/${post.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-sky-500/40 transition-colors group">
              <time class="text-xs text-white/40">{post.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-sky-400 mt-1 line-clamp-2">{post.data.title}</h3>
              <div class="flex gap-2 mt-2">
                <span class="text-xs text-white/40">{post.data.itemCount} items</span>
                {post.data.topScore && <span class="text-xs text-sky-400">Top {post.data.topScore}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Decisions -->
      <div data-reveal>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-[#e9b94a]">⚖️</span> Decisions
          </h2>
          <a href="/en/intelligence/decisions" class="text-sm text-[#e9b94a] hover:text-[#c96442] transition-colors">All decisions →</a>
        </div>
        <div class="space-y-3">
          {decisions.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No decisions yet.</div>
          ) : decisions.map(d => (
            <a href={`/en/intelligence/decisions/${d.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-[#e9b94a]/40 transition-colors group">
              <time class="text-xs text-white/40">{d.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-[#e9b94a] mt-1 line-clamp-2">{d.data.topIntel}</h3>
              <div class="flex gap-2 mt-2 flex-wrap">
                {d.data.executeCount > 0 && <span class="text-xs text-[#e9b94a]">⚡ {d.data.executeCount} executed</span>}
                {d.data.inboxCount > 0 && <span class="text-xs text-sky-400">📥 {d.data.inboxCount} tracked</span>}
                {d.data.topScore && <span class="text-xs text-white/40">top {d.data.topScore}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Results -->
      <div data-reveal="right">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-green-400">🔄</span> Outcomes
          </h2>
          <a href="/en/intelligence/results" class="text-sm text-green-400 hover:text-green-300">All results →</a>
        </div>
        <div class="space-y-3">
          {results.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No results yet.</div>
          ) : results.map(r => (
            <a href={`/en/intelligence/results/${r.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-green-500/40 transition-colors group">
              <time class="text-xs text-white/40">{r.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-green-400 mt-1 line-clamp-2">{r.data.title}</h3>
              <div class="flex gap-2 mt-2">
                <span class="text-xs text-white/40">{r.data.actionsCount} actions</span>
                <span class="text-xs text-green-400">{r.data.completedCount} completed</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
