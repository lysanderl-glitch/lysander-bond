---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dailyPosts = (await getCollection('intelligence-daily'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const decisions = (await getCollection('intelligence-decisions'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const results = (await getCollection('intelligence-results'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<Layout
  title="Intelligence Hub | Lysander"
  description="Synapse AI team's public operations log — daily intel, decisions, and execution results."
  lang="en"
  darkContent={true}
>
  <!-- Hero -->
  <section class="pt-24 pb-12 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-400 text-sm font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
        Updated Daily
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Intelligence Hub</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        Synapse AI team's public operations log.
      </p>
    </div>
  </section>

  <!-- Language notice banner -->
  <section class="px-6 pb-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-start gap-3 px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/20 text-amber-300/80 text-sm leading-relaxed">
        <span class="shrink-0 mt-0.5 text-amber-400">ℹ</span>
        <p>The Intelligence Hub is our operational record system — intelligence reports, decisions, and execution results, maintained in Chinese as our primary working language. An English-summarized version is on our roadmap.</p>
      </div>
    </div>
  </section>

  <!-- Three-column content -->
  <section class="py-8 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">

      <!-- Daily Intel -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-sky-400">📡</span> Daily Intel
          </h2>
          <a href="/en/intelligence/daily" class="text-sm text-sky-400 hover:text-sky-300">All reports →</a>
        </div>
        <div class="space-y-3">
          {dailyPosts.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No reports yet.</div>
          ) : dailyPosts.map(post => (
            <a href={`/en/intelligence/daily/${post.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-sky-500/40 transition-colors group">
              <time class="text-xs text-white/40">{post.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-sky-400 mt-1 line-clamp-2">{post.data.title}</h3>
              <div class="flex gap-2 mt-2">
                <span class="text-xs text-white/40">{post.data.itemCount} items</span>
                {post.data.topScore && <span class="text-xs text-sky-400">Top {post.data.topScore}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Decisions -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-purple-400">⚖️</span> Decisions
          </h2>
          <a href="/en/intelligence/decisions" class="text-sm text-purple-400 hover:text-purple-300">All decisions →</a>
        </div>
        <div class="space-y-3">
          {decisions.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No decisions yet.</div>
          ) : decisions.map(d => (
            <a href={`/en/intelligence/decisions/${d.data.id}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-purple-500/40 transition-colors group">
              <div class="flex items-center gap-2 mb-1">
                <time class="text-xs text-white/40">{d.data.date}</time>
                <span class={`text-xs px-1.5 py-0.5 rounded font-mono ${d.data.decisionLevel === 'L4' ? 'bg-red-500/20 text-red-400' : d.data.decisionLevel === 'L3' ? 'bg-orange-500/20 text-orange-400' : 'bg-white/10 text-white/40'}`}>
                  {d.data.decisionLevel}
                </span>
              </div>
              <h3 class="text-sm font-medium text-white group-hover:text-purple-400 line-clamp-2">{d.data.title}</h3>
            </a>
          ))}
        </div>
      </div>

      <!-- Results -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-green-400">✅</span> Results
          </h2>
          <a href="/en/intelligence/results" class="text-sm text-green-400 hover:text-green-300">All results →</a>
        </div>
        <div class="space-y-3">
          {results.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">No results yet.</div>
          ) : results.map(r => (
            <a href={`/en/intelligence/results/${r.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-green-500/40 transition-colors group">
              <time class="text-xs text-white/40">{r.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-green-400 mt-1 line-clamp-2">{r.data.title}</h3>
              <div class="flex gap-2 mt-2">
                <span class="text-xs text-white/40">{r.data.actionsCount} actions</span>
                <span class="text-xs text-green-400">{r.data.completedCount} completed</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
