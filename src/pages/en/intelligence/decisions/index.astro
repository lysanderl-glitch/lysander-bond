---
import Layout from '../../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const decisions = (await getCollection('intelligence-decisions'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const levelColor = (l: string) => ({
  'L4': 'bg-red-500/20 text-red-400',
  'L3': 'bg-orange-500/20 text-orange-400',
  'L2': 'bg-yellow-500/20 text-yellow-400',
  'L1': 'bg-white/10 text-white/40',
})[l] || 'bg-white/10 text-white/40';
---

<Layout title="Decision Log | Lysander" description="Synapse AI team L3/L4 decision archive — full decision context and expert review." lang="en" darkContent={true}>
  <section class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/en/intelligence" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← Intelligence Hub</a>
      <h1 class="text-3xl font-bold text-white mb-2">Decision Log</h1>
      <p class="text-white/50 mb-10">L3 Lysander decisions / L4 President decisions — full context and expert review process.</p>
      {decisions.length === 0 ? (
        <div class="text-center py-20 text-white/30">No decisions yet. Decisions will appear here automatically once archived.</div>
      ) : (
        <div class="space-y-4">
          {decisions.map(d => (
            <a href={`/en/intelligence/decisions/${d.data.id}`}
               class="flex items-start gap-4 p-5 rounded-xl bg-white/5 border border-white/10 hover:border-purple-500/40 transition-colors group">
              <span class={`flex-shrink-0 text-xs px-2 py-1 rounded font-mono ${levelColor(d.data.decisionLevel)}`}>{d.data.decisionLevel}</span>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-white/40 mb-1">{d.data.date} · {d.data.decidedBy}</div>
                <h2 class="font-semibold text-white group-hover:text-purple-400 mb-1">{d.data.title}</h2>
                <p class="text-sm text-white/50 line-clamp-2">{d.data.summary}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
