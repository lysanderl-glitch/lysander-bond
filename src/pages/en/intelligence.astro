      <div class="bg-[#f0f0f0] px-4 py-2 flex items-center gap-2 border-b border-[#e0e0e0]">
        <div class="flex gap-1.5"><div class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></div><div class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></div><div class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></div></div>
        <div class="flex-1 mx-3"><div class="bg-white rounded px-3 py-0.5 text-[10px] text-[#999] text-center">synapse — daily AI intelligence report</div></div>
      </div>
