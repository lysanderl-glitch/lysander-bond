---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  lang="en"
  title="SCP Course — Synapse Certified Practitioner Badge | Academy"
  description="The Synapse Certified Practitioner badge — eight-hour curriculum, four hands-on labs, mentor review. Online course in development; enterprise track available now."
>
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0A1628 0%, #0d1f3c 100%); padding: 72px 0 56px;">
    <div class="grid-dots"></div>
    <div class="glow-cyan" style="top:-60px; right:-40px; opacity:0.3;"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <a href="/en/academy" class="inline-flex items-center gap-1.5 text-white/40 text-sm hover:text-white/70 transition-colors mb-6">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Academy home
      </a>
      <p class="text-xs font-semibold tracking-widest text-[var(--color-muted)] uppercase mb-3">SCP COURSE</p>
      <h1 class="text-4xl font-extrabold text-white mb-4">Synapse Certified Practitioner — Academy edition.</h1>
      <p class="text-white/60 text-lg">Self-paced certification for the Harness Engineering methodology. Coming soon. Enterprise track available now.</p>
    </div>
  </section>

  <div class="glow-line"></div>

  <div class="max-w-3xl mx-auto px-6 py-20 text-center">
    <div class="w-16 h-16 rounded-full bg-[#F7F8FA] border-2 border-[var(--color-border)] flex items-center justify-center mx-auto mb-6">
      <svg width="28" height="28" fill="none" stroke="#94A3B8" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
    </div>
    <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">What's coming.</h2>
    <p class="text-[var(--color-text-light)] mb-10 max-w-md mx-auto">The Academy edition of the Synapse Certified Practitioner badge is in development. When it ships, it will provide a fully self-paced learning path — no scheduled training, no live workshop dependency.</p>

    <!-- Course preview -->
    <div class="text-left space-y-3 mb-10">
      {[
        { m: "M1", title: "Why Harness Engineering exists", desc: "Real failure cases · the path from problem to methodology", status: "ready" },
        { m: "M2", title: "Guides + Sensors design", desc: "Feedforward and feedback control mechanisms", status: "ready" },
        { m: "M3", title: "The four-tier decision system", desc: "L1 through L4 · the specialist-before-CEO principle", status: "ready" },
        { m: "M4", title: "Agent HR Management", desc: "Capability grading · onboarding gates · auto-audit pipelines", status: "ready" },
        { m: "M5", title: "Intelligence loop and automation", desc: "Daily intel · action loop · self-evolution loop", status: "ready" },
        { m: "Lab", title: "Build your own AI team (4 workshops)", desc: "Hands-on construction · mentor review · SCP badge", status: "coming" },
      ].map(m => (
        <div class={`flex gap-4 items-start p-4 border rounded-xl ${m.status === 'coming' ? 'bg-[#F7F8FA] border-[var(--color-border)] opacity-60' : 'bg-white border-[var(--color-border)]'}`}>
          <span class={`font-black text-sm shrink-0 ${m.status === 'coming' ? 'text-[var(--color-muted)]' : 'text-[#FCAD2A]'}`}>{m.m}</span>
          <div>
            <p class="font-semibold text-[var(--color-text)] text-sm">{m.title}</p>
            <p class="text-xs text-[var(--color-muted)] mt-0.5">{m.desc}</p>
          </div>
          <span class={`ml-auto text-xs px-2 py-0.5 rounded-full shrink-0 ${m.status === 'coming' ? 'bg-[#F7F8FA] text-[var(--color-muted)] border border-[var(--color-border)]' : 'bg-[#028CDC]/10 text-[#028CDC] border border-[#028CDC]/20'}`}>
            {m.status === 'coming' ? 'Coming soon' : 'Content ready'}
          </span>
        </div>
      ))}
    </div>

    <p class="text-sm text-[var(--color-muted)] mb-8">Need SCP today? The <a href="/en/training" class="text-[#028CDC] hover:underline">enterprise track</a> runs as a live workshop with mentor-led reviews and on-the-spot badge issuance — currently the only path to an issued SCP badge.</p>

    <div class="flex justify-center gap-4">
      <a href="/en/training" class="px-6 py-2.5 bg-[#FCAD2A] text-[#0A1628] rounded-lg text-sm font-bold hover:opacity-90 transition-opacity">Learn about enterprise training</a>
      <a href="/en/academy" class="px-6 py-2.5 border border-[var(--color-border)] rounded-lg text-sm font-semibold text-[var(--color-text)] hover:border-[#028CDC] hover:text-[#028CDC] transition-colors">Back to Academy</a>
    </div>
  </div>
</Layout>
