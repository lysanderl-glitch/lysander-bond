---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import TimelineItem from '../../../components/synapse/TimelineItem.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const pipeline = [
  {
    step: 1,
    title: '6:00am Dubai — Task recovery.',
    body: 'Reads active_tasks.yaml. Picks up anything left unblocked.',
  },
  {
    step: 2,
    title: '8:00am Dubai — Intelligence scan.',
    body: 'AI and market signals collected, filtered for practical relevance, rendered as HTML, committed to git.',
  },
  {
    step: 3,
    title: '10:00am Dubai — Action evaluation.',
    body: 'Report recommendations pass a four-expert panel. Approved items dispatch to Harness Ops for execution.',
  },
  {
    step: 4,
    title: 'Completion — Slack notification.',
    body: 'The president gets one line: done, blocked, or awaiting review.',
  },
];
---

<SynapseLayout
  title="Intelligence"
  description="Every morning, your AI team reports for work. A closed daily pipeline: scan, filter, decide, act, report."
  subNavActive="intelligence"
  currentLang="en"
  altLang={{ lang: 'zh', href: '/synapse/intelligence' }}
>
  <Hero
    eyebrow="Intelligence"
    title="Every morning, your AI team reports for work."
    subtitle="Synapse runs a daily intelligence pipeline: scan the AI frontier, filter for signal, evaluate for action, ship the report. No human in the loop. The output is public — and the pipeline itself is part of the product."
    primaryCta={{ label: 'Subscribe to Intelligence Daily', href: '#subscribe' }}
    secondaryCta={{ label: 'See How It Works', href: '/en/synapse/how-it-works' }}
  />

  <PillarSection
    eyebrow="The Daily Pipeline"
    title="Four steps. Before most teams start the day."
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {pipeline.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What makes it different"
    title="A closed intelligence loop — not a newsletter"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        This is not a daily newsletter. It is a closed intelligence loop. Signals come in, decisions come out, actions happen, results return.
      </p>
      <p>
        Every daily report is archived with an outcome — what we learned, what we changed, what we didn't act on and why. Over months, the archive becomes a compounding record of how an organization actually keeps up with AI.
      </p>
    </div>
  </PillarSection>

  <section id="subscribe" class="py-16 px-6" style="background: var(--color-dark, #0A1628);">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">Today's report</p>
      <h2 class="text-2xl font-bold text-white mb-3">Subscribe to Intelligence Daily</h2>
      <p class="text-white/60 mb-8">Daily AI battlefield updates, curated by the Synapse team. Straight to your inbox.</p>
      <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="subscribe-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-sky-400"
        />
        <button
          type="submit"
          id="subscribe-btn"
          class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p id="subscribe-msg" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('subscribe-form');
    const emailInput = document.getElementById('subscribe-email') as HTMLInputElement | null;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
    const msg = document.getElementById('subscribe-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value?.trim();
      if (!email) return;

      if (btn) { btn.disabled = true; btn.textContent = 'Submitting…'; }

      try {
        const res = await fetch('https://n8n.lysander.bond/webhook/blog-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'lysander.bond', lang: 'en', timestamp: new Date().toISOString() })
        });

        if (res.ok) {
          if (msg) {
            msg.textContent = '✅ Subscribed! Your first Intelligence Daily arrives tomorrow morning.';
            msg.className = 'mt-4 text-sm text-sky-400';
          }
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        if (msg) {
          msg.textContent = '⚠️ Submission failed. Please email lysanderl@janusd.io to subscribe manually.';
          msg.className = 'mt-4 text-sm text-yellow-400';
        }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
        msg?.classList.remove('hidden');
      }
    });
  </script>

  <CTABanner
    heading="Run your own intelligence loop."
    body="Synapse ships with the daily pipeline included. Yours starts the first morning you open Claude Code."
    primaryCta={{ label: 'Get Started', href: '/en/synapse/get-started' }}
    secondaryCta={{ label: 'Visit Academy', href: '/en/academy' }}
  />
</SynapseLayout>
