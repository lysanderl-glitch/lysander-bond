---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import TimelineItem from '../../../components/synapse/TimelineItem.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const pipeline = [
  {
    step: 1,
    title: 'Scan — Signal capture',
    body: 'AI frontier and market signals are collected, filtered for actionable value, and staged as raw intel entries.',
  },
  {
    step: 2,
    title: 'Bulletin — Daily intel report',
    body: 'Signals are rendered as an HTML intelligence report, auto-committed to git at 08:00 Dubai and publicly archived.',
  },
  {
    step: 3,
    title: 'Decision — Expert scoring',
    body: 'Multi-dimension expert scoring and action grading — each intel item is labelled execute, track, or defer.',
  },
  {
    step: 4,
    title: 'Track — Dispatch and follow-up',
    body: 'Approved items dispatch to execution teams for continuous cross-session follow-through.',
  },
  {
    step: 5,
    title: 'Evolve — Capability gain',
    body: 'Completed actions become capability improvements. Decisions are archived, pipeline health is checked, next cycle begins.',
  },
];
---

<SynapseLayout
  title="Self-improve Pipeline"
  description="Synapse's evolution layer. A daily 5-step closed loop that turns external signals into verified capability improvements."
  subNavActive="intelligence"
  currentLang="en"
  altLang={{ lang: 'zh', href: '/synapse/intelligence' }}
>
  <Hero
    eyebrow="Self-improve Pipeline"
    title="Every cycle ends with Synapse measurably better than yesterday."
    subtitle="Synapse's evolution layer: a daily 5-step loop — scan signals → publish bulletin → expert score → Lysander dispatch & track → evolve capabilities. L3 items dispatched autonomously by Lysander, L4 items notify the Synapse Owner, L5 items pause for an Owner call; every cycle's output is publicly archived."
    primaryCta={{ label: 'Subscribe to Intelligence Daily', href: '#subscribe' }}
    secondaryCta={{ label: 'View the Archive', href: '/en/intelligence' }}
  />

  <!-- Intelligence archive entry cards -->
  <section class="py-12 px-6 border-t border-white/10">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/en/intelligence/daily" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">📡</div>
          <div>
            <div class="text-white font-semibold mb-1">Daily Intel</div>
            <div class="text-white/50 text-sm">Latest AI signal picks, auto-generated 08:00 Dubai</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">View Archive →</div>
        </a>
        <a href="/en/intelligence/decisions" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">⚖️</div>
          <div>
            <div class="text-white font-semibold mb-1">Decisions</div>
            <div class="text-white/50 text-sm">L1-L4 decision log with reasoning and outcomes</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">Browse Decisions →</div>
        </a>
        <a href="/en/intelligence/results" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">🔄</div>
          <div>
            <div class="text-white font-semibold mb-1">Outcomes</div>
            <div class="text-white/50 text-sm">Capability gains from completed actions, closing each cycle</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">See Outcomes →</div>
        </a>
      </div>
    </div>
  </section>

  <PillarSection
    eyebrow="The Self-improve Pipeline"
    title="Five steps. One system upgrade, every day."
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {pipeline.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What makes it different"
    title="A self-improve pipeline — not a newsletter"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        This is not a daily newsletter. It is Synapse's self-improvement mechanism. Signals come in, decisions come out, actions happen, capabilities improve.
      </p>
      <p>
        Every cycle leaves a verifiable trace — what we learned, what changed, what evolved. Over months, the archive becomes a compounding capability curve: proof of how an AI system continuously improves itself.
      </p>
    </div>
  </PillarSection>

  <section id="subscribe" class="py-16 px-6" style="background: var(--color-dark, #0A1628);">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">Today's report</p>
      <h2 class="text-2xl font-bold text-white mb-3">Subscribe to Intelligence Daily</h2>
      <p class="text-white/60 mb-8">Daily AI battlefield updates, curated by the Synapse team. Straight to your inbox.</p>
      <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="subscribe-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-sky-400"
        />
        <button
          type="submit"
          id="subscribe-btn"
          class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p id="subscribe-msg" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('subscribe-form');
    const emailInput = document.getElementById('subscribe-email') as HTMLInputElement | null;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
    const msg = document.getElementById('subscribe-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value?.trim();
      if (!email) return;

      if (btn) { btn.disabled = true; btn.textContent = 'Submitting…'; }

      try {
        const res = await fetch('https://n8n.lysander.bond/webhook/blog-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'lysander.bond', lang: 'en', timestamp: new Date().toISOString() })
        });

        if (res.ok) {
          if (msg) {
            msg.textContent = '✅ Subscribed! Your first Intelligence Daily arrives tomorrow morning.';
            msg.className = 'mt-4 text-sm text-sky-400';
          }
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        if (msg) {
          msg.textContent = '⚠️ Submission failed. Please email lysanderl@janusd.com to subscribe manually.';
          msg.className = 'mt-4 text-sm text-yellow-400';
        }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
        msg?.classList.remove('hidden');
      }
    });
  </script>

  <CTABanner
    heading="Build your own self-improve pipeline."
    body="Synapse ships with the evolution layer included. Your first cycle starts the morning you open Claude Code."
    primaryCta={{ label: 'Get Started', href: '/en/synapse/get-started' }}
    secondaryCta={{ label: 'Visit Academy', href: '/en/academy' }}
  />
</SynapseLayout>
