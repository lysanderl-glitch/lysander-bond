---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import TimelineItem from '../../../components/synapse/TimelineItem.astro';
import CodeBlock from '../../../components/synapse/CodeBlock.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const installScript = `Invoke-WebRequest -Uri 'https://github.com/lysanderl-glitch/synapse/archive/refs/heads/main.zip' -OutFile "$env:USERPROFILE\\Downloads\\synapse.zip"
Expand-Archive -Path "$env:USERPROFILE\\Downloads\\synapse.zip" -DestinationPath "$env:USERPROFILE\\Claude Code" -Force`;

const dispatchExample = `/dispatch write a one-page brief on our competitor landscape`;
---

<SynapseLayout
  title="Get Started"
  description="Three steps. Five minutes. Your AI CEO on duty. Synapse is designed to work on first load."
  subNavActive="get-started"
  currentLang="en"
  altLang={{ lang: 'zh', href: '/synapse/get-started' }}
>
  <Hero
    eyebrow="Get Started"
    title="Three steps. Five minutes. Your AI CEO on duty."
    subtitle="Synapse is designed to work on first load. No build step. No multi-hour setup. Here is the entire onboarding."
    primaryCta={{ label: 'Download the Bundle', href: '/academy' }}
    secondaryCta={{
      label: 'View on GitHub',
      href: 'https://github.com/lysanderl-glitch/synapse',
      external: true,
    }}
  />

  <PillarSection
    eyebrow="The Five Steps"
    title="From download to first dispatch"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-10">
      <TimelineItem
        step={1}
        title="Get the configuration bundle"
        body="Option A (recommended): Visit /academy to download a personalized bundle. Option B (technical users): Clone on GitHub."
      >
        <CodeBlock
          lang="powershell"
          filename="install.ps1"
          code={installScript}
        />
      </TimelineItem>

      <TimelineItem
        step={2}
        title="Personalize (Option B only)"
        body="Open CLAUDE.md. Global-replace (Ctrl+H) three tokens: Lysander with your CEO's name, 刘子杨 with your own name, Synapse-PJ with your organization. Save."
      />

      <TimelineItem
        step={3}
        title="Open Claude Code"
        body="Launch Claude Code. Open Folder. Pick the directory containing CLAUDE.md."
      />

      <TimelineItem
        step={4}
        title="Say anything"
        body="Send any message. You will receive a greeting confirming identity and team readiness. From that moment the dispatch workflow is active."
      />

      <TimelineItem
        step={5}
        title="Try a dispatch"
        body="Send the command below and watch Graphify take it."
      >
        <CodeBlock
          lang="text"
          filename="claude-code session"
          code={dispatchExample}
        />
      </TimelineItem>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What to try first"
    title="Four commands that show what Synapse is"
  >
    <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-4">
      <div class="bg-gray-900/60 border border-white/10 rounded-xl p-5">
        <code class="text-[#FCAD2A] font-mono text-sm block mb-2">升级 Synapse</code>
        <p class="text-white/60 text-sm">Check for system updates.</p>
      </div>
      <div class="bg-gray-900/60 border border-white/10 rounded-xl p-5">
        <code class="text-[#FCAD2A] font-mono text-sm block mb-2">Open obs/</code>
        <p class="text-white/60 text-sm">See where knowledge accumulates.</p>
      </div>
      <div class="bg-gray-900/60 border border-white/10 rounded-xl p-5">
        <code class="text-[#FCAD2A] font-mono text-sm block mb-2">Edit synapse.yaml</code>
        <p class="text-white/60 text-sm">Enable an optional module like janus or stock.</p>
      </div>
      <div class="bg-gray-900/60 border border-white/10 rounded-xl p-5">
        <code class="text-[#FCAD2A] font-mono text-sm block mb-2">/dispatch …</code>
        <p class="text-white/60 text-sm">Route any task to the right specialist.</p>
      </div>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Troubleshooting"
    title="When you get stuck"
    bordered={true}
  >
    <div class="max-w-2xl mx-auto">
      <ul class="space-y-4">
        <li class="flex items-start gap-3 bg-gray-900/60 border border-white/10 rounded-xl p-5">
          <span class="text-[#FCAD2A] font-semibold shrink-0">Documentation:</span>
          <span class="text-white/70"><code class="font-mono text-sm">COLLEAGUE_GUIDE.md</code> in the repo</span>
        </li>
        <li class="flex items-start gap-3 bg-gray-900/60 border border-white/10 rounded-xl p-5">
          <span class="text-[#FCAD2A] font-semibold shrink-0">Deep dive:</span>
          <span class="text-white/70"><code class="font-mono text-sm">PROPOSAL.md</code> in the repo</span>
        </li>
        <li class="flex items-start gap-3 bg-gray-900/60 border border-white/10 rounded-xl p-5">
          <span class="text-[#FCAD2A] font-semibold shrink-0">Community:</span>
          <a href="https://github.com/lysanderl-glitch/synapse/issues" target="_blank" rel="noopener noreferrer" class="text-sky-400 hover:text-sky-300">GitHub Issues</a>
        </li>
        <li class="flex items-start gap-3 bg-gray-900/60 border border-white/10 rounded-xl p-5">
          <span class="text-[#FCAD2A] font-semibold shrink-0">Paid help:</span>
          <a href="/en/synapse/pricing" class="text-sky-400 hover:text-sky-300">Pricing</a>
        </li>
      </ul>
    </div>
  </PillarSection>

  <CTABanner
    heading="Five minutes from now, your AI CEO is on duty."
    body="Run the install script, say hello, and watch the dispatch workflow kick in."
    primaryCta={{ label: 'Download from Academy', href: '/academy' }}
    secondaryCta={{
      label: 'View on GitHub',
      href: 'https://github.com/lysanderl-glitch/synapse',
      external: true,
    }}
  />
</SynapseLayout>
