---
import Layout from '../../../layouts/Layout.astro';
import SynapseSubNav from '../../../components/synapse/SynapseSubNav.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import FeatureCard from '../../../components/synapse/FeatureCard.astro';
---

<Layout
  darkContent={true}
  lang="en"
  title="Synapse Forge — AI Team Management OS"
  description="Distilled from running 44 AI agents in production at Janus Digital. An AI team management operating system built on Harness Engineering — so any team can forge its own AI workforce."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="/en/synapse/" />
    <link rel="alternate" hreflang="zh-CN" href="/synapse/" />
  </Fragment>
  <SynapseSubNav active="overview" currentLang="en" />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FCAD2A]/5 via-transparent to-sky-900/10 pointer-events-none"></div>
    <div class="max-w-5xl mx-auto px-6 py-24 text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#FCAD2A]/10 border border-[#FCAD2A]/30 rounded-full text-[#FCAD2A] text-xs font-semibold mb-8 tracking-wider uppercase">
        Open Source · Production Proven · 44 Agents
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight mb-6">
        Synapse Forge
        <span class="block text-[#FCAD2A] mt-1">AI Team Management OS</span>
      </h1>
      <p class="text-xl text-white/60 max-w-2xl mx-auto leading-relaxed mb-4">
        Distilled from 44 production AI agents at <strong class="text-white">Janus Digital</strong>.
      </p>
      <p class="text-lg text-white/50 max-w-2xl mx-auto leading-relaxed mb-12">
        Any team can forge its own AI workforce.<br class="hidden md:block"/>
        Not prompt tweaking — engineered <strong class="text-sky-400">Harness Engineering</strong>.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/synapse/get-started"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#FCAD2A] text-gray-900 font-bold rounded-xl hover:bg-[#FCAD2A]/90 transition-all shadow-lg shadow-[#FCAD2A]/20 text-base"
        >
          Get Started
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="/en/synapse/how-it-works"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all text-base"
        >
          See How It Works
        </a>
      </div>
    </div>
  </section>

  <!-- Proof Numbers -->
  <section class="border-y border-white/5 bg-white/2">
    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="grid grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-4xl font-extrabold text-[#FCAD2A] mb-2">44</div>
          <div class="text-white/50 text-sm">Production AI Agents</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-sky-400 mb-2">11</div>
          <div class="text-white/50 text-sm">Functional Modules</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-purple-400 mb-2">5</div>
          <div class="text-white/50 text-sm">Templates, Live in 5 minutes</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three Core Pillars -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">Three Core Pillars</h2>
      <p class="text-white/40 text-sm">What makes Synapse Forge reliable in production</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <!-- Pillar 1: Harness Engineering -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-[#FCAD2A]/30 transition-colors group">
        <div class="w-10 h-10 rounded-xl bg-[#FCAD2A]/10 flex items-center justify-center mb-5 group-hover:bg-[#FCAD2A]/20 transition-colors">
          <svg class="w-5 h-5 text-[#FCAD2A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Harness Engineering</h3>
        <p class="text-xs text-[#FCAD2A]/80 font-mono mb-4">Agent = Model + Harness</p>
        <p class="text-white/50 text-sm leading-relaxed">
          A three-layer governance architecture: Guides (feed-forward) × Workflow (structured process) × Constraints (enforced boundaries).
          Agents stop repeating the same mistakes.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="px-2 py-1 bg-[#FCAD2A]/10 text-[#FCAD2A]/80 rounded text-xs">Feed-forward</span>
          <span class="px-2 py-1 bg-[#FCAD2A]/10 text-[#FCAD2A]/80 rounded text-xs">Feedback sensors</span>
          <span class="px-2 py-1 bg-[#FCAD2A]/10 text-[#FCAD2A]/80 rounded text-xs">Three layers</span>
        </div>
      </div>

      <!-- Pillar 2: CEO Guard -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-sky-500/30 transition-colors group">
        <div class="w-10 h-10 rounded-xl bg-sky-500/10 flex items-center justify-center mb-5 group-hover:bg-sky-500/20 transition-colors">
          <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">CEO Guard Execution Chain</h3>
        <p class="text-xs text-sky-400/80 font-mono mb-4">L1 → L2 → L3 → L4 Decisions</p>
        <p class="text-white/50 text-sm leading-relaxed">
          A four-tier decision system (L1 auto → L4 president). Every tool call is auditable.
          PreToolUse hooks intercept out-of-scope execution in real time. Zero tolerance for chain breaks.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="px-2 py-1 bg-sky-500/10 text-sky-400/80 rounded text-xs">Four tiers</span>
          <span class="px-2 py-1 bg-sky-500/10 text-sky-400/80 rounded text-xs">Fully auditable</span>
          <span class="px-2 py-1 bg-sky-500/10 text-sky-400/80 rounded text-xs">Real-time guard</span>
        </div>
      </div>

      <!-- Pillar 3: Zero Code Start -->
      <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-purple-500/30 transition-colors group">
        <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center mb-5 group-hover:bg-purple-500/20 transition-colors">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Zero-code Start</h3>
        <p class="text-xs text-purple-400/80 font-mono mb-4">Template → Configure → Launch</p>
        <p class="text-white/50 text-sm leading-relaxed">
          Five pre-built templates cover the mainstream use cases. Swap three fields in the template
          and your complete AI team management system is live in five minutes.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="px-2 py-1 bg-purple-500/10 text-purple-400/80 rounded text-xs">5 templates</span>
          <span class="px-2 py-1 bg-purple-500/10 text-purple-400/80 rounded text-xs">5-minute setup</span>
          <span class="px-2 py-1 bg-purple-500/10 text-purple-400/80 rounded text-xs">Works on first load</span>
        </div>
      </div>

    </div>
  </section>

  <!-- How it works -->
  <section class="border-y border-white/5 bg-white/2">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="text-center mb-14">
        <h2 class="text-3xl font-bold text-white mb-3">How Synapse Forge Works</h2>
        <p class="text-white/40 text-sm">From download to first dispatch</p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#FCAD2A]/20 flex-shrink-0 flex items-center justify-center text-[#FCAD2A] font-bold text-sm">1</div>
            <div>
              <h4 class="font-semibold text-white mb-1">Choose a template</h4>
              <p class="text-white/50 text-sm">Pick the preset closest to your context — content team, engineering team, operations team, and more.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-sky-500/20 flex-shrink-0 flex items-center justify-center text-sky-400 font-bold text-sm">2</div>
            <div>
              <h4 class="font-semibold text-white mb-1">Personalize</h4>
              <p class="text-white/50 text-sm">Global-replace three fields: CEO name, president name, company name. Ctrl+H, three minutes.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-purple-500/20 flex-shrink-0 flex items-center justify-center text-purple-400 font-bold text-sm">3</div>
            <div>
              <h4 class="font-semibold text-white mb-1">Activate</h4>
              <p class="text-white/50 text-sm">Restart your Claude Code session. Harness, CEO Guard, execution chain, and decision system all come online.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-green-500/20 flex-shrink-0 flex items-center justify-center text-green-400 font-bold text-sm">4</div>
            <div>
              <h4 class="font-semibold text-white mb-1">Evolve continuously</h4>
              <p class="text-white/50 text-sm">Say "upgrade Synapse" to pull the latest version. Your personalized config is preserved across upgrades.</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-900 rounded-2xl border border-white/10 p-6 font-mono text-sm">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            <span class="text-white/30 text-xs ml-2">CLAUDE.md — Harness Config</span>
          </div>
          <div class="space-y-2 text-xs leading-relaxed">
            <div class="text-white/30"># Swap three fields, three minutes</div>
            <div><span class="text-purple-400">CEO</span> <span class="text-white/50">=</span> <span class="text-green-400">"Lysander"</span> <span class="text-white/30">← your AI CEO name</span></div>
            <div><span class="text-purple-400">PRESIDENT</span> <span class="text-white/50">=</span> <span class="text-green-400">"Liu Ziyang"</span> <span class="text-white/30">← your name</span></div>
            <div><span class="text-purple-400">COMPANY</span> <span class="text-white/50">=</span> <span class="text-green-400">"Synapse-PJ"</span> <span class="text-white/30">← company name</span></div>
            <div class="mt-4 text-white/30"># Save → restart session → system online</div>
            <div class="mt-2 text-[#FCAD2A]">[OK] CEO Guard ready</div>
            <div class="text-[#FCAD2A]">[OK] Execution chain v2.0 ready</div>
            <div class="text-[#FCAD2A]">[OK] Four-tier decision system ready</div>
            <div class="text-[#FCAD2A]">[OK] 44-agent team ready</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Production Proof -->
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold text-white mb-3">Production Proof</h2>
      <p class="text-white/40 text-sm">From Janus Digital, not a whitepaper</p>
    </div>

    <div class="bg-gradient-to-r from-[#FCAD2A]/10 via-sky-500/5 to-purple-500/10 border border-white/10 rounded-2xl p-8">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <p class="text-white/70 leading-relaxed mb-6">
            Synapse Forge is not a theoretical product. It was distilled inside <strong class="text-white">Janus Digital</strong>,
            from running 44 AI agents in production — through failures, iterations, and corrections — into an engineered methodology.
          </p>
          <p class="text-white/50 text-sm leading-relaxed">
            Every rule has a real "why" behind it: system chaos from an over-privileged CEO persona,
            runaway tasks from broken execution chains, opaque decisions from missing audit trails.
            These are the problems that drove every iteration of Harness Engineering.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-[#FCAD2A] mt-2 flex-shrink-0"></div>
            <p class="text-white/60 text-sm">Intelligence pipeline runs daily: search, filter, report, act, notify.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-sky-400 mt-2 flex-shrink-0"></div>
            <p class="text-white/60 text-sm">CEO Guard intercepts every out-of-scope tool call in real time, fully auditable.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-purple-400 mt-2 flex-shrink-0"></div>
            <p class="text-white/60 text-sm">Cross-session state recovery: new sessions read active_tasks.yaml, nothing is lost.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full bg-green-400 mt-2 flex-shrink-0"></div>
            <p class="text-white/60 text-sm">Eleven functional modules load on demand — the Harness file stays lean and auditable.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Reference -->
  <section class="border-t border-white/5">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white mb-2">Learn More</h2>
        <p class="text-white/40 text-sm">Deep dives on the methodology</p>
      </div>
      <div class="max-w-xl mx-auto">
        <a
          href="/blog/harness-engineering-guide"
          class="group block p-6 bg-white/5 rounded-xl border border-white/10 hover:border-sky-500/50 transition-colors"
        >
          <div class="flex items-center gap-3 mb-3">
            <time class="text-white/40 text-sm">2026-04-06</time>
            <div class="flex gap-2">
              <span class="px-2 py-0.5 bg-purple-500/20 text-purple-400 rounded text-xs">AI</span>
              <span class="px-2 py-0.5 bg-blue-500/20 text-blue-400 rounded text-xs">Harness Engineering</span>
            </div>
          </div>
          <h3 class="text-lg font-semibold text-white group-hover:text-sky-400 transition-colors">
            Harness Engineering — the control framework for AI agents
          </h3>
          <p class="text-white/50 mt-2 text-sm">An engineered approach to keep AI agents from repeating the same mistake.</p>
          <div class="flex items-center gap-1 mt-4 text-sky-400 text-sm font-medium">
            Read article
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-white/5 bg-gradient-to-b from-transparent to-[#FCAD2A]/5">
    <div class="max-w-5xl mx-auto px-6 py-20 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to forge your AI team?</h2>
      <p class="text-white/50 mb-10 max-w-lg mx-auto">
        Open source. Free. Give us a star — five minutes later, your AI team is on duty.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/en/synapse/get-started"
          class="inline-flex items-center gap-2 px-8 py-4 bg-[#FCAD2A] text-gray-900 font-bold rounded-xl hover:bg-[#FCAD2A]/90 transition-all shadow-lg shadow-[#FCAD2A]/20 text-base"
        >
          Get Started — Live in 5 minutes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="/en/synapse/pricing"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all text-base"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- Explore Synapse Forge -->
  <PillarSection
    eyebrow="Explore"
    title="Everything in Synapse Forge"
  >
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <FeatureCard
        title="Capabilities"
        body="Eleven specialist teams covering the full operating surface of a modern business."
        accent="amber"
        href="/en/synapse/capabilities"
      />
      <FeatureCard
        title="How It Works"
        body="Agent = Model + Harness. The five-step execution chain, guides and sensors, the three-layer CLAUDE.md."
        accent="sky"
        href="/en/synapse/how-it-works"
      />
      <FeatureCard
        title="Team"
        body="Forty-six specialists across eleven teams. Every one graded A/B/C and machine-readable."
        accent="purple"
        href="/en/synapse/team"
      />
      <FeatureCard
        title="Intelligence"
        body="Every morning, your AI team reports for work. A closed daily intelligence loop."
        accent="amber"
        href="/en/synapse/intelligence"
      />
      <FeatureCard
        title="Pricing"
        body="The system is free. Services — assessment and implementation — are how we help you land it."
        accent="sky"
        href="/en/synapse/pricing"
      />
      <FeatureCard
        title="Closed Beta"
        body="The Founding 30 — thirty teams shaping the next year of Synapse. Apply to join the waitlist."
        accent="amber"
        href="/en/synapse/beta"
      />
      <FeatureCard
        title="Get Started"
        body="Three steps. Five minutes. Your AI CEO on duty."
        accent="purple"
        href="/en/synapse/get-started"
      />
    </div>
  </PillarSection>

</Layout>
