---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import FeatureCard from '../../../components/synapse/FeatureCard.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const principles = [
  {
    title: 'Internal testing in progress',
    body: 'The system continues maturing with internal teams. External access will open in stages once readiness criteria are met.',
  },
  {
    title: 'Lifetime Pro promise honored',
    body: 'Early participants keep full Pro access when the commercial tier launches — for as long as Synapse exists.',
  },
  {
    title: 'No active recruitment',
    body: 'No public invites, no cold email applications, no signup form right now. We are still refining the engineering cadence.',
  },
];
---

<SynapseLayout
  title="Internal Testing"
  description="Synapse is currently in internal testing. We're refining Synapse with internal teams; external access will open once readiness criteria are met."
  subNavActive=""
  currentLang="en"
  altLang={{ lang: 'zh', href: '/synapse/beta' }}
>
  <Hero
    eyebrow="Internal Testing"
    title="Synapse — Internal Testing."
    subtitle="We're refining Synapse with internal teams. External access will open once readiness criteria are met."
    primaryCta={{ label: 'Currently invitation-only — Learn more', href: '/en/synapse/how-it-works' }}
    secondaryCta={{ label: 'Read the Methodology', href: '/en/synapse/how-it-works' }}
  />

  <PillarSection
    eyebrow="Status"
    title="Why external access is closed for now"
    subtitle="We're refining Synapse with internal teams. External access will open once readiness criteria are met."
  >
    <div class="grid md:grid-cols-3 gap-5">
      {principles.map((p) => (
        <FeatureCard title={p.title} body={p.body} accent="amber" />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Founding Member Commitment / Honored"
    title="Early-participant promises continue"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        The <strong class="text-white">lifetime Pro subscription promise</strong> made to early participants stands — for as long as Synapse exists.
      </p>
      <p class="text-white/60 text-sm">
        If you are already on the early-participant list, nothing is required from you; the entitlement carries forward automatically.
      </p>
    </div>
  </PillarSection>

  <CTABanner
    heading="Learn what Synapse is, first"
    body="Read the Harness Engineering methodology before external access opens. When it does, you'll already know which parts fit your team."
    primaryCta={{ label: 'See How It Works', href: '/en/synapse/how-it-works' }}
    secondaryCta={{ label: 'Explore Synapse', href: '/en/synapse' }}
  />
</SynapseLayout>
