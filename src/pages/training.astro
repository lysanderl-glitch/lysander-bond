---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SCP 培训认证 | Synapse Certified Practitioner">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <p class="text-sm font-semibold tracking-widest text-[var(--color-accent)] uppercase mb-4">TRAINING</p>
    <h1 class="text-4xl font-extrabold text-white mb-4">Synapse Certified Practitioner</h1>
    <p class="text-[var(--color-text)] text-lg mb-12">学会用 Harness Engineering 构建你自己的 AI Agent 协作运营体系。</p>

    <!-- Course Overview -->
    <div class="bg-[var(--color-card)] border border-white/5 rounded-xl p-8 mb-8">
      <div class="grid md:grid-cols-4 gap-6 text-center">
        <div><div class="text-2xl font-bold text-[var(--color-accent)]">8 小时</div><div class="text-sm text-[var(--color-muted)]">课程时长</div></div>
        <div><div class="text-2xl font-bold text-[var(--color-accent)]">4 + 4</div><div class="text-sm text-[var(--color-muted)]">理论 + 实操</div></div>
        <div><div class="text-2xl font-bold text-[var(--color-accent)]">4 Labs</div><div class="text-sm text-[var(--color-muted)]">动手工作坊</div></div>
        <div><div class="text-2xl font-bold text-[var(--color-accent)]">SCP</div><div class="text-sm text-[var(--color-muted)]">认证证书</div></div>
      </div>
    </div>

    <!-- Modules -->
    <h2 class="text-xl font-bold text-white mb-6">课程内容</h2>
    <div class="space-y-4 mb-12">
      <div class="flex gap-4 items-start p-4 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-accent)] font-black text-lg shrink-0">M1</span>
        <div><div class="font-semibold text-white">为什么需要 Harness Engineering</div><div class="text-sm text-[var(--color-muted)]">真实案例导入 — 写了规则但没人遵守的教训</div></div>
      </div>
      <div class="flex gap-4 items-start p-4 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-accent)] font-black text-lg shrink-0">M2</span>
        <div><div class="font-semibold text-white">Guides + Sensors 双保险机制</div><div class="text-sm text-[var(--color-muted)]">前馈控制（CLAUDE.md/决策规则）+ 反馈控制（QA评分/执行审计）</div></div>
      </div>
      <div class="flex gap-4 items-start p-4 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-accent)] font-black text-lg shrink-0">M3</span>
        <div><div class="font-semibold text-white">四级决策体系设计</div><div class="text-sm text-[var(--color-muted)]">L1自动 → L2专家 → L3管理 → L4高管，以及为什么专家先于CEO</div></div>
      </div>
      <div class="flex gap-4 items-start p-4 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-accent)] font-black text-lg shrink-0">M4</span>
        <div><div class="font-semibold text-white">Agent HR 管理体系</div><div class="text-sm text-[var(--color-muted)]">能力分级(A/B/C)、入职审批、自动审计引擎、进化与退役</div></div>
      </div>
      <div class="flex gap-4 items-start p-4 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-accent)] font-black text-lg shrink-0">M5</span>
        <div><div class="font-semibold text-white">情报闭环与自动化编排</div><div class="text-sm text-[var(--color-muted)]">每日情报管线、行动管线、4专家评审制、自动化事件链</div></div>
      </div>
    </div>

    <!-- Labs -->
    <h2 class="text-xl font-bold text-white mb-6">实操工作坊</h2>
    <div class="grid md:grid-cols-2 gap-4 mb-12">
      <div class="p-5 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-primary)] font-bold text-sm">Lab 1</span>
        <h3 class="font-semibold text-white mt-1">搭建你的 Harness Configuration</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">编写 CLAUDE.md — 角色/执行链/决策规则/强制检查点</p>
      </div>
      <div class="p-5 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-primary)] font-bold text-sm">Lab 2</span>
        <h3 class="font-semibold text-white mt-1">创建你的 AI 团队</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">设计组织架构 + 编写 Agent 卡片（审计引擎评分需达90+）</p>
      </div>
      <div class="p-5 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-primary)] font-bold text-sm">Lab 3</span>
        <h3 class="font-semibold text-white mt-1">构建情报管线</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">配置行业情报搜索范围 + 生成首期报告</p>
      </div>
      <div class="p-5 bg-[var(--color-card)] border border-white/5 rounded-lg">
        <span class="text-[var(--color-primary)] font-bold text-sm">Lab 4</span>
        <h3 class="font-semibold text-white mt-1">综合演练 + 答辩</h3>
        <p class="text-sm text-[var(--color-muted)] mt-1">展示完整体系设计 + 讲师评审 + SCP 认证评估</p>
      </div>
    </div>

    <!-- Pricing -->
    <h2 class="text-xl font-bold text-white mb-6">定价</h2>
    <div class="grid md:grid-cols-3 gap-4 mb-12">
      <div class="p-6 bg-[var(--color-card)] border border-white/5 rounded-xl text-center">
        <p class="text-sm text-[var(--color-muted)]">个人</p>
        <p class="text-3xl font-bold text-white mt-2">$500</p>
        <p class="text-sm text-[var(--color-muted)] mt-2">线上课程 + 实操 + SCP认证</p>
      </div>
      <div class="p-6 bg-[var(--color-card)] border border-[var(--color-accent)]/30 rounded-xl text-center">
        <p class="text-sm text-[var(--color-accent)]">企业（20人内）</p>
        <p class="text-3xl font-bold text-[var(--color-accent)] mt-2">$10K</p>
        <p class="text-sm text-[var(--color-muted)] mt-2">定制内容 + 现场Workshop</p>
      </div>
      <div class="p-6 bg-[var(--color-card)] border border-white/5 rounded-xl text-center">
        <p class="text-sm text-[var(--color-muted)]">企业（50人内）</p>
        <p class="text-3xl font-bold text-white mt-2">$15K</p>
        <p class="text-sm text-[var(--color-muted)] mt-2">含1个月后续咨询支持</p>
      </div>
    </div>

    <div class="text-center">
      <a href="mailto:lysanderl@janusd.io?subject=SCP%20培训咨询" class="inline-block px-10 py-4 bg-[var(--color-accent)] text-[var(--color-dark)] rounded-lg font-bold hover:opacity-90 transition-opacity">咨询培训</a>
    </div>
  </section>
</Layout>
