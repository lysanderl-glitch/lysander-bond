      读懂 Synapse 的语言，才能真正驾驭它。
    </p>
    <p class="text-white/40 text-sm mt-3">Synapse Glossary — 权威定义，持续更新</p>
  </section>

  <!-- Terms -->
  <section class="max-w-5xl mx-auto px-6 pb-24">
    <div class="space-y-4">
      {terms.map((item) => (
        <div class={`bg-white/5 border border-white/10 rounded-2xl p-6 hover:${colorClass(item.color, 'border')} transition-colors`}>
          <div class="flex items-start gap-4 flex-wrap">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap mb-3">
                <h3 class="text-xl font-bold text-white">{item.term}</h3>
                {(item as any).zhName && (
                  <span class="text-white/40 text-sm">{(item as any).zhName}</span>
                )}
                {(item as any).pronunciation && (
                  <span class="text-white/30 text-sm font-mono">{(item as any).pronunciation}</span>
                )}
                <span class={`px-2 py-0.5 ${colorClass(item.color, 'bg')} ${colorClass(item.color, 'text')} rounded text-xs`}>
                  {item.category}
                </span>
              </div>
              <p class="text-white/60 text-sm leading-relaxed mb-4">{item.definition}</p>
              {item.examples.length > 0 && (
                <div class="space-y-1">
                  {item.examples.map((ex) => (
                    <div class="flex items-start gap-2">
                      <span class={`w-1.5 h-1.5 rounded-full ${colorClass(item.color, 'bg').replace('/10', '')} mt-1.5 flex-shrink-0`}></span>
                      <span class="text-white/40 text-xs">{ex}</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTABanner
    heading="概念已掌握？来看实际案例"
    body="理论不如实战。查看真实的 Synapse 应用案例，了解这些概念如何在生产环境中协作。"
    primaryCta={{ label: "查看案例", href: "/synapse/cases" }}
    secondaryCta={{ label: "快速上手", href: "/synapse/get-started" }}
  />

</SynapseLayout>
