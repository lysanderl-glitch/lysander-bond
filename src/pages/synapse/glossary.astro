const categoryColors: Record<string, string> = {
  '核心概念': 'amber',
  '方法论': 'amber',
  '执行机制': 'sky',
  '质量保障': 'green',
  '决策框架': 'purple',
  '数据治理': 'rose',
  '知识管理': 'indigo',
  '知识图谱': 'amber',
  '自动化管线': 'sky',
  'Harness 治理': 'rose',
  '核心原则': 'purple',
};

function colorClass(color: string, type: 'bg' | 'text' | 'border') {
  const map: Record<string, Record<string, string>> = {
    amber: { bg: 'bg-[#FCAD2A]/10', text: 'text-[#FCAD2A]/80', border: 'border-[#FCAD2A]/30' },
    sky:   { bg: 'bg-sky-500/10',   text: 'text-sky-400/80',   border: 'border-sky-500/30'   },
    green: { bg: 'bg-green-500/10', text: 'text-green-400/80', border: 'border-green-500/30' },
    purple:{ bg: 'bg-purple-500/10',text: 'text-purple-400/80',border: 'border-purple-500/30'},
    rose:  { bg: 'bg-rose-500/10',  text: 'text-rose-400/80',  border: 'border-rose-500/30'  },
    indigo:{ bg: 'bg-indigo-500/10',text: 'text-indigo-400/80',border: 'border-indigo-500/30'},
  };
  return map[color]?.[type] ?? '';
}
