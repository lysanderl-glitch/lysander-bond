---
import SynapseLayout from '../../layouts/SynapseLayout.astro';
import Hero from '../../components/synapse/Hero.astro';
import PillarSection from '../../components/synapse/PillarSection.astro';
import PricingCard from '../../components/synapse/PricingCard.astro';
import CTABanner from '../../components/synapse/CTABanner.astro';

const tiers = [
  {
    tier: 'Community',
    price: '免费',
    tagline: '面向愿意读文档的开发者与个人采用者。',
    features: [
      '完整访问 Synapse 操作系统',
      '预装 CLAUDE.md',
      '全部 46 份 Agent 能力卡',
      '生成器与验证器工具链',
      '每日情报管线',
      '完整文档',
      'GitHub 社区支持',
    ],
    cta: { label: '免费开始', href: '/synapse/get-started' },
  },
  {
    tier: 'Assessment',
    price: '$5K–$10K',
    tagline: '两周交付。测绘、规划、交接。',
    features: [
      '两周交付周期',
      '测绘当前 AI 使用现状',
      '识别高杠杆的 Synapse 采用路径',
      '交付定制化 synapse.yaml 与落地计划',
      '一位 Harness Ops 专家 + 一位 Graphify 战略师全程对接',
    ],
    cta: {
      label: '预约评估',
      href: 'mailto:lysanderl@janusd.io?subject=Synapse%20Assessment',
      external: false,
    },
    highlighted: true,
  },
  {
    tier: 'Implementation',
    price: '$30K–$80K',
    tagline: '全量落地。按组织规模与模块报价。',
    features: [
      '4 到 12 周交付周期',
      '为你的领域定制 Agent 能力卡',
      '与现有工具链集成',
      '团队培训',
      '上线后 90 天支持',
      '按组织规模与模块数量定价',
    ],
    cta: {
      label: '申请方案',
      href: 'mailto:lysanderl@janusd.io?subject=Synapse%20Implementation',
      external: false,
    },
  },
];

const addons = [
  '建筑数字交付模块（Janus）：按项目报价',
  '量化交易模块（Stock）：按策略报价',
  '私人培训班：每席位 $8,000，6 周课程',
  '持续 AI 运营顾问：起价 $4,000/月',
];
---

<SynapseLayout
  title="定价"
  description="Synapse 操作系统免费。付费服务是我们帮你在组织内落地的方式。"
  subNavActive="pricing"
  currentLang="zh"
  altLang={{ lang: 'en', href: '/en/synapse/pricing' }}
>
  <Hero
    eyebrow="Pricing / 定价"
    title="体系免费。服务收费。"
    subtitle="Synapse Forge 操作系统、46 人 Agent 花名册、Harness 框架、工具链——全部开源免费。付费是为了让它在你的组织中跑起来。"
    primaryCta={{ label: '免费开始', href: '/synapse/get-started' }}
    secondaryCta={{
      label: '与我们聊聊',
      href: 'mailto:lysanderl@janusd.io?subject=Synapse%20Inquiry',
    }}
  />

  <PillarSection
    eyebrow="Three tiers / 三档"
    title="选一档适合你的"
  >
    <div class="grid md:grid-cols-3 gap-6">
      {tiers.map((t) => (
        <PricingCard {...t} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Add-ons / 附加项"
    title="专项扩展与持续支持"
    bordered={true}
  >
    <div class="max-w-2xl mx-auto">
      <ul class="space-y-4">
        {addons.map((addon) => (
          <li class="flex items-start gap-3 bg-gray-900/60 border border-white/10 rounded-xl p-5">
            <svg class="w-5 h-5 text-[#FCAD2A] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            <span class="text-white/70 leading-relaxed">{addon}</span>
          </li>
        ))}
      </ul>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Who this is for / 适合谁"
    title="诚实的筛选"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed">
      <p>
        Synapse Community 适合任何使用 Claude Code、并愿意读文档的人。付费服务面向需要 Synapse 正确跑起来、且希望比独立采用更快落地的组织。
      </p>
    </div>
  </PillarSection>

  <CTABanner
    heading="准备开始？"
    body="要么拿走免费配置包自己跑，要么预约评估，让我们帮你测绘出路径。"
    primaryCta={{ label: '获取免费配置包', href: '/synapse/get-started' }}
    secondaryCta={{
      label: '预约评估',
      href: 'mailto:lysanderl@janusd.io?subject=Synapse%20Assessment',
    }}
  />
</SynapseLayout>
