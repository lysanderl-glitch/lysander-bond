---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import TimelineItem from '../../../components/synapse/TimelineItem.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const pipeline = [
  {
    step: 1,
    title: '迪拜时间 6:00 — 任务恢复',
    body: '读取 active_tasks.yaml，续接阻塞已解除的未完成工作。',
  },
  {
    step: 2,
    title: '迪拜时间 8:00 — 情报扫描',
    body: '采集 AI 与市场信号，过滤出可落地价值，渲染为 HTML 并提交到 git。',
  },
  {
    step: 3,
    title: '迪拜时间 10:00 — 行动评估',
    body: '日报中的建议通过四位专家评审，批准项派单到 Harness Ops 执行。',
  },
  {
    step: 4,
    title: '完成 — Slack 通知',
    body: '总裁收到一行字：已完成、被阻塞、或待审阅。',
  },
];
---

<SynapseLayout
  title="情报闭环"
  description="每天早晨，AI 团队自动上岗。一条闭合的日常管线：扫描、过滤、决策、行动、上报。"
  subNavActive="intelligence"
  currentLang="zh"
  altLang={{ lang: 'en', href: '/synapse/intelligence' }}
>
  <Hero
    eyebrow="Intelligence / 情报闭环"
    title="每天早晨，AI 团队自动上岗"
    subtitle="Synapse 运转一条日常情报管线：扫描 AI 前沿 → 过滤信号 → 评估行动 → 交付报告。无人工介入。产出公开——管线本身即是产品的一部分。"
    primaryCta={{ label: '查看每日快报', href: '/intelligence' }}
    secondaryCta={{ label: '了解工作原理', href: '/synapse/zh/how-it-works' }}
  />

  <PillarSection
    eyebrow="The Daily Pipeline / 日常管线"
    title="四步。在大多数团队开始上班之前。"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {pipeline.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What makes it different / 与众不同之处"
    title="闭合的情报回路——不是一封新闻简报"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        这不是一封每日新闻简报。它是一条闭合的情报回路。信号进来，决策出去，行动发生，结果回流。
      </p>
      <p>
        每份日报都归档并附带结果——学到了什么、改了什么、没做什么以及为什么。几个月后，档案本身就成为一份复利式的记录：一个组织究竟是如何跟上 AI 前沿的。
      </p>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Today's report / 今日情报"
    title="订阅晨间快报"
    subtitle="档案库即将上线。在此之前，先订阅晨间快报直投邮箱。"
    bordered={true}
  >
    <div class="max-w-xl mx-auto">
      <form
        action="mailto:lysanderl@janusd.io"
        method="GET"
        enctype="text/plain"
        class="bg-gray-900/60 border border-white/10 rounded-2xl p-6"
      >
        <input type="hidden" name="subject" value="Synapse Intelligence Subscription" />
        <label for="email" class="block text-white/70 text-sm font-medium mb-2">
          邮箱地址
        </label>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            id="email"
            name="body"
            type="email"
            required
            placeholder="you@company.com"
            class="flex-1 px-4 py-3 bg-black/40 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-[#FCAD2A]/50"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center px-6 py-3 bg-[#FCAD2A] text-gray-900 font-bold rounded-xl hover:bg-[#FCAD2A]/90 transition-all whitespace-nowrap"
          >
            订阅晨间快报
          </button>
        </div>
        <p class="text-white/40 text-xs mt-3">
          我们会亲自跟进。随时可退订。
        </p>
      </form>
    </div>
  </PillarSection>

  <CTABanner
    heading="跑一条属于你的情报回路"
    body="Synapse 自带这条日常管线。你的回路，从你第一次打开 Claude Code 的那个清晨开始。"
    primaryCta={{ label: '立即上手', href: '/synapse/zh/get-started' }}
    secondaryCta={{ label: '查看定价', href: '/synapse/zh/pricing' }}
  />
</SynapseLayout>
