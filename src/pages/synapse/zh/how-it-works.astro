---
import SynapseLayout from '../../../layouts/SynapseLayout.astro';
import Hero from '../../../components/synapse/Hero.astro';
import PillarSection from '../../../components/synapse/PillarSection.astro';
import TimelineItem from '../../../components/synapse/TimelineItem.astro';
import CTABanner from '../../../components/synapse/CTABanner.astro';

const steps = [
  {
    step: 1,
    title: '问候与目标承接',
    body: 'Lysander 确认身份，并用自己的语言复述总裁的目标。',
  },
  {
    step: 2,
    title: '任务分级',
    body: 'execution_auditor 自动将任务分为 S/M/L 三级。S 级快速放行；L 级走专家评审。',
  },
  {
    step: 3,
    title: '强制派单表',
    body: '没有指名专家和指名交付物，任何工作都不得开始。这是一条硬约束。',
  },
  {
    step: 4,
    title: '独立上下文执行',
    body: '专家在子 Agent 上下文中运行。CEO 人格从不直接调用 Edit/Write/Bash——CEO Guard 会拦截。',
  },
  {
    step: 5,
    title: 'QA 门禁与交付',
    body: 'integration_qa 从完整性、准确性、一致性、可维护性、合规性五维度打分。≥85 出厂。',
  },
];
---

<SynapseLayout
  title="工作原理"
  description="Agent = 模型 + 约束（Harness）。Synapse 是 Harness Engineering 的参考实现——这是 2026 年生产级 AI 团队的工程学科。"
  subNavActive="how-it-works"
  currentLang="zh"
  altLang={{ lang: 'en', href: '/synapse/how-it-works' }}
>
  <Hero
    eyebrow="How It Works / 工作原理"
    title="Agent = 模型 + 约束（Harness）"
    subtitle="人人都能调用同样的模型。真正决定可靠性的是约束。Synapse 是 Harness Engineering 的参考实现——这是 2026 年生产级 AI 团队的工程学科。"
    primaryCta={{ label: '阅读博客文章', href: '/blog/harness-engineering-guide' }}
    secondaryCta={{ label: '认识团队', href: '/synapse/zh/team' }}
  />

  <PillarSection
    eyebrow="The Mechanics / 双环控制"
    title="Guides 与 Sensors"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        一套约束由两件事构成。<strong class="text-[#FCAD2A]">Guides（前馈）</strong>在行动前塑造行为——CLAUDE.md 的人格定义、organization.yaml 的路由表、decision_rules.yaml 的约束、Agent 能力卡。
      </p>
      <p>
        <strong class="text-sky-400">Sensors（反馈）</strong>在行动后监视结果——85/100 QA 评审、执行链审计师、决策日志、跨会话状态文件。
      </p>
      <p class="text-white/80">
        Guides 防漂移。Sensors 抓漏网。
      </p>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="The Process / 执行链"
    title="五步执行链"
    subtitle="五个步骤，每一次都走完。跳过任何一步都会被记录为 P0 违规。"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {steps.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="The Cache Architecture / 缓存架构"
    title="三层式 CLAUDE.md"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        Synapse 的 CLAUDE.md 分为三层，对应不同的缓存生命周期。
      </p>
      <ul class="space-y-4">
        <li class="flex gap-4">
          <span class="text-[#FCAD2A] font-mono text-sm mt-1 shrink-0">Layer 1</span>
          <span><strong class="text-white">身份层（约 25 行）</strong>——几乎不变。</span>
        </li>
        <li class="flex gap-4">
          <span class="text-sky-400 font-mono text-sm mt-1 shrink-0">Layer 2</span>
          <span><strong class="text-white">Harness 规则（约 170 行）</strong>——版本升级时变化。</span>
        </li>
        <li class="flex gap-4">
          <span class="text-purple-400 font-mono text-sm mt-1 shrink-0">Layer 3</span>
          <span><strong class="text-white">实例配置（约 85 行）</strong>——个人化时变化。</span>
        </li>
      </ul>
      <p>
        顺序是刻意设计的：稳定内容在前，让 Anthropic prompt cache 跨轮保持命中，成本降低约 90%。
      </p>
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="The Governance / 治理"
    title="熵增预算"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        Synapse 里每条规则都带时间戳。每 3 天，<strong class="text-white">harness_engineer</strong> 对 CLAUDE.md 运行 <code class="text-[#FCAD2A] font-mono text-sm">audit_harness()</code>——检查行数、重复语义、超过 180 天未复核的陈旧规则。
      </p>
      <p>
        超过 300 行，新增被阻断，直到有规则被移除。治理是一等特性，不是事后补救。
      </p>
    </div>
  </PillarSection>

  <CTABanner
    heading="准备自己跑一遍？"
    body="下载配置包。从下载到第一次派单，五分钟。"
    primaryCta={{ label: '立即上手', href: '/synapse/zh/get-started' }}
    secondaryCta={{ label: '查看定价', href: '/synapse/zh/pricing' }}
  />
</SynapseLayout>
