---
import SynapseLayout from '../../layouts/SynapseLayout.astro';
import Hero from '../../components/synapse/Hero.astro';
import PillarSection from '../../components/synapse/PillarSection.astro';
import FeatureCard from '../../components/synapse/FeatureCard.astro';
import CTABanner from '../../components/synapse/CTABanner.astro';

const principles = [
  {
    title: '内部测试中',
    body: '体系仍在内部团队中迭代成熟。外部接入将在准入条件满足后逐步开放。',
  },
  {
    title: '终身 Pro 承诺保留',
    body: '当商业版本发布时，已加入的早期参与者保留完整 Pro 访问权限——只要 Synapse 还在运转，权限不撤回。',
  },
  {
    title: '不主动招募',
    body: '现阶段不公开邀请、不接受冷邮件申请、不开放报名入口。仍在打磨工程节奏。',
  },
];
---

<SynapseLayout
  title="Internal Testing"
  description="Synapse 当前处于内部测试阶段。我们正在与内部团队一起打磨体系；外部接入将在准入条件满足后开放。"
  subNavActive=""
  currentLang="zh"
  altLang={{ lang: 'en', href: '/en/synapse/beta' }}
>
  <Hero
    eyebrow="Internal Testing / 内部测试"
    title="Synapse — Internal Testing."
    subtitle="我们正在与内部团队一起打磨 Synapse。外部接入将在准入条件满足后开放。"
    primaryCta={{ label: 'Currently invitation-only — Learn more', href: '/synapse/how-it-works' }}
    secondaryCta={{ label: '了解工作原理', href: '/synapse/how-it-works' }}
  />

  <PillarSection
    eyebrow="Status / 当前状态"
    title="为什么暂不开放外部接入"
    subtitle="We're refining Synapse with internal teams. External access will open once readiness criteria are met."
  >
    <div class="grid md:grid-cols-3 gap-5">
      {principles.map((p) => (
        <FeatureCard title={p.title} body={p.body} accent="amber" />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="Founding Member 承诺 / Honored"
    title="对早期参与者的承诺继续兑现"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        早期参与者拿到的<strong class="text-white">终身 Pro 订阅承诺</strong>继续保留——只要 Synapse 还在运转，这一权益就一直有效。
      </p>
      <p class="text-white/60 text-sm">
        如果你已在早期参与名单中，无需任何操作，权益自动续接。
      </p>
    </div>
  </PillarSection>

  <CTABanner
    heading="先了解 Synapse 是什么"
    body="在外部接入开放之前，可以先读一遍 Harness Engineering 方法论。当外部接入开放时，你已经知道哪一部分最契合你的团队。"
    primaryCta={{ label: '了解 Synapse 工作原理', href: '/synapse/how-it-works' }}
    secondaryCta={{ label: '查看体系全景', href: '/synapse' }}
  />
</SynapseLayout>
