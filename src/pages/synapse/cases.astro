                ['MES-01 基线', '0.00（执行链违规率归零）'],
                ['MES-02 基线', '85.7%（QA 通过率超目标）'],
                ['Hook 拦截测试', '5/5 测试场景全部通过'],
              ].map(([label, value]) => (
                <div class="flex items-start gap-3">
