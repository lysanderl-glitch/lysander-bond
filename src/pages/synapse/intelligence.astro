---
import SynapseLayout from '../../layouts/SynapseLayout.astro';
import Hero from '../../components/synapse/Hero.astro';
import PillarSection from '../../components/synapse/PillarSection.astro';
import TimelineItem from '../../components/synapse/TimelineItem.astro';
import CTABanner from '../../components/synapse/CTABanner.astro';

const pipeline = [
  {
    step: 1,
    title: '迪拜时间 6:00 — 任务恢复',
    body: '读取 active_tasks.yaml，续接阻塞已解除的未完成工作。',
  },
  {
    step: 2,
    title: '迪拜时间 8:00 — 情报扫描',
    body: '采集 AI 与市场信号，过滤出可落地价值，渲染为 HTML 并提交到 git。',
  },
  {
    step: 3,
    title: '迪拜时间 10:00 — 行动评估',
    body: '日报中的建议通过四位专家评审，批准项派单到 Harness Ops 执行。',
  },
  {
    step: 4,
    title: '完成 — Slack 通知',
    body: '总裁收到一行字：已完成、被阻塞、或待审阅。',
  },
];
---

<SynapseLayout
  title="情报闭环"
  description="每天早晨，AI 团队自动上岗。一条闭合的日常管线：扫描、过滤、决策、行动、上报。"
  subNavActive="intelligence"
  currentLang="zh"
  altLang={{ lang: 'en', href: '/en/synapse/intelligence' }}
>
  <Hero
    eyebrow="Intelligence / 情报闭环"
    title="每天早晨，AI 团队自动上岗"
    subtitle="Synapse 运转一条日常情报管线：扫描 AI 前沿 → 过滤信号 → 评估行动 → 交付报告。无人工介入。产出公开——管线本身即是产品的一部分。"
    primaryCta={{ label: '订阅情报日报', href: '#subscribe' }}
    secondaryCta={{ label: '了解工作原理', href: '/synapse/how-it-works' }}
  />

  <PillarSection
    eyebrow="The Daily Pipeline / 日常管线"
    title="四步。在大多数团队开始上班之前。"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {pipeline.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What makes it different / 与众不同之处"
    title="闭合的情报回路——不是一封新闻简报"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        这不是一封每日新闻简报。它是一条闭合的情报回路。信号进来，决策出去，行动发生，结果回流。
      </p>
      <p>
        每份日报都归档并附带结果——学到了什么、改了什么、没做什么以及为什么。几个月后，档案本身就成为一份复利式的记录：一个组织究竟是如何跟上 AI 前沿的。
      </p>
    </div>
  </PillarSection>

  <!-- 情报档案入口 -->
  <section class="py-12 px-6 border-t border-white/10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold text-white mb-3">查看每日快报</h2>
      <p class="text-white/50 mb-8">情报档案实时更新，每日 08:00 Dubai 自动生成</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/intelligence/daily" class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-lg transition-colors">
          📡 情报快报档案
        </a>
        <a href="/intelligence/decisions" class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition-colors">
          ⚖️ 执行决策记录
        </a>
        <a href="/intelligence/results" class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg transition-colors">
          ✅ 执行结果报告
        </a>
      </div>
    </div>
  </section>

  <section id="subscribe" class="py-16 px-6" style="background: var(--color-dark, #0A1628);">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">Today's report / 今日情报</p>
      <h2 class="text-2xl font-bold text-white mb-3">订阅情报日报</h2>
      <p class="text-white/60 mb-8">每日 AI 战场最新动态，Synapse 团队精选评述，直达你的收件箱。</p>
      <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="subscribe-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-sky-400"
        />
        <button
          type="submit"
          id="subscribe-btn"
          class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
        >
          订阅晨间快报
        </button>
      </form>
      <p id="subscribe-msg" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('subscribe-form');
    const emailInput = document.getElementById('subscribe-email') as HTMLInputElement | null;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
    const msg = document.getElementById('subscribe-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value?.trim();
      if (!email) return;

      if (btn) { btn.disabled = true; btn.textContent = '提交中…'; }

      try {
        const res = await fetch('https://n8n.lysander.bond/webhook/blog-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'lysander.bond', lang: 'zh', timestamp: new Date().toISOString() })
        });

        if (res.ok) {
          if (msg) {
            msg.textContent = '✅ 订阅成功！我们会在明天早上将情报日报发到你的收件箱。';
            msg.className = 'mt-4 text-sm text-sky-400';
          }
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        if (msg) {
          msg.textContent = '⚠️ 提交暂时失败，请通过 lysanderl@janusd.io 联系我们完成订阅。';
          msg.className = 'mt-4 text-sm text-yellow-400';
        }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = '订阅晨间快报'; }
        msg?.classList.remove('hidden');
      }
    });
  </script>

  <CTABanner
    heading="跑一条属于你的情报回路"
    body="Synapse 自带这条日常管线。你的回路，从你第一次打开 Claude Code 的那个清晨开始。"
    primaryCta={{ label: '立即上手', href: '/synapse/get-started' }}
    secondaryCta={{ label: '了解学院', href: '/academy' }}
  />
</SynapseLayout>
