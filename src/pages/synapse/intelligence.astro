---
import SynapseLayout from '../../layouts/SynapseLayout.astro';
import Hero from '../../components/synapse/Hero.astro';
import PillarSection from '../../components/synapse/PillarSection.astro';
import TimelineItem from '../../components/synapse/TimelineItem.astro';
import CTABanner from '../../components/synapse/CTABanner.astro';

const pipeline = [
  {
    step: 1,
    title: 'Scan — 信号扫描',
    body: '采集 AI 前沿与市场信号，过滤出可落地价值，生成原始情报条目。',
  },
  {
    step: 2,
    title: 'Bulletin — 情报快报',
    body: '将当日信号渲染为 HTML 情报快报，08:00 Dubai 自动提交到 git，公开归档。',
  },
  {
    step: 3,
    title: 'Decision — 执行决策',
    body: '四维 VACE 专家评分 + WSCORE 行动分级，每条情报标注执行/跟踪/搁置。',
  },
  {
    step: 4,
    title: 'Track — 追踪落地',
    body: '批准项派单到执行团队，写入 active_tasks.yaml 跨会话持续追踪。',
  },
  {
    step: 5,
    title: 'Evolve — 能力演进',
    body: '行动完成形成能力提升，归档决策记录，管线健康检查，准备下一个循环。',
  },
];
---

<SynapseLayout
  title="自进化管线"
  description="Synapse 系统演进层。每日 5 步闭合循环，将外部信号转化为系统能力的实质提升。"
  subNavActive="intelligence"
  currentLang="zh"
  altLang={{ lang: 'en', href: '/en/synapse/intelligence' }}
>
  <Hero
    eyebrow="Self-improve Pipeline / 自进化管线"
    title="每个循环结束，Synapse 比昨天更强"
    subtitle="Synapse 演进层：每日自动运行 5 步循环——扫描信号 → 生成快报 → 专家评分 → Lysander 派单追踪 → 能力演进。L3 项 Lysander 自主决策，L4 项总裁知会，L5 项总裁裁决；每个循环的输出公开归档。"
    primaryCta={{ label: '订阅情报日报', href: '#subscribe' }}
    secondaryCta={{ label: '查看自进化档案', href: '/intelligence' }}
  />

  <!-- 情报档案入口卡片 -->
  <section class="py-12 px-6 border-t border-white/10">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/intelligence/daily" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">📡</div>
          <div>
            <div class="text-white font-semibold mb-1">情报快报</div>
            <div class="text-white/50 text-sm">每日 AI 前沿信号精选，08:00 Dubai 自动生成</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">查看档案 →</div>
        </a>
        <a href="/intelligence/decisions" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">⚖️</div>
          <div>
            <div class="text-white font-semibold mb-1">执行决策</div>
            <div class="text-white/50 text-sm">L1-L4 决策归档，附推理过程与采纳理由</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">查看决策 →</div>
        </a>
        <a href="/intelligence/results" class="group flex flex-col gap-3 p-6 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/50 transition-all">
          <div class="text-2xl">🔄</div>
          <div>
            <div class="text-white font-semibold mb-1">演进成果</div>
            <div class="text-white/50 text-sm">行动完成形成的能力提升，每个循环的演进闭环</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto">查看演进 →</div>
        </a>
      </div>
    </div>
  </section>

  <PillarSection
    eyebrow="The Self-improve Pipeline / 自进化管线"
    title="五步。每天自动完成一次系统升级。"
    bordered={true}
  >
    <div class="max-w-3xl mx-auto space-y-8">
      {pipeline.map((s) => (
        <TimelineItem step={s.step} title={s.title} body={s.body} />
      ))}
    </div>
  </PillarSection>

  <PillarSection
    eyebrow="What makes it different / 与众不同之处"
    title="自进化管线——不是一封新闻简报"
  >
    <div class="max-w-3xl mx-auto text-white/70 text-base md:text-lg leading-relaxed space-y-5">
      <p>
        这不是一封每日新闻简报。它是 Synapse 系统的自我升级机制。信号进来，决策出去，能力提升，系统变强。
      </p>
      <p>
        每个循环都留下可验证的痕迹——学到了什么、改了什么、演进了哪里。几个月后，这份档案变成一条清晰的能力增长曲线：一个 AI 系统究竟如何持续自我迭代。
      </p>
    </div>
  </PillarSection>

  <section id="subscribe" class="py-16 px-6" style="background: var(--color-dark, #0A1628);">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">Today's report / 今日情报</p>
      <h2 class="text-2xl font-bold text-white mb-3">订阅情报日报</h2>
      <p class="text-white/60 mb-8">每日 AI 战场最新动态，Synapse 团队精选评述，直达你的收件箱。</p>
      <form id="subscribe-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="subscribe-email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-sky-400"
        />
        <button
          type="submit"
          id="subscribe-btn"
          class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-lg transition-colors whitespace-nowrap"
        >
          订阅晨间快报
        </button>
      </form>
      <p id="subscribe-msg" class="mt-4 text-sm hidden"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('subscribe-form');
    const emailInput = document.getElementById('subscribe-email') as HTMLInputElement | null;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
    const msg = document.getElementById('subscribe-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value?.trim();
      if (!email) return;

      if (btn) { btn.disabled = true; btn.textContent = '提交中…'; }

      try {
        const res = await fetch('https://n8n.lysander.bond/webhook/blog-subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'lysander.bond', lang: 'zh', timestamp: new Date().toISOString() })
        });

        if (res.ok) {
          if (msg) {
            msg.textContent = '✅ 订阅成功！我们会在明天早上将情报日报发到你的收件箱。';
            msg.className = 'mt-4 text-sm text-sky-400';
          }
          form.reset();
        } else {
          throw new Error('Server error');
        }
      } catch {
        if (msg) {
          msg.textContent = '⚠️ 提交暂时失败，请通过 lysanderl@janusd.com 联系我们完成订阅。';
          msg.className = 'mt-4 text-sm text-yellow-400';
        }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = '订阅晨间快报'; }
        msg?.classList.remove('hidden');
      }
    });
  </script>

  <CTABanner
    heading="搭建属于你的自进化管线"
    body="Synapse 自带这条演进机制。你的第一个循环，从你第一次打开 Claude Code 的那个清晨开始。"
    primaryCta={{ label: '立即上手', href: '/synapse/get-started' }}
    secondaryCta={{ label: '了解学院', href: '/academy' }}
  />
</SynapseLayout>
