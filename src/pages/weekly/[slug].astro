---
// Dynamic weekly route — versioned PLS (Plain-Language Surface) archive.
// URL pattern: /weekly/YYYY-MM-DD/
// Each .md file in src/content/weekly/ maps to one dated entry.
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('weekly');
  return entries.map((entry) => ({
    params: { slug: entry.data.date },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | Lysander`}
  description={entry.data.summary ?? `Synapse 本周快报 · ${entry.data.date}`}
  lang="zh"
  darkContent={false}
>
  <!-- Header -->
  <section class="pt-24 pb-10 px-6 border-b border-[var(--color-border)]">
    <div class="max-w-4xl mx-auto">
      <a href="/this-week" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors mb-6 inline-block">
        ← 返回本周快报
      </a>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#FCAD2A]/10 border border-[#FCAD2A]/30 text-[#FCAD2A] text-xs font-semibold mb-5">
        <span class="w-1.5 h-1.5 rounded-full bg-[#FCAD2A]"></span>
        历史档案 · {entry.data.date}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-3" style="font-family: var(--font-display, 'Fraunces', Georgia, serif); letter-spacing: -0.02em;">
        {entry.data.title}
      </h1>
      {entry.data.summary && (
        <p class="text-base text-[var(--color-text-light)] leading-relaxed max-w-2xl">
          {entry.data.summary}
        </p>
      )}
      <div class="flex items-center gap-4 mt-4">
        <span class="text-xs text-[var(--color-muted)] font-mono">{entry.data.date}</span>
        {entry.data.window_label && (
          <span class="text-xs text-[var(--color-muted)] font-mono">数据窗口 {entry.data.window_label}</span>
        )}
        {entry.data.health_score && (
          <span class="text-xs font-semibold text-[#28a745]">健康分 {entry.data.health_score}/100</span>
        )}
      </div>
    </div>
  </section>

  <!-- Content -->
  <article class="py-14 px-6">
    <div class="max-w-4xl mx-auto prose prose-lg max-w-none weekly-content">
      <Content />
    </div>
  </article>

  <!-- Footer nav -->
  <section class="py-10 px-6 border-t border-[var(--color-border)] bg-[#F7F8FA]">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <a href="/this-week" class="text-sm text-[#028CDC] hover:underline">← 查看最新一期</a>
      <span class="text-xs text-[var(--color-muted)] font-mono">{entry.data.date}</span>
    </div>
  </section>
</Layout>

<style>
  .weekly-content h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.4rem;
  }
  .weekly-content h2:first-child {
    margin-top: 0;
  }
  .weekly-content strong {
    color: var(--color-text);
  }
  .weekly-content p {
    color: var(--color-text-light);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .weekly-content em {
    color: var(--color-muted);
    font-style: normal;
    font-size: 0.875rem;
  }
  .weekly-content hr {
    border-color: var(--color-border);
    margin: 2rem 0;
  }
  .weekly-content table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.5rem 0;
  }
  .weekly-content th,
  .weekly-content td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .weekly-content th {
    background: #F7F8FA;
    font-weight: 600;
    color: var(--color-text);
  }
  .weekly-content td {
    color: var(--color-text-light);
  }
</style>
