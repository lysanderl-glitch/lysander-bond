---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const results = (await getCollection('intelligence-results'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="执行结果档案 | Lysander" description="AI 团队每日行动报告，从任务到交付的完整过程记录" lang="zh" darkContent={true}>
  <section class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/intelligence" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← 情报中枢</a>
      <h1 class="text-3xl font-bold text-white mb-2">执行结果档案</h1>
      <p class="text-white/50 mb-10">AI 团队每日行动报告，从任务到交付的完整过程记录</p>

      {results.length === 0 ? (
        <div class="text-center py-20 text-white/30">行动报告生成后自动出现在这里</div>
      ) : (
        <div class="space-y-4">
          {results.map(r => (
            <a href={`/intelligence/results/${r.data.date}`}
               class="flex items-start gap-4 p-5 rounded-xl bg-white/5 border border-white/10 hover:border-green-500/40 transition-colors group">
              <div class="flex-shrink-0 text-center">
                <div class="text-2xl font-bold text-green-400">{new Date(r.data.date).getDate()}</div>
                <div class="text-xs text-white/40">{new Date(r.data.date).toLocaleDateString('zh-CN', {month:'short'})}</div>
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="font-semibold text-white group-hover:text-green-400 mb-1">{r.data.title}</h2>
                <p class="text-sm text-white/50 line-clamp-2">{r.data.summary}</p>
                <div class="flex gap-3 mt-2 text-xs text-white/30">
                  <span>{r.data.actionsCount} 项行动</span>
                  <span class="text-green-400">{r.data.completedCount} 项完成</span>
                  {r.data.tags.slice(0,3).map(t => <span class="bg-green-500/10 text-green-400 px-1.5 py-0.5 rounded">{t}</span>)}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
