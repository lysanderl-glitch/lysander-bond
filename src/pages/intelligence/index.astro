---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import {
  loadOverallManifests,
  decideHubDisplay,
  ringStatuses,
} from '../../lib/intelManifest';

// ── Simple frontmatter parser (no external dep) ───────────────────────────
function parseFrontmatter(content: string): Record<string, unknown> {
  const match = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
  if (!match) return {};
  const fm: Record<string, unknown> = {};
  for (const line of match[1].split(/\r?\n/)) {
    const kv = line.match(/^(\w[\w_]*)\s*:\s*(.+)$/);
    if (!kv) continue;
    const [, key, rawVal] = kv;
    const val = rawVal.trim().replace(/^["']|["']$/g, '');
    if (val === 'true') fm[key] = true;
    else if (val === 'false') fm[key] = false;
    else if (/^\d+$/.test(val)) fm[key] = parseInt(val, 10);
    else fm[key] = val;
  }
  return fm;
}

// ── Public Briefs ──────────────────────────────────────────────────────────
interface PublicBrief {
  date: string;
  publish_gate: boolean;
  top_discovery?: string;
  decision_summary?: string;
  completed_this_cycle?: number;
  value_delta?: string;
  scan_count?: number;
  semantic_score?: number;
}

let latestBrief: PublicBrief | null = null;

try {
  const briefsDir = path.resolve('./src/content/intelligence/public-briefs');
  if (fs.existsSync(briefsDir)) {
    const files = fs.readdirSync(briefsDir)
      .filter((f: string) => f.endsWith('.md'))
      .sort()
      .reverse();

    for (const file of files.slice(0, 7)) {
      const raw = fs.readFileSync(path.join(briefsDir, file), 'utf-8');
      const fm = parseFrontmatter(raw);
      if (fm.publish_gate === true) {
        latestBrief = {
          date: String(fm.date ?? file.replace('.md', '')),
          publish_gate: true,
          top_discovery: fm.top_discovery ? String(fm.top_discovery) : undefined,
          decision_summary: fm.decision_summary ? String(fm.decision_summary) : undefined,
          completed_this_cycle: typeof fm.completed_this_cycle === 'number' ? fm.completed_this_cycle : undefined,
          value_delta: fm.value_delta ? String(fm.value_delta) : undefined,
          scan_count: typeof fm.scan_count === 'number' ? fm.scan_count : undefined,
          semantic_score: typeof fm.semantic_score === 'number' ? fm.semantic_score : undefined,
        };
        break;
      }
    }
  }
} catch {
  // graceful degradation — show placeholder state
}

// ── Milestones ────────────────────────────────────────────────────────────
interface Milestone {
  date: string;
  title: string;
  title_en: string;
  impact: string;
  impact_en: string;
}

let milestones: Milestone[] = [];

try {
  const mPath = path.resolve('./src/content/intelligence/milestones.yaml');
  if (fs.existsSync(mPath)) {
    const raw = fs.readFileSync(mPath, 'utf-8');
    // Parse YAML milestones list — simple block-style parsing
    const items = raw.split(/^  - /m).slice(1);
    milestones = items.map((block) => {
      const get = (key: string) => {
        const m = block.match(new RegExp(`${key}:\\s*"?([^"\\n]+)"?`));
        return m ? m[1].trim() : '';
      };
      return {
        date: get('date'),
        title: get('title'),
        title_en: get('title_en'),
        impact: get('impact'),
        impact_en: get('impact_en'),
      };
    }).filter(m => m.date).reverse(); // newest first
  }
} catch {
  // graceful degradation
}

// ── System Ring (DE-5 manifest) ───────────────────────────────────────────
const overalls = await loadOverallManifests();
const hub = decideHubDisplay(overalls);
const ring = ringStatuses(hub.overall);
---

<Layout
  title="Synapse 自进化管线 | Lysander"
  description="Synapse 每天自动扫描 AI 领域变化、判断哪些值得行动、派任务给团队。这是系统真实工作的实时记录。"
  lang="zh"
  darkContent={true}
>

  <!-- ═══ 区块1：Hero ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden pt-20 pb-16 px-6" style="background: linear-gradient(135deg, #0A1628 0%, #0d1f3c 50%, #011830 100%);">
    <!-- Background network pattern -->
    <svg class="absolute inset-0 w-full h-full opacity-10 pointer-events-none" viewBox="0 0 1200 500" fill="none" preserveAspectRatio="xMidYMid slice">
      <circle cx="900" cy="150" r="200" fill="#FCAD2A" opacity="0.04"/>
      <circle cx="300" cy="350" r="150" fill="#028CDC" opacity="0.05"/>
      <circle cx="600" cy="250" r="3" fill="#FCAD2A"/><circle cx="750" cy="180" r="2" fill="#028CDC"/>
      <circle cx="450" cy="300" r="2" fill="#FCAD2A"/><circle cx="850" cy="220" r="2.5" fill="#028CDC"/>
      <circle cx="1000" cy="150" r="2" fill="#FCAD2A"/><circle cx="200" cy="200" r="1.5" fill="#028CDC"/>
      <line x1="600" y1="250" x2="750" y2="180" stroke="#FCAD2A" stroke-width="0.5" opacity="0.4"/>
      <line x1="750" y1="180" x2="850" y2="220" stroke="#028CDC" stroke-width="0.5" opacity="0.3"/>
      <line x1="450" y1="300" x2="600" y2="250" stroke="#028CDC" stroke-width="0.5" opacity="0.3"/>
      <line x1="850" y1="220" x2="1000" y2="150" stroke="#FCAD2A" stroke-width="0.3" opacity="0.3"/>
    </svg>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center">

        <!-- 左栏：文案 -->
        <div class="hero-stagger">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#FCAD2A]/10 border border-[#FCAD2A]/30 text-[#FCAD2A] text-xs font-semibold mb-6 tracking-wider uppercase">
            <span class="w-1.5 h-1.5 rounded-full bg-[#FCAD2A] animate-pulse"></span>
            Self-improve Pipeline / 自进化管线
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 leading-[1.1]" style="font-family: var(--font-display, 'Fraunces', Georgia, serif); letter-spacing: -0.02em;">
            Synapse 在进化
          </h1>
          <p class="text-lg text-white/65 leading-relaxed mb-8 max-w-lg">
            这不是新闻简报。这是一个 AI 系统每天真实工作的记录——扫描信号、做出判断、派出任务、能力提升。
          </p>

          <!-- 关键数字 -->
          <div class="flex flex-wrap gap-6 mb-8">
            <div class="text-center">
              <div class="text-2xl font-bold text-[#FCAD2A]">{latestBrief?.scan_count ?? '—'}</div>
              <div class="text-xs text-white/40 mt-1">今日扫描源</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">47</div>
              <div class="text-xs text-white/40 mt-1">核心 Agent</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">{milestones.length}</div>
              <div class="text-xs text-white/40 mt-1">进化里程碑</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a href="#today-snapshot" class="px-6 py-3 bg-[#FCAD2A] text-[#0A1628] font-bold rounded-xl hover:bg-[#FCAD2A]/90 transition-all text-sm">
              查看今日记录
            </a>
            <a href="#evolution-timeline" class="px-6 py-3 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/10 transition-all text-sm">
              进化轨迹 →
            </a>
          </div>
        </div>

        <!-- 右栏：今日快照卡片 -->
        <div id="today-snapshot">
          {latestBrief ? (
            <div class="rounded-2xl border border-[#FCAD2A]/30 bg-[#FCAD2A]/5 p-6 relative overflow-hidden">
              <!-- 活跃指示点 -->
              <div class="flex items-center justify-between mb-5">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-[#FCAD2A] animate-pulse"></span>
                  <span class="text-xs font-semibold text-[#FCAD2A] uppercase tracking-wider">今日运行快照</span>
                </div>
                <time class="text-xs text-white/40 font-mono">{latestBrief.date}</time>
              </div>

              <div class="space-y-4">
                <!-- 今日发现 -->
                <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-base">🔍</span>
                    <span class="text-xs font-semibold text-white/50 uppercase tracking-wider">今日发现</span>
                  </div>
                  <p class="text-sm text-white leading-relaxed">
                    {latestBrief.top_discovery ?? '系统今日正常扫描，无重大信号'}
                  </p>
                </div>

                <!-- 判断与决策 -->
                <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-base">⚡</span>
                    <span class="text-xs font-semibold text-white/50 uppercase tracking-wider">判断与决策</span>
                  </div>
                  <p class="text-sm text-white leading-relaxed">
                    {latestBrief.decision_summary ?? '评估中'}
                  </p>
                </div>

                <!-- 上轮成果 -->
                {latestBrief.value_delta && (
                  <div class="p-4 rounded-xl bg-white/5 border border-white/10">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-base">✅</span>
                      <span class="text-xs font-semibold text-white/50 uppercase tracking-wider">上轮成果</span>
                    </div>
                    <p class="text-sm text-white leading-relaxed">
                      {latestBrief.value_delta}
                    </p>
                    {latestBrief.completed_this_cycle !== undefined && latestBrief.completed_this_cycle > 0 && (
                      <p class="text-xs text-[#FCAD2A]/70 mt-2">
                        本轮完成 {latestBrief.completed_this_cycle} 项任务
                      </p>
                    )}
                  </div>
                )}
              </div>
            </div>
          ) : (
            <!-- 占位状态 -->
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
              <div class="flex items-center gap-2 mb-5">
                <span class="w-2 h-2 rounded-full bg-white/30"></span>
                <span class="text-xs font-semibold text-white/40 uppercase tracking-wider">今日快照</span>
              </div>
              <div class="text-center py-8">
                <div class="text-3xl mb-3">🔄</div>
                <p class="text-white/60 text-sm">系统今日处于分析中</p>
                <p class="text-white/30 text-xs mt-2">通常在 Dubai 时间 08:00 前更新</p>
              </div>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ 区块2：系统行动档案入口 ═══════════════════════════════════════ -->
  <section class="py-10 px-6 border-b border-white/10" data-reveal>
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-1">System Activity / 系统行动记录</p>
          <h2 class="text-lg font-bold text-white">完整情报档案</h2>
        </div>
        <a href="/synapse/intelligence" class="hidden md:inline-flex items-center gap-1.5 text-xs text-white/40 hover:text-white/70 transition-colors border border-white/10 px-3 py-1.5 rounded-lg">
          查看完整管线介绍 →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/intelligence/daily" class="group flex flex-col gap-3 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-sky-500/40 transition-all">
          <div class="text-2xl">📡</div>
          <div>
            <div class="text-white font-semibold mb-1">情报快报</div>
            <div class="text-white/50 text-sm">每日 AI 前沿信号精选，08:00 Dubai 自动生成</div>
          </div>
          <div class="text-sky-400 text-sm font-medium mt-auto group-hover:translate-x-1 transition-transform">查看档案 →</div>
        </a>
        <a href="/intelligence/decisions" class="group flex flex-col gap-3 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-[#FCAD2A]/40 transition-all">
          <div class="text-2xl">⚖️</div>
          <div>
            <div class="text-white font-semibold mb-1">执行决策</div>
            <div class="text-white/50 text-sm">判断归档：哪些值得行动、为什么、结果如何</div>
          </div>
          <div class="text-[#FCAD2A] text-sm font-medium mt-auto group-hover:translate-x-1 transition-transform">查看决策 →</div>
        </a>
        <a href="/intelligence/results" class="group flex flex-col gap-3 p-5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:border-green-500/40 transition-all">
          <div class="text-2xl">✅</div>
          <div>
            <div class="text-white font-semibold mb-1">演进成果</div>
            <div class="text-white/50 text-sm">行动完成后系统能力的真实变化记录</div>
          </div>
          <div class="text-green-400 text-sm font-medium mt-auto group-hover:translate-x-1 transition-transform">查看成果 →</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ 区块3：进化轨迹 ════════════════════════════════════════════════ -->
  <section id="evolution-timeline" class="py-16 px-6" data-reveal>
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">Evolution Timeline / 进化轨迹</p>
        <h2 class="text-3xl font-bold text-white mb-3" style="font-family: var(--font-display, 'Fraunces', Georgia, serif);">
          从实践到原则
        </h2>
        <p class="text-white/50 max-w-xl mx-auto text-sm leading-relaxed">
          每一个里程碑都是系统真实进化的节点——不是计划，是已经发生的事实。
        </p>
      </div>

      {milestones.length > 0 ? (
        <div class="relative pl-8 md:pl-0">
          <!-- 竖线 -->
          <div class="absolute left-3 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-px bg-gradient-to-b from-[#FCAD2A]/50 via-[#FCAD2A]/20 to-transparent"></div>

          <div class="space-y-6">
            {milestones.map((m, i) => (
              <div class="relative flex items-start gap-0 md:gap-0">
                <!-- 节点 dot (absolute, centered on the line) -->
                <div class="absolute left-[-21px] md:left-1/2 md:-translate-x-1/2 w-4 h-4 mt-1 flex items-center justify-center">
                  <div class={`w-3 h-3 rounded-full border-2 border-[#0A1628] ${i === 0 ? 'bg-[#FCAD2A] shadow-[0_0_8px_rgba(252,173,42,0.6)]' : 'bg-[#FCAD2A]/60'}`}></div>
                </div>

                <!-- 卡片：在 md 上左右交替 -->
                <div class={`w-full md:w-[calc(50%-2rem)] p-4 rounded-xl bg-white/5 border border-white/10 hover:border-[#FCAD2A]/25 transition-colors ${i % 2 === 0 ? 'md:mr-auto' : 'md:ml-auto'}`}>
                  <time class="text-xs font-mono text-[#FCAD2A]/70">{m.date}</time>
                  <h3 class="text-sm font-semibold text-white mt-1">{m.title}</h3>
                  <p class="text-xs text-white/50 mt-1 leading-relaxed">{m.impact}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 text-white/40 text-sm">进化轨迹数据加载中…</div>
      )}
    </div>
  </section>

  <!-- ═══ 区块4：思想领导力（占位） ══════════════════════════════════════ -->
  <section class="py-16 px-6 border-t border-white/10" data-reveal>
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-3">System Design Insights / 系统设计思考</p>
        <h2 class="text-3xl font-bold text-white mb-3" style="font-family: var(--font-display, 'Fraunces', Georgia, serif);">
          从实战中提炼
        </h2>
        <p class="text-white/50 max-w-xl mx-auto text-sm leading-relaxed">
          来自真实运营的框架与教训——不是教程，是从连续运行的真实踩坑中提炼的设计原则。
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- 占位卡片 -->
        <div class="p-6 rounded-xl border border-dashed border-[#FCAD2A]/30 bg-[#FCAD2A]/5 flex flex-col items-center justify-center text-center min-h-[180px]">
          <div class="text-2xl mb-3">✍️</div>
          <p class="text-sm font-semibold text-white/70 mb-2">首篇文章即将发布</p>
          <p class="text-xs text-white/40 leading-relaxed">
            来自管线真实运营的案例研究——等待下一个值得分享的里程碑
          </p>
        </div>

        <!-- 预留结构 -->
        <div class="md:col-span-2 p-6 rounded-xl border border-white/5 bg-white/3 flex flex-col justify-center">
          <div class="text-center py-4 flex flex-col gap-3 items-center">
            <p class="text-xs text-white/20 uppercase tracking-wider">深度文章区</p>
            <p class="text-xs text-white/30 max-w-sm leading-relaxed">
              管线自主识别到值得记录的事件后，这里将展示从发现到行动的完整案例分析
            </p>
            <a href="/blog" class="text-xs text-[#FCAD2A]/60 hover:text-[#FCAD2A] transition-colors">
              浏览现有博客文章 →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 区块5：CTA ════════════════════════════════════════════════════ -->
  <section class="py-16 px-6" style="background: linear-gradient(135deg, #0A1628 0%, #011830 100%);">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-widest text-[#FCAD2A] uppercase mb-4">For Your Team</p>
      <h2 class="text-3xl font-bold text-white mb-4" style="font-family: var(--font-display, 'Fraunces', Georgia, serif);">
        了解 Synapse 如何服务您的团队
      </h2>
      <p class="text-white/55 mb-8 leading-relaxed">
        Synapse 自带这条演进机制。你的第一个循环，从你第一次打开 Claude Code 的清晨开始。
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/synapse/get-started" class="px-7 py-3 bg-[#FCAD2A] text-[#0A1628] font-bold rounded-xl hover:bg-[#FCAD2A]/90 transition-all text-sm">
          立即上手
        </a>
        <a href="/academy" class="px-7 py-3 bg-white/5 text-white font-semibold rounded-xl border border-white/10 hover:bg-white/10 transition-all text-sm">
          了解学院
        </a>
      </div>
    </div>
  </section>

</Layout>
