---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dailyPosts = (await getCollection('intelligence-daily'))
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const decisions = (await getCollection('intelligence-decisions'))
  .filter(d => d.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const results = (await getCollection('intelligence-results'))
  .filter(r => r.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<Layout
  title="自进化管线 | Lysander"
  description="Synapse 系统演进层。每日 5 步闭合循环，将外部信号转化为系统能力的实质提升。"
  lang="zh"
  darkContent={true}
>
  <!-- Hero -->
  <section class="pt-24 pb-12 px-6">
    <div class="max-w-4xl mx-auto text-center hero-stagger">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-sky-500/10 border border-sky-500/20 text-sky-400 text-sm font-medium mb-6">
        <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
        Synapse 演进层 · 每日循环
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: var(--font-display, 'Fraunces', Georgia, serif); letter-spacing: -0.02em;">自进化管线</h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto">
        Synapse 系统演进层。每日执行 5 步闭合循环，将外部信号转化为系统能力的实质提升。不是新闻简报——是系统的自我升级日志。
      </p>
    </div>
  </section>

  <!-- 5步自进化循环 -->
  <section class="py-4 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-5 gap-2 md:gap-3">
        {[
          { step: '01', en: 'Scan', zh: '扫描' },
          { step: '02', en: 'Bulletin', zh: '快报' },
          { step: '03', en: 'Decision', zh: '决策' },
          { step: '04', en: 'Track', zh: '追踪' },
          { step: '05', en: 'Evolve', zh: '演进' },
        ].map(s => (
          <div class="flex flex-col items-center text-center p-3 rounded-lg bg-white/5 border border-white/10">
            <span class="text-xs text-white/30 mb-1">{s.step}</span>
            <span class="text-sm font-semibold text-[#fcad2a]">{s.en}</span>
            <span class="text-xs text-white/50 mt-0.5">{s.zh}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 三栏内容线 -->
  <section class="py-8 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">

      <!-- 情报快报 -->
      <div data-reveal="left">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-sky-400">📡</span> 情报快报
          </h2>
          <a href="/intelligence/daily" class="text-sm text-sky-400 hover:text-sky-300">全部档案 →</a>
        </div>
        <div class="space-y-3">
          {dailyPosts.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">首份日报生成后自动展示</div>
          ) : dailyPosts.map(post => (
            <a href={`/intelligence/daily/${post.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-sky-500/40 transition-colors group">
              <time class="text-xs text-white/40">{post.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-sky-400 mt-1 line-clamp-2">{post.data.title}</h3>
              <div class="flex gap-2 mt-2">
                <span class="text-xs text-white/40">{post.data.itemCount} 条情报</span>
                {post.data.topScore && <span class="text-xs text-sky-400">最高 {post.data.topScore} 分</span>}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 执行决策 -->
      <div data-reveal>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-[#e9b94a]">⚖️</span> 执行决策
          </h2>
          <a href="/intelligence/decisions" class="text-sm text-[#e9b94a] hover:text-[#c96442] transition-colors">全部档案 →</a>
        </div>
        <div class="space-y-3">
          {decisions.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">评分裁定后自动展示</div>
          ) : decisions.map(d => (
            <a href={`/intelligence/decisions/${d.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-[#e9b94a]/40 transition-colors group">
              <time class="text-xs text-white/40">{d.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-[#e9b94a] mt-1 line-clamp-2">{d.data.topIntel}</h3>
              <div class="flex gap-2 mt-2 flex-wrap">
                {d.data.executeCount > 0 && <span class="text-xs text-[#e9b94a]">⚡ {d.data.executeCount} 执行</span>}
                {d.data.inboxCount > 0 && <span class="text-xs text-sky-400">📥 {d.data.inboxCount} 跟踪</span>}
                {d.data.topScore && <span class="text-xs text-white/40">最高 {d.data.topScore}</span>}
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 自我进化 -->
      <div data-reveal="right">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <span class="text-green-400">🔄</span> 演进成果
          </h2>
          <a href="/intelligence/results" class="text-sm text-green-400 hover:text-green-300">全部档案 →</a>
        </div>
        <div class="space-y-3">
          {results.length === 0 ? (
            <div class="p-4 rounded-lg bg-white/5 border border-white/10 text-white/40 text-sm text-center">行动报告生成后自动展示</div>
          ) : results.map(r => (
            <a href={`/intelligence/results/${r.data.date}`}
               class="block p-4 rounded-lg bg-white/5 border border-white/10 hover:border-green-500/40 transition-colors group">
              <time class="text-xs text-white/40">{r.data.date}</time>
              <h3 class="text-sm font-medium text-white group-hover:text-green-400 mt-1 line-clamp-2">{r.data.title}</h3>
              <div class="flex gap-2 mt-2 flex-wrap">
                {r.data.discoveredCount !== undefined ? (
                  <>
                    <span class="text-xs text-white/40">发现 {r.data.discoveredCount}</span>
                    <span class="text-xs text-sky-400">评估 {r.data.evaluatedCount ?? 0}</span>
                    {(r.data.executedCount ?? 0) > 0 && <span class="text-xs text-green-400">执行 {r.data.executedCount}</span>}
                  </>
                ) : (
                  <>
                    <span class="text-xs text-white/40">{r.data.actionsCount} 项行动</span>
                    {r.data.completedCount > 0
                      ? <span class="text-xs text-green-400">{r.data.completedCount} 项完成</span>
                      : <span class="text-xs text-white/30">执行中</span>
                    }
                  </>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
