---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const decisions = (await getCollection('intelligence-decisions'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="执行决策档案 | Lysander" description="Synapse AI 团队情报评分裁定完整记录" lang="zh" darkContent={true}>
  <section class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/intelligence" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← 情报中枢</a>
      <h1 class="text-3xl font-bold text-white mb-2">执行决策档案</h1>
      <p class="text-white/50 mb-10">每日情报评分矩阵裁定结果 — 哪些情报进入执行、跟踪或延迟</p>
      {decisions.length === 0 ? (
        <div class="text-center py-20 text-white/30">评分裁定后自动出现在这里</div>
      ) : (
        <div class="space-y-4">
          {decisions.map(d => (
            <a href={`/intelligence/decisions/${d.data.date}`}
               class="flex items-start gap-4 p-5 rounded-xl bg-white/5 border border-white/10 hover:border-purple-500/40 transition-colors group">
              <div class="flex-shrink-0 flex flex-col gap-1 items-center pt-1">
                {d.data.executeCount > 0 && (
                  <span class="text-xs px-2 py-0.5 rounded font-mono bg-purple-500/20 text-purple-400">⚡ {d.data.executeCount}</span>
                )}
                {d.data.inboxCount > 0 && (
                  <span class="text-xs px-2 py-0.5 rounded font-mono bg-sky-500/20 text-sky-400">📥 {d.data.inboxCount}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-white/40 mb-1">{d.data.date} · {d.data.totalCount} 条情报评估</div>
                <h2 class="font-semibold text-white group-hover:text-purple-400 mb-1 line-clamp-1">{d.data.topIntel}</h2>
                <p class="text-sm text-white/50 line-clamp-2">{d.data.title}</p>
                {d.data.topScore && (
                  <div class="mt-1 text-xs text-white/30">最高评分 {d.data.topScore}/20</div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
