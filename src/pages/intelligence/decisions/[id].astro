---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('intelligence-decisions');
  return items.map(item => ({
    params: { id: item.data.date },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout title={`${item.data.date} 执行决策 | Lysander`} description={item.data.title} lang="zh" darkContent={true}>
  <article class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/intelligence/decisions" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← 执行决策档案</a>
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          {item.data.executeCount > 0 && (
            <span class="text-xs bg-purple-500/20 text-purple-400 px-2 py-1 rounded font-mono">⚡ {item.data.executeCount} 执行</span>
          )}
          {item.data.inboxCount > 0 && (
            <span class="text-xs bg-sky-500/20 text-sky-400 px-2 py-1 rounded font-mono">📥 {item.data.inboxCount} 跟踪</span>
          )}
          {item.data.deferredCount > 0 && (
            <span class="text-xs bg-white/10 text-white/40 px-2 py-1 rounded font-mono">⏸ {item.data.deferredCount} 延迟</span>
          )}
          <span class="text-xs text-white/40">{item.data.date} · 共 {item.data.totalCount} 条情报</span>
        </div>
        <h1 class="text-3xl font-bold text-white mb-3">{item.data.topIntel}</h1>
        <p class="text-white/60">{item.data.title}</p>
        {item.data.topScore && (
          <div class="mt-2 text-sm text-white/40">最高综合评分：<span class="text-purple-400 font-mono">{item.data.topScore}/20</span></div>
        )}
      </header>
      <div class="blog-content">
        <Content />
      </div>
      <footer class="mt-12 pt-6 border-t border-white/10 flex justify-between items-center">
        <a href="/intelligence/decisions" class="text-sm text-white/40 hover:text-white">← 查看全部档案</a>
        <a href="/intelligence" class="text-sm text-purple-400 hover:text-purple-300">情报中枢 →</a>
      </footer>
    </div>
  </article>
</Layout>
