---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // RESTORED (2026-06-01): intelligence hub redesigned and relaunched.
  const items = await getCollection('intelligence-decisions');
  return items
    .filter(item => item.data.date)
    .map(item => ({
      params: { id: item.data.date },
      props: { item },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);
// DE-5 (2026-05-31): honest-empty detail state. A day with truthfulness:empty is
// "今日无新情报" — render the honest marker, NOT "共 0 条情报" (which mimics a real
// scoring day that found nothing).
const isHonestEmpty = item.data.truthfulness === 'empty';
---

<Layout title={`${item.data.date} 执行决策 | Lysander`} description={item.data.title} lang="zh" darkContent={true}>
  <article class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/intelligence/decisions" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← 执行决策档案</a>
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          {isHonestEmpty ? (
            <span class="text-xs bg-white/10 text-white/50 px-2 py-1 rounded font-mono">{item.data.date} · 今日无新情报</span>
          ) : (
            <>
              {item.data.executeCount > 0 && (
                <span class="text-xs bg-[#e9b94a]/15 text-[#e9b94a] px-2 py-1 rounded font-mono">⚡ {item.data.executeCount} 执行</span>
              )}
              {item.data.inboxCount > 0 && (
                <span class="text-xs bg-sky-500/20 text-sky-400 px-2 py-1 rounded font-mono">📥 {item.data.inboxCount} 跟踪</span>
              )}
              {item.data.deferredCount > 0 && (
                <span class="text-xs bg-white/10 text-white/40 px-2 py-1 rounded font-mono">⏸ {item.data.deferredCount} 延迟</span>
              )}
              <span class="text-xs text-white/40">{item.data.date} · 共 {item.data.totalCount} 条情报</span>
            </>
          )}
        </div>
        <h1 class="text-3xl font-bold text-white mb-3">{item.data.topIntel}</h1>
        <p class="text-white/60">{item.data.title}</p>
        {!isHonestEmpty && item.data.topScore && (
          <div class="mt-2 text-sm text-white/40">最高综合评分：<span class="text-[#e9b94a] font-mono">{item.data.topScore}/20</span></div>
        )}
      </header>
      <div class="blog-content">
        <Content />
      </div>
      <footer class="mt-12 pt-6 border-t border-white/10 flex justify-between items-center">
        <a href="/intelligence/decisions" class="text-sm text-white/40 hover:text-white">← 查看全部档案</a>
        <a href="/intelligence" class="text-sm text-[#e9b94a] hover:text-[#c96442] transition-colors">情报中枢 →</a>
      </footer>
    </div>
  </article>
</Layout>
