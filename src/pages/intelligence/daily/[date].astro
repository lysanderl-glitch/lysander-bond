---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('intelligence-daily');
  // Only ZH entries own the /intelligence/daily/[date] canonical route.
  // EN stub files share the same `date` frontmatter field and would overwrite
  // the ZH entry when both are mapped to params:{date}, because the glob loader
  // processes files alphabetically and "2026-05-21-en.md" sorts after
  // "2026-05-21.md", causing Astro to keep the EN entry as the winner.
  const zhPosts = posts.filter(post => post.data.lang !== 'en');
  return zhPosts.map(post => ({
    params: { date: post.data.date },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | 情报快报`} description={post.data.summary} lang="zh" darkContent={true}>
  <article class="pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/intelligence/daily" class="text-sm text-white/40 hover:text-white/70 mb-6 inline-block">← 情报快报档案</a>
      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs bg-sky-500/20 text-sky-400 px-2 py-1 rounded-full font-mono">{post.data.date}</span>
          <span class="text-xs text-white/40">{post.data.itemCount} 条情报 · 自动生成</span>
        </div>
        <h1 class="text-3xl font-bold text-white mb-3" style="font-family: var(--font-display, 'Fraunces', Georgia, serif);">{post.data.title}</h1>
        <p class="text-white/60">{post.data.summary}</p>
      </header>
      <div class="blog-content">
        <Content />
      </div>
      <div class="mt-10 p-4 rounded-lg bg-sky-500/5 border border-sky-500/20">
        <p class="text-xs text-white/40 mb-1">情报评估与行动</p>
        <p class="text-sm text-white/60 mb-2">本期情报已进入 Synapse 分析管线，生成执行行动报告。</p>
        <a href="/intelligence/results" class="text-sm text-sky-400 hover:text-sky-300 transition-colors">查看执行行动报告 →</a>
      </div>
      <footer class="mt-12 pt-6 border-t border-white/10 flex justify-between items-center">
        <a href="/intelligence/daily" class="text-sm text-white/40 hover:text-white">← 查看全部档案</a>
        <a href="/intelligence" class="text-sm text-sky-400 hover:text-sky-300">情报中枢 →</a>
      </footer>
    </div>
  </article>
</Layout>
