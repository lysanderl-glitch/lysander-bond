---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

function getDiaryText(dateStr: string): string {
  try {
    const filePath = `/home/ubuntu/knowledge-base/daily/${dateStr}.html`;
    const content = fs.readFileSync(filePath, 'utf-8');
    const textMatch = content.match(/<div class="text">(.*?)<\/div>/s);
    if (!textMatch) return '';
    const text = textMatch[1].replace(/<[^>]+>/g, '').trim();
    return text.substring(0, 120) + (text.length > 120 ? '...' : '');
  } catch {
    return '';
  }
}

const dailyFiles = [
  { date: '2026-04-06', day: '星期一' },
  { date: '2026-04-05', day: '星期日' },
  { date: '2026-04-04', day: '星期六' },
  { date: '2026-04-03', day: '星期五' },
];

const diaries = dailyFiles.map(f => ({
  ...f,
  text: getDiaryText(f.date)
}));
---

<Layout title="日常记录 - Lysander" description="日常生活记录">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-white mb-4">日常记录</h1>
    <p class="text-white/60 mb-12">生活随笔、工作日常、偶尔的思考</p>

    <div class="space-y-6">
      {diaries.map((diary) => (
        <a href={`/daily/${diary.date}`} class="group block p-6 bg-white/5 rounded-xl border border-white/10 hover:border-cyan-500/50 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <time class="text-white/40 text-sm">{diary.date}</time>
            <span class="text-white/30">·</span>
            <span class="text-cyan-400 text-sm">{diary.day}</span>
          </div>
          <p class="text-white/70 leading-relaxed">
            {diary.text || '暂无内容'}
          </p>
          <p class="text-cyan-400 text-sm mt-3 group-hover:text-cyan-300">阅读全文 →</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
