  <div id="game-area">
    <canvas id="game-canvas"></canvas>
    <div class="shooter-label">🌸 汐弥</div>
  </div>
</div>

<!-- END SCREEN -->
<div id="screen-end" class="screen">
  <div class="end-box">
    <div class="end-label">最终得分</div>
    <div class="end-score" id="e-score">0</div>
    <div class="end-title" id="e-title">精彩表现！</div>
    <div class="end-sub" id="e-sub">汐弥收到了你的礼物</div>
    <div class="gifts-earned" id="e-gifts"></div>
    <div class="btn-row" style="justify-content:center">
      <button class="btn" id="btn-replay">再来一局</button>
      <button class="btn" style="border-color:var(--lav);background:rgba(200,160,212,0.1);color:var(--lav)" id="btn-back">返回</button>
    </div>
  </div>
</div>

<script is:inline>
window.addEventListener('DOMContentLoaded', function() {

  // ── BUBBLE TYPES ──
  var TYPES = [
    {id:0, emoji:'🍭', name:'棒棒糖', color:'#ff69b4', dark:'#cc1468', glow:'rgba(255,105,180,.7)'},
    {id:1, emoji:'💖', name:'爱心',   color:'#ff2255', dark:'#990022', glow:'rgba(255,34,85,.7)'},
    {id:2, emoji:'🌸', name:'小花花', color:'#ffb7c5', dark:'#cc6080', glow:'rgba(255,183,197,.7)'},
    {id:3, emoji:'⭐', name:'星星',   color:'#ffd700', dark:'#cc9900', glow:'rgba(255,215,0,.7)'},
    {id:4, emoji:'🎁', name:'礼物',   color:'#b86eff', dark:'#7733cc', glow:'rgba(184,110,255,.7)'},
    {id:5, emoji:'✨', name:'彩虹糖', color:'#00d4e8', dark:'#007a88', glow:'rgba(0,212,232,.7)'},
  ];
  var NT = TYPES.length;

  var GIFT_TIERS = [
    {threshold:100, emoji:'🎆', name:'烟花秀',   color:'#ff6eb4', border:'#ff0080'},
    {threshold:150, emoji:'🏎️', name:'超级跑车', color:'#ffd700', border:'#cc9900'},
    {threshold:200, emoji:'🚀', name:'火箭',     color:'#c8a0d4', border:'#9b59b6'},
    {threshold:250, emoji:'🏰', name:'梦幻城堡', color:'#ff0080', border:'#cc0066'},
  ];

  // ── GAME STATE ──
  var canvas, ctx, W, H, R, COLS;
  var grid = [];
  var flyBubble = null;
  var curType, nextType;
  var score = 0;
  var aimX = 0, aimY = 0, aiming = false;
  var giftsShown = new Set();
  var gameActive = false;
  var raf = null;
  var timeLeft = 30;
  var timerInterval = null;
  var notifQueue = [], notifShowing = false;

  // ── SCREENS ──
  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
    document.getElementById(id).classList.add('active');
  }

  // ── BUTTON BINDINGS ──
  document.getElementById('btn-start').addEventListener('click', startGame);
  document.getElementById('btn-replay').addEventListener('click', startGame);
  document.getElementById('btn-back').addEventListener('click', function() {
    stopGame();
    showScreen('screen-title');
  });

  // ── GRID HELPERS ──
  function colX(col, row) {
    var offset = (row % 2 === 1) ? R : 0;
    return offset + col * (2 * R) + R;
  }
  function rowY(row) {
    return row * (R * 1.73) + R + 4;
  }

  function initGrid() {
    R = Math.min(24, Math.max(16, Math.floor(W / 18)));
    COLS = Math.floor(W / (2 * R));
    grid = [];
    var initRows = Math.min(5, Math.floor(H * 0.55 / (R * 1.73)));
    for (var r = 0; r < initRows; r++) {
      var cols = r % 2 === 0 ? COLS : COLS - 1;
      var row = [];
      for (var c = 0; c < cols; c++) {
        row.push(Math.floor(Math.random() * NT));
      }
      grid.push(row);
    }
  }

  function nearestCell(x, y) {
    var bestR = 0, bestC = 0, bestD = Infinity;
    var maxSearch = Math.min(grid.length + 2, 20);
    for (var r = 0; r < maxSearch; r++) {
      var cols = r % 2 === 0 ? COLS : COLS - 1;
      for (var c = 0; c < cols; c++) {
        var cx = colX(c, r), cy = rowY(r);
        var d = (x - cx) * (x - cx) + (y - cy) * (y - cy);
        if (d < bestD) { bestD = d; bestR = r; bestC = c; }
      }
    }
    return {r: bestR, c: bestC};
  }

  // ── BUBBLE MANAGEMENT ──
  function randType() { return Math.floor(Math.random() * NT); }

  function pickNextType() {
    // Prefer types already in grid to make matches more likely
    var inGrid = [];
    for (var r = 0; r < Math.min(grid.length, 4); r++) {
      for (var c = 0; c < grid[r].length; c++) {
        if (grid[r][c] >= 0) inGrid.push(grid[r][c]);
      }
    }
    if (inGrid.length > 0 && Math.random() < 0.65) {
      return inGrid[Math.floor(Math.random() * inGrid.length)];
    }
    return randType();
  }

  function newBubble() {
    curType = (nextType !== undefined) ? nextType : pickNextType();
    nextType = pickNextType();
    var nb = document.getElementById('g-next');
    if (nb) {
      nb.textContent = TYPES[nextType].emoji;
      nb.style.background = TYPES[nextType].color + '33';
      nb.style.borderColor = TYPES[nextType].color;
    }
  }

  // ── DRAW ──
  function drawBubble(x, y, typeId, alpha, scale) {
    if (typeId < 0 || typeId >= NT) return;
    var t = TYPES[typeId];
    alpha = alpha || 1;
    scale = scale || 1;
    ctx.save();
    ctx.globalAlpha = alpha;
    ctx.translate(x, y);
    ctx.scale(scale, scale);
    ctx.shadowColor = t.glow;
    ctx.shadowBlur = 8;
    var g = ctx.createRadialGradient(-R * .3, -R * .3, R * .1, 0, 0, R * .95);
    g.addColorStop(0, '#fff');
    g.addColorStop(0.3, t.color);
    g.addColorStop(1, t.dark);
    ctx.beginPath();
    ctx.arc(0, 0, R * .92, 0, Math.PI * 2);
    ctx.fillStyle = g;
    ctx.fill();
    ctx.shadowBlur = 0;
    ctx.font = (R * .9) + 'px serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(t.emoji, 0, R * .05);
    ctx.restore();
  }

  function drawShooter() {
    var sx = W / 2, sy = H - R * 2.2;
    if (aiming) {
      ctx.save();
      ctx.strokeStyle = 'rgba(255,0,128,0.45)';
      ctx.lineWidth = 2;
      ctx.setLineDash([5, 7]);
      var tx = sx, ty = sy;
      var dx = aimX - sx, dy = aimY - sy;
      var len = Math.sqrt(dx * dx + dy * dy);
      if (len > 0) { dx /= len; dy /= len; }
      ctx.beginPath();
      ctx.moveTo(tx, ty);
      for (var i = 0; i < 150; i++) {
        tx += dx * 8; ty += dy * 8;
        if (tx < R) { tx = R; dx *= -1; }
        if (tx > W - R) { tx = W - R; dx *= -1; }
        if (ty < 0) break;
        ctx.lineTo(tx, ty);
      }
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();
    }
    // Platform glow
    ctx.save();
    var grad = ctx.createRadialGradient(sx, sy + R, 0, sx, sy + R, R * 2.5);
    grad.addColorStop(0, 'rgba(255,0,128,0.25)');
    grad.addColorStop(1, 'rgba(255,0,128,0)');
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.ellipse(sx, sy + R * 1.2, R * 2, R * .7, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
    // Current bubble
    if (!flyBubble) drawBubble(sx, sy, curType, 1, 1);
  }

  function drawGrid() {
    for (var r = 0; r < grid.length; r++) {
      for (var c = 0; c < grid[r].length; c++) {
        if (grid[r][c] >= 0) {
          drawBubble(colX(c, r), rowY(r), grid[r][c]);
        }
      }
    }
  }

  function render() {
    ctx.clearRect(0, 0, W, H);
    // Danger line
    var dangerY = H * 0.75;
    ctx.save();
    ctx.strokeStyle = 'rgba(255,0,80,0.2)';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([8, 6]);
    ctx.beginPath();
    ctx.moveTo(0, dangerY);
    ctx.lineTo(W, dangerY);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();
    drawGrid();
    drawShooter();
    if (flyBubble) drawBubble(flyBubble.x, flyBubble.y, flyBubble.typeId, 1, 1);
  }

  // ── PHYSICS ──
  function gameLoop() {
    if (!gameActive) return;
    if (flyBubble) {
      flyBubble.x += flyBubble.dx;
      flyBubble.y += flyBubble.dy;
      if (flyBubble.x < R) { flyBubble.x = R; flyBubble.dx *= -1; }
      if (flyBubble.x > W - R) { flyBubble.x = W - R; flyBubble.dx *= -1; }
      // Collision with grid
      var hit = false;
      for (var r = 0; r < grid.length && !hit; r++) {
        for (var c = 0; c < grid[r].length && !hit; c++) {
          if (grid[r][c] < 0) continue;
          var cx = colX(c, r), cy = rowY(r);
          var d = Math.sqrt((flyBubble.x - cx) * (flyBubble.x - cx) + (flyBubble.y - cy) * (flyBubble.y - cy));
          if (d < R * 1.9) { hit = true; }
        }
      }
      if (flyBubble.y <= R + 2) hit = true;
      if (hit) landBubble();
    }
    render();
    raf = requestAnimationFrame(gameLoop);
  }

  function landBubble() {
    if (!flyBubble) return;
    var cell = nearestCell(flyBubble.x, flyBubble.y);
    var r = cell.r, c = cell.c;
    // Ensure rows exist
    while (grid.length <= r) {
      var newLen = grid.length % 2 === 0 ? COLS : COLS - 1;
      grid.push(new Array(newLen).fill(-1));
    }
    var maxC = r % 2 === 0 ? COLS : COLS - 1;
    c = Math.max(0, Math.min(c, maxC - 1));
    // Place bubble
    if (grid[r][c] === -1) {
      grid[r][c] = flyBubble.typeId;
      checkMatches(r, c);
    } else {
      // Find nearby empty cell
      var placed = false;
      var offsets = [[0, c - 1], [0, c + 1], [-1, c], [1, c], [-1, c - 1], [-1, c + 1]];
      for (var i = 0; i < offsets.length && !placed; i++) {
        var nr = r + offsets[i][0], nc = offsets[i][1];
        if (nr < 0) continue;
        while (grid.length <= nr) {
          var nlen = grid.length % 2 === 0 ? COLS : COLS - 1;
          grid.push(new Array(nlen).fill(-1));
        }
        var nmax = nr % 2 === 0 ? COLS : COLS - 1;
        if (nc < 0 || nc >= nmax) continue;
        if (grid[nr][nc] === -1) {
          grid[nr][nc] = flyBubble.typeId;
          checkMatches(nr, nc);
          placed = true;
        }
      }
    }
    flyBubble = null;
    aiming = false;
    checkGameOver();
    newBubble();
  }

  // ── MATCH LOGIC ──
  function getNeighbors(r, c) {
    var nbrs = [];
    var even = r % 2 === 0;
    var candidates = [
      [r, c - 1], [r, c + 1],
      [r - 1, even ? c - 1 : c], [r - 1, even ? c : c + 1],
      [r + 1, even ? c - 1 : c], [r + 1, even ? c : c + 1],
    ];
    for (var i = 0; i < candidates.length; i++) {
      var nr = candidates[i][0], nc = candidates[i][1];
      if (nr < 0 || nr >= grid.length) continue;
      var maxC = nr % 2 === 0 ? COLS : COLS - 1;
      if (nc < 0 || nc >= maxC) continue;
      nbrs.push([nr, nc]);
    }
    return nbrs;
  }

  function bfs(startR, startC, matchType) {
    var visited = {};
    var queue = [[startR, startC]];
    visited[startR + ',' + startC] = true;
    while (queue.length) {
      var cur = queue.shift();
      var r = cur[0], c = cur[1];
      var nbrs = getNeighbors(r, c);
      for (var i = 0; i < nbrs.length; i++) {
        var nr = nbrs[i][0], nc = nbrs[i][1];
        var key = nr + ',' + nc;
        if (visited[key]) continue;
        if (nr < grid.length && nc < grid[nr].length && grid[nr][nc] === matchType) {
          visited[key] = true;
          queue.push([nr, nc]);
        }
      }
    }
    return Object.keys(visited).map(function(k) { return k.split(',').map(Number); });
  }

  function checkMatches(r, c) {
    if (r >= grid.length || c >= grid[r].length || grid[r][c] < 0) return;
    var typeId = grid[r][c];
    var matched = bfs(r, c, typeId);
    if (matched.length >= 3) {
      for (var i = 0; i < matched.length; i++) {
        var mr = matched[i][0], mc = matched[i][1];
        spawnParticles(colX(mc, mr), rowY(mr), typeId);
        grid[mr][mc] = -1;
      }
      var pts = matched.length * 10 + (matched.length > 3 ? (matched.length - 3) * 5 : 0);
      addScore(pts);
      removeFloaters();
    }
  }

  function removeFloaters() {
    var connected = {};
    var queue = [];
    if (grid[0]) {
      for (var c = 0; c < grid[0].length; c++) {
        if (grid[0][c] >= 0) {
          connected['0,' + c] = true;
          queue.push([0, c]);
        }
      }
    }
    while (queue.length) {
      var cur = queue.shift();
      var r = cur[0], c2 = cur[1];
      var nbrs = getNeighbors(r, c2);
      for (var i = 0; i < nbrs.length; i++) {
        var nr = nbrs[i][0], nc = nbrs[i][1];
        var key = nr + ',' + nc;
        if (connected[key]) continue;
        if (nr < grid.length && nc < (grid[nr] ? grid[nr].length : 0) && grid[nr][nc] >= 0) {
          connected[key] = true;
          queue.push([nr, nc]);
        }
      }
    }
    var bonus = 0;
    for (var r2 = 0; r2 < grid.length; r2++) {
      for (var c3 = 0; c3 < grid[r2].length; c3++) {
        if (grid[r2][c3] >= 0 && !connected[r2 + ',' + c3]) {
          spawnParticles(colX(c3, r2), rowY(r2), grid[r2][c3]);
          grid[r2][c3] = -1;
          bonus += 5;
        }
      }
    }
    if (bonus > 0) addScore(bonus);
  }

  function checkGameOver() {
    // If any bubble below danger line → end
    var dangerRow = Math.floor(H * 0.72 / (R * 1.73));
    for (var r = dangerRow; r < grid.length; r++) {
      for (var c = 0; c < grid[r].length; c++) {
        if (grid[r][c] >= 0) { endGame(); return; }
      }
    }
    // All cleared → bonus + new rows
    var any = false;
    for (var r2 = 0; r2 < grid.length; r2++) {
      for (var c2 = 0; c2 < grid[r2].length; c2++) {
        if (grid[r2][c2] >= 0) { any = true; break; }
      }
      if (any) break;
    }
    if (!any) {
      addScore(50);
      for (var i = 0; i < 3; i++) {
        var cols = i % 2 === 0 ? COLS : COLS - 1;
        var row = [];
        for (var j = 0; j < cols; j++) row.push(Math.floor(Math.random() * NT));
        grid.unshift(row);
      }
    }
  }

  // ── SCORE & GIFTS ──
  function addScore(pts) {
    score += pts;
    var el = document.getElementById('g-score');
    if (el) el.textContent = score;
    for (var i = 0; i < GIFT_TIERS.length; i++) {
      var g = GIFT_TIERS[i];
      if (score >= g.threshold && !giftsShown.has(g.threshold)) {
        giftsShown.add(g.threshold);
        showGiftNotif(g);
      }
    }
  }

  function showGiftNotif(g) {
    notifQueue.push(g);
    if (!notifShowing) processNotifQueue();
  }

  function processNotifQueue() {
    if (!notifQueue.length) { notifShowing = false; return; }
    notifShowing = true;
    var g = notifQueue.shift();
    var el = document.createElement('div');
    el.className = 'gift-notif';
    el.style.borderColor = g.border;
    el.innerHTML = '<div class="gift-notif-icon">' + g.emoji + '</div>'
      + '<div><div class="gift-notif-name" style="color:' + g.color + '">' + g.name + '</div>'
      + '<div class="gift-notif-sub">汐弥收到了！× 1</div></div>';
    document.body.appendChild(el);
    launchFirework();
    setTimeout(function() { el.classList.add('show'); }, 50);
    setTimeout(function() {
      el.classList.remove('show');
      setTimeout(function() { el.remove(); processNotifQueue(); }, 600);
    }, 3000);
  }

  function launchFirework() {
    var colors = ['#ff0080','#ffd700','#ff6eb4','#c8a0d4','#00d4e8','#fff'];
    var area = document.getElementById('game-area');
    if (!area) return;
    for (var f = 0; f < 3; f++) {
      (function(delay) {
        setTimeout(function() {
          var fx = W * (.2 + Math.random() * .6);
          var fy = H * (.1 + Math.random() * .35);
          for (var i = 0; i < 18; i++) {
            var p = document.createElement('div');
            var angle = (i / 18) * Math.PI * 2;
            var dist = 45 + Math.random() * 55;
            var col = colors[Math.floor(Math.random() * colors.length)];
            var sz = 4 + Math.random() * 4;
            p.className = 'particle';
            p.style.cssText = 'width:' + sz + 'px;height:' + sz + 'px;background:' + col + ';left:' + fx + 'px;top:' + fy + 'px;box-shadow:0 0 5px ' + col + ';transition:all .65s ease;opacity:1;';
            area.appendChild(p);
            requestAnimationFrame(function(pp, fa, fd, angle2) {
              return function() {
                pp.style.left = (fa + Math.cos(angle2) * fd) + 'px';
                pp.style.top = (fy + Math.sin(angle2) * fd) + 'px';
                pp.style.opacity = '0';
                pp.style.transform = 'scale(0)';
              };
            }(p, fx, dist, angle));
            setTimeout(function(pp) { return function() { pp.remove(); }; }(p), 700);
          }
        }, delay);
      }(f * 230));
    }
  }

  function spawnParticles(x, y, typeId) {
    var area = document.getElementById('game-area');
    if (!area) return;
    var col = TYPES[typeId] ? TYPES[typeId].color : '#ff0080';
    for (var i = 0; i < 8; i++) {
      var p = document.createElement('div');
      var angle = (i / 8) * Math.PI * 2;
      var dist = 18 + Math.random() * 18;
      p.className = 'particle';
      p.style.cssText = 'width:5px;height:5px;background:' + col + ';left:' + x + 'px;top:' + y + 'px;box-shadow:0 0 4px ' + col + ';transition:all .45s ease;opacity:1;';
      area.appendChild(p);
      (function(pp, px, py2, a, d) {
        requestAnimationFrame(function() {
          pp.style.left = (px + Math.cos(a) * d) + 'px';
          pp.style.top = (py2 + Math.sin(a) * d) + 'px';
          pp.style.opacity = '0';
        });
        setTimeout(function() { pp.remove(); }, 480);
      }(p, x, y, angle, dist));
    }
  }

  // ── INPUT ──
  function getXY(e) {
    var rect = canvas.getBoundingClientRect();
    if (e.touches && e.touches.length > 0) {
      return {x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top};
    }
    if (e.changedTouches && e.changedTouches.length > 0) {
      return {x: e.changedTouches[0].clientX - rect.left, y: e.changedTouches[0].clientY - rect.top};
    }
    return {x: e.clientX - rect.left, y: e.clientY - rect.top};
  }

  function onMove(e) {
    if (!gameActive) return;
    e.preventDefault();
    var pos = getXY(e);
    aimX = pos.x; aimY = pos.y;
    aiming = pos.y < H - R * 2;
  }

  function onUp(e) {
    if (!gameActive || flyBubble) return;
    e.preventDefault();
    var pos = getXY(e);
    var sx = W / 2, sy = H - R * 2.2;
    var dx = pos.x - sx, dy = pos.y - sy;
    if (dy > -10) return; // must aim upward
    var len = Math.sqrt(dx * dx + dy * dy);
    if (len < 5) return;
    var speed = 9;
    flyBubble = {x: sx, y: sy, dx: (dx / len) * speed, dy: (dy / len) * speed, typeId: curType};
    aiming = false;
  }

  // ── TIMER ──
  function startTimer() {
    timeLeft = 30;
    updateTimerDisplay();
    timerInterval = setInterval(function() {
      timeLeft--;
      updateTimerDisplay();
      if (timeLeft <= 0) {
        clearInterval(timerInterval);
        timerInterval = null;
        endGame();
      }
    }, 1000);
  }

  function updateTimerDisplay() {
    var el = document.getElementById('g-timer');
    if (!el) return;
    el.textContent = timeLeft;
    if (timeLeft <= 10) el.classList.add('urgent');
    else el.classList.remove('urgent');
  }

  function stopTimer() {
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  }

  // ── GAME CONTROL ──
  function stopGame() {
    gameActive = false;
    if (raf) { cancelAnimationFrame(raf); raf = null; }
    stopTimer();
  }

  function startGame() {
    stopGame();
    score = 0;
    giftsShown = new Set();
    flyBubble = null;
    aiming = false;
    notifQueue = []; notifShowing = false;

    canvas = document.getElementById('game-canvas');
    var area = document.getElementById('game-area');
    // Size canvas to fill game-area
    W = area.clientWidth || window.innerWidth;
    H = area.clientHeight || (window.innerHeight - 60);
    if (W === 0) W = window.innerWidth;
    if (H === 0) H = window.innerHeight - 60;
    canvas.width = W;
    canvas.height = H;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx = canvas.getContext('2d');

    initGrid();
    nextType = undefined;
    newBubble();

    document.getElementById('g-score').textContent = '0';

    // Remove old listeners by cloning
    var newCanvas = canvas.cloneNode(true);
    canvas.parentNode.replaceChild(newCanvas, canvas);
    canvas = newCanvas;
    ctx = canvas.getContext('2d');

    canvas.addEventListener('mousemove', onMove);
    canvas.addEventListener('mouseup', onUp);
    canvas.addEventListener('touchstart', function(e) { e.preventDefault(); var p = getXY(e); aimX = p.x; aimY = p.y; aiming = p.y < H - R * 2; }, {passive: false});
    canvas.addEventListener('touchmove', onMove, {passive: false});
    canvas.addEventListener('touchend', onUp, {passive: false});

    showScreen('screen-game');
    gameActive = true;
    if (raf) cancelAnimationFrame(raf);
    gameLoop();
    startTimer();
  }

  function endGame() {
    stopGame();
    document.getElementById('e-score').textContent = score;
    var titles = [
      [250, '传说！梦幻城堡已解锁', '汐弥被你的礼物感动了 ✨'],
      [200, '太厉害了！火箭升空',   '满满的爱意送到主播啦 🚀'],
      [150, '超棒！超级跑车解锁',   '汐弥好开心！继续加油 🏎️'],
      [100, '不错！烟花秀解锁',     '汐弥收到你的礼物了 🎆'],
      [  0, '加油！下次更好',       '汐弥依然爱你哦 💕'],
    ];
    var found = titles.find(function(t) { return score >= t[0]; });
    document.getElementById('e-title').textContent = found[1];
    document.getElementById('e-sub').textContent = found[2];
    var giftsEl = document.getElementById('e-gifts');
    giftsEl.innerHTML = '';
    for (var i = 0; i < GIFT_TIERS.length; i++) {
      var g = GIFT_TIERS[i];
      if (score >= g.threshold) {
        var chip = document.createElement('div');
        chip.className = 'gift-chip';
        chip.style.cssText = 'color:' + g.color + ';border-color:' + g.border + ';background:' + g.border + '22;';
        chip.textContent = g.emoji + ' ' + g.name;
        giftsEl.appendChild(chip);
      }
    }
    if (giftsEl.children.length === 0) {
      giftsEl.innerHTML = '<div style="font-size:12px;color:#5a3050">继续努力解锁礼物！</div>';
    }
    showScreen('screen-end');
  }

  // ── BG PARTICLES ──
  (function() {
    var bgCanvas = document.createElement('canvas');
    bgCanvas.style.cssText = 'position:fixed;inset:0;z-index:1;pointer-events:none;';
    document.body.insertBefore(bgCanvas, document.body.firstChild);
    var bgCtx = bgCanvas.getContext('2d');
    var bW, bH, pts = [];
    function rsz() { bW = bgCanvas.width = window.innerWidth; bH = bgCanvas.height = window.innerHeight; }
    rsz();
    window.addEventListener('resize', rsz);
    var SYM = ['✦','♡','✧','·','★','°'];
    function mk() {
      return {x: Math.random() * bW, y: bH + 10, sz: 8 + Math.random() * 10, sp: 0.2 + Math.random() * 0.4,
        op: 0.05 + Math.random() * 0.15, sym: SYM[Math.floor(Math.random() * SYM.length)],
        hue: Math.random() < 0.6 ? 330 : Math.random() < 0.5 ? 280 : 50,
        dx: (Math.random() - .5) * .3, wb: Math.random() * Math.PI * 2, ws: 0.01 + Math.random() * .02};
    }
    for (var i = 0; i < 30; i++) { var p = mk(); p.y = Math.random() * bH; pts.push(p); }
    function draw() {
      bgCtx.clearRect(0, 0, bW, bH);
      for (var j = 0; j < pts.length; j++) {
        var pt = pts[j];
        pt.y -= pt.sp; pt.wb += pt.ws; pt.x += pt.dx + Math.sin(pt.wb) * .2;
        bgCtx.save();
        bgCtx.globalAlpha = pt.op;
        bgCtx.fillStyle = 'hsl(' + pt.hue + ',80%,70%)';
        bgCtx.font = pt.sz + 'px serif';
        bgCtx.textAlign = 'center';
        bgCtx.fillText(pt.sym, pt.x, pt.y);
        bgCtx.restore();
        if (pt.y < -20) pts[j] = mk();
      }
      requestAnimationFrame(draw);
    }
    draw();
  }());

}); // end DOMContentLoaded
</script>
</body>
</html>
