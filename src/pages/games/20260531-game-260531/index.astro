<!-- 汐弥泡泡射击 v1.0 - 2026-05-31 -->
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
  <title>汐弥泡泡射击</title>
  <style is:global>
    :root{--pk:#FF0080;--pks:#F4A0C0;--lav:#C8A0D4;--gold:#F0C840;--dark:#0a0010;--dark2:#120018;--glow:rgba(255,0,128,0.5);}
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{height:100%;overflow:hidden;background:var(--dark);}
    body{color:#fde8f0;font-family:'PingFang SC','Microsoft YaHei',sans-serif;user-select:none;touch-action:none;}
    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,0,128,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,0,128,0.04) 1px,transparent 1px);background-size:50px 50px;pointer-events:none;z-index:0;}

    .screen{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;z-index:10;}
    .screen.active{display:flex;animation:fadeIn .4s ease both;}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}

    /* ── TITLE ── */
    #st{background:radial-gradient(ellipse at 50% 40%,rgba(255,0,128,0.15) 0%,transparent 70%)}
    .av-ring{width:130px;height:130px;border-radius:50%;border:3px solid var(--pk);box-shadow:0 0 24px var(--glow),0 0 60px var(--glow);overflow:hidden;margin-bottom:16px;animation:float 3s ease-in-out infinite;}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    .t-main{font-size:26px;font-weight:700;letter-spacing:4px;color:#fff;text-shadow:0 0 20px var(--glow);margin-bottom:6px;}
    .t-sub{font-size:13px;color:var(--pks);letter-spacing:2px;margin-bottom:28px;}
    .btn{padding:11px 30px;border:1.5px solid var(--pk);background:rgba(255,0,128,0.12);color:#fff;font-size:14px;letter-spacing:2px;cursor:pointer;border-radius:6px;transition:.2s;font-family:inherit;}
    .btn:active{background:rgba(255,0,128,0.35);}
    .btn-row{display:flex;gap:12px;}
    .badge-row{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:20px;}
    .badge{padding:4px 12px;border-radius:20px;font-size:11px;border:1px solid rgba(255,0,128,0.3);background:rgba(255,0,128,0.08);color:var(--pks);letter-spacing:1px;}

    /* ── GAME SCREEN ── */
    #sg{padding:0;justify-content:flex-start;}
    .hud{width:100%;padding:8px 14px 6px;background:rgba(10,0,16,0.9);border-bottom:1px solid rgba(255,0,128,0.2);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:20;}
    .hud-score{font-size:20px;font-weight:700;color:#fff;text-shadow:0 0 10px var(--glow);}
    .hud-label{font-size:10px;color:#8a6070;letter-spacing:1px;margin-bottom:2px;}
    .hud-next-wrap{display:flex;flex-direction:column;align-items:center;}
    .next-bubble{width:38px;height:38px;border-radius:50%;border:2px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;font-size:18px;}
    #g-canvas-wrap{flex:1;width:100%;position:relative;overflow:hidden;}
    #g-canvas{display:block;touch-action:none;}

    /* ── GIFT NOTIFICATION ── */
    .gift-notif{position:fixed;right:-300px;top:30%;transform:translateY(-50%);z-index:200;pointer-events:none;
      background:linear-gradient(135deg,rgba(18,0,28,0.97),rgba(30,0,50,0.97));
      border:1px solid;border-radius:12px 0 0 12px;padding:12px 20px 12px 16px;
      display:flex;align-items:center;gap:12px;min-width:200px;
      transition:right .5s cubic-bezier(.23,1,.32,1);}
    .gift-notif.show{right:0;}
    .gift-notif-icon{font-size:36px;animation:float 1s ease-in-out infinite;}
    .gift-notif-text{display:flex;flex-direction:column;}
    .gift-notif-name{font-size:15px;font-weight:700;letter-spacing:2px;}
    .gift-notif-sub{font-size:11px;opacity:.7;margin-top:2px;}

    /* ── END SCREEN ── */
    #se{background:radial-gradient(ellipse at 50% 50%,rgba(255,0,128,0.12) 0%,transparent 70%)}
    .end-box{background:rgba(12,0,20,0.95);border:1px solid rgba(255,0,128,0.35);border-radius:16px;padding:32px 28px;text-align:center;max-width:340px;width:90%;}
    .end-score{font-size:64px;font-weight:700;color:var(--pk);text-shadow:0 0 30px var(--glow);line-height:1;}
    .end-label{font-size:11px;letter-spacing:3px;color:#8a6070;margin-bottom:4px;}
    .end-title{font-size:18px;color:#fff;margin:12px 0 4px;letter-spacing:2px;}
    .end-sub{font-size:13px;color:var(--pks);margin-bottom:24px;}
    .gifts-earned{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;}
    .gift-chip{padding:6px 14px;border-radius:20px;font-size:13px;border:1px solid;letter-spacing:1px;}

    /* ── PARTICLES ── */
    .particle{position:absolute;pointer-events:none;border-radius:50%;z-index:30;}
  </style>
</head>
