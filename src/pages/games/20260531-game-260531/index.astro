      100分 🎆 烟花秀 · 150分 🏎️ 超级跑车<br>200分 🚀 火箭 · 250分 🏰 梦幻城堡
    </div>
  </div>
</div>

<!-- GAME SCREEN -->
<div id="screen-game" class="screen">
  <div class="hud">
    <div class="hud-block">
      <div class="hud-label">得分</div>
      <div class="hud-score" id="g-score">0</div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <div style="font-size:10px;color:#8a6070;text-align:center">汐弥<br>加油！</div>
      <svg viewBox="0 0 50 50" width="42" height="42" xmlns="http://www.w3.org/2000/svg">
        <circle cx="25" cy="25" r="24" fill="#2a001a" stroke="#ff0080" stroke-width="1.5"/>
        <polygon points="12,22 19,8 26,22" fill="#ff6eb4"/>
        <polygon points="24,22 31,8 38,22" fill="#ff6eb4"/>
        <polygon points="14,21 19,10 24,21" fill="#ffb6d9"/>
        <polygon points="26,21 31,10 36,21" fill="#ffb6d9"/>
        <circle cx="25" cy="32" r="14" fill="#ffe4f0"/>
        <ellipse cx="20" cy="29" rx="3" ry="3.5" fill="#2a0015"/>
        <ellipse cx="30" cy="29" rx="3" ry="3.5" fill="#2a0015"/>
        <circle cx="21" cy="28" r="1" fill="#fff"/>
        <circle cx="31" cy="28" r="1" fill="#fff"/>
        <ellipse cx="17" cy="34" rx="3.5" ry="2" fill="#ffb6d9" opacity=".6"/>
        <ellipse cx="33" cy="34" rx="3.5" ry="2" fill="#ffb6d9" opacity=".6"/>
