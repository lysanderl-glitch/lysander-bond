<!-- 汐弥泡泡射击 v2.0 - Rewritten 2026-05-31 -->
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
  <title>汐弥泡泡射击</title>
  <style is:global>
    :root{--pk:#FF0080;--pks:#F4A0C0;--lav:#C8A0D4;--gold:#F0C840;--dark:#0a0010;--glow:rgba(255,0,128,0.5);}
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{width:100%;height:100%;overflow:hidden;background:var(--dark);}
    body{color:#fde8f0;font-family:'PingFang SC','Microsoft YaHei',sans-serif;user-select:none;touch-action:none;}
    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,0,128,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,0,128,0.05) 1px,transparent 1px);background-size:50px 50px;pointer-events:none;z-index:0;}

    .screen{display:none;position:fixed;inset:0;flex-direction:column;align-items:center;justify-content:center;z-index:10;}
    .screen.active{display:flex;animation:fadeIn .35s ease both;}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}

    /* TITLE */
    #screen-title{background:radial-gradient(ellipse at 50% 40%,rgba(255,0,128,0.15) 0%,transparent 70%);}
    .av-ring{width:120px;height:120px;border-radius:50%;border:3px solid var(--pk);box-shadow:0 0 24px var(--glow),0 0 50px var(--glow);overflow:hidden;margin-bottom:14px;animation:float 3s ease-in-out infinite;}
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
    .t-main{font-size:24px;font-weight:700;letter-spacing:3px;color:#fff;text-shadow:0 0 20px var(--glow);margin-bottom:4px;}
    .t-sub{font-size:12px;color:var(--pks);letter-spacing:2px;margin-bottom:22px;}
    .btn{padding:10px 28px;border:1.5px solid var(--pk);background:rgba(255,0,128,0.12);color:#fff;font-size:14px;letter-spacing:2px;cursor:pointer;border-radius:6px;font-family:inherit;transition:.2s;}
    .btn:hover,.btn:active{background:rgba(255,0,128,0.3);}
    .btn-row{display:flex;gap:12px;}
    .badge-row{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:18px;}
    .badge{padding:3px 10px;border-radius:20px;font-size:11px;border:1px solid rgba(255,0,128,0.3);background:rgba(255,0,128,0.08);color:var(--pks);}

    /* GAME */
    #screen-game{padding:0;justify-content:flex-start;}
    .hud{width:100%;padding:8px 14px 6px;background:rgba(10,0,16,0.92);border-bottom:1px solid rgba(255,0,128,0.2);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;z-index:20;position:relative;}
    .hud-block{display:flex;flex-direction:column;align-items:center;}
    .hud-label{font-size:10px;color:#8a6070;letter-spacing:1px;margin-bottom:2px;}
    .hud-score{font-size:22px;font-weight:700;color:#fff;text-shadow:0 0 10px var(--glow);}
    .hud-timer{font-size:22px;font-weight:700;color:#fff;}
    .hud-timer.urgent{color:#ff2255;animation:blink .5s infinite;}
    @keyframes blink{50%{opacity:.5}}
    .next-bubble{width:38px;height:38px;border-radius:50%;border:2px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;font-size:18px;}
    #game-area{flex:1;width:100%;position:relative;overflow:hidden;}
    #game-canvas{display:block;cursor:crosshair;}

    /* SHOOTER */
    .shooter-label{position:absolute;bottom:8px;left:50%;transform:translateX(-50%);font-size:12px;color:var(--pks);letter-spacing:2px;text-shadow:0 0 8px var(--glow);pointer-events:none;white-space:nowrap;}

    /* GIFT NOTIFICATION */
    .gift-notif{position:fixed;right:-280px;top:35%;transform:translateY(-50%);z-index:200;pointer-events:none;
      background:linear-gradient(135deg,rgba(18,0,28,0.97),rgba(30,0,50,0.97));
      border:1px solid;border-radius:12px 0 0 12px;padding:12px 18px 12px 14px;
      display:flex;align-items:center;gap:10px;min-width:190px;
      transition:right .5s cubic-bezier(.23,1,.32,1);}
    .gift-notif.show{right:0;}
    .gift-notif-icon{font-size:32px;animation:float 1s ease-in-out infinite;}
    .gift-notif-name{font-size:14px;font-weight:700;letter-spacing:2px;}
    .gift-notif-sub{font-size:10px;opacity:.7;margin-top:1px;}

    /* END */
    #screen-end{background:radial-gradient(ellipse at 50% 50%,rgba(255,0,128,0.12) 0%,transparent 70%);}
    .end-box{background:rgba(12,0,20,0.95);border:1px solid rgba(255,0,128,0.35);border-radius:16px;padding:28px 24px;text-align:center;max-width:320px;width:90%;}
    .end-score{font-size:60px;font-weight:700;color:var(--pk);text-shadow:0 0 30px var(--glow);line-height:1;}
    .end-label{font-size:10px;letter-spacing:3px;color:#8a6070;margin-bottom:4px;}
    .end-title{font-size:17px;color:#fff;margin:10px 0 3px;letter-spacing:2px;}
    .end-sub{font-size:12px;color:var(--pks);margin-bottom:20px;}
    .gifts-earned{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:18px;}
    .gift-chip{padding:5px 12px;border-radius:20px;font-size:12px;border:1px solid;letter-spacing:1px;}
    .particle{position:absolute;pointer-events:none;border-radius:50%;z-index:30;}
  </style>
</head>
<body>

<!-- TITLE SCREEN -->
<div id="screen-title" class="screen active">
  <div style="position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;padding:20px;">
    <div class="av-ring">
      <svg viewBox="0 0 130 130" xmlns="http://www.w3.org/2000/svg" width="130" height="130">
        <defs><radialGradient id="bg1" cx="50%" cy="60%"><stop offset="0%" stop-color="#ff6eb4"/><stop offset="100%" stop-color="#8b0057"/></radialGradient></defs>
        <rect width="130" height="130" fill="url(#bg1)"/>
        <polygon points="22,52 36,14 50,52" fill="#ff6eb4"/>
        <polygon points="27,50 36,20 45,50" fill="#ffb6d9"/>
        <polygon points="80,52 94,14 108,52" fill="#ff6eb4"/>
        <polygon points="85,50 94,20 103,50" fill="#ffb6d9"/>
        <circle cx="65" cy="78" r="40" fill="#ffe4f0"/>
