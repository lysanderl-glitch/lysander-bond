<script is:inline>
// ═══ BG PARTICLES ═══
(function(){
  const c=document.getElementById('bg-canvas');
  if(!c)return;
  const ctx=c.getContext('2d');
  let W,H,pts=[];
  function rsz(){W=c.width=window.innerWidth;H=c.height=window.innerHeight;}
  rsz();window.addEventListener('resize',rsz);
  const SYM=['✦','♡','✧','·','★','°','🌸'];
  function mk(){return{x:Math.random()*W,y:H+10,sz:8+Math.random()*12,sp:0.25+Math.random()*0.5,op:0.06+Math.random()*0.2,sym:SYM[Math.floor(Math.random()*SYM.length)],hue:Math.random()<0.6?330:Math.random()<0.5?280:50,dx:(Math.random()-.5)*.3,wb:Math.random()*Math.PI*2,ws:0.01+Math.random()*.02};}
  for(let i=0;i<35;i++){const p=mk();p.y=Math.random()*H;pts.push(p);}
  function draw(){
    ctx.clearRect(0,0,W,H);
    pts.forEach((p,i)=>{
      p.y-=p.sp;p.wb+=p.ws;p.x+=p.dx+Math.sin(p.wb)*.2;
      ctx.save();ctx.globalAlpha=p.op;ctx.fillStyle=`hsl(${p.hue},80%,70%)`;ctx.font=`${p.sz}px serif`;ctx.textAlign='center';ctx.fillText(p.sym,p.x,p.y);ctx.restore();
      if(p.y<-20)pts[i]=mk();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

// ═══ BUBBLE TYPES ═══
const TYPES=[
  {id:0,emoji:'🍭',name:'棒棒糖',color:'#ff69b4',dark:'#cc1468',glow:'rgba(255,105,180,.7)'},
  {id:1,emoji:'💖',name:'爱心',  color:'#ff2255',dark:'#990022',glow:'rgba(255,34,85,.7)'},
  {id:2,emoji:'🌸',name:'小花花',color:'#ffb7c5',dark:'#cc6080',glow:'rgba(255,183,197,.7)'},
  {id:3,emoji:'⭐',name:'星星',  color:'#ffd700',dark:'#cc9900',glow:'rgba(255,215,0,.7)'},
  {id:4,emoji:'🎁',name:'礼物',  color:'#b86eff',dark:'#7733cc',glow:'rgba(184,110,255,.7)'},
  {id:5,emoji:'🌈',name:'彩虹糖',color:'#00d4e8',dark:'#007a88',glow:'rgba(0,212,232,.7)'},
];
const NT=TYPES.length;

// ═══ GAME STATE ═══
let canvas,ctx,W,H;
let R; // bubble radius
let COLS,ROWS_VISIBLE;
let grid=[];       // grid[row][col] = typeId or -1
let flyBubble=null;// {x,y,dx,dy,typeId}
let curType,nextType;
let score=0;
let aimX=0,aimY=0,aiming=false;
let giftsShown=new Set();
let gameActive=false;

// Grid geometry helpers
function colX(col,row){
  const offset=(row%2===1)?R:0;
  return offset + col*(2*R) + R;
}
function rowY(row){
  return row * (R*1.73) + R + 4;
}
function nearestCell(x,y){
  let bestR=-1,bestC=-1,bestD=Infinity;
  for(let r=0;r<grid.length+1&&r<ROWS_VISIBLE+2;r++){
    const cols=r%2===0?COLS:COLS-1;
    for(let c=0;c<cols;c++){
      const cx=colX(c,r),cy=rowY(r);
      const d=(x-cx)**2+(y-cy)**2;
      if(d<bestD){bestD=d;bestR=r;bestC=c;}
    }
  }
  return{r:bestR,c:bestC};
}

function initGrid(){
  R=Math.min(22,Math.floor(W/20));
  COLS=Math.floor(W/(2*R));
  ROWS_VISIBLE=Math.floor(H*0.65/(R*1.73));
  grid=[];
  const initRows=Math.min(6,ROWS_VISIBLE);
  for(let r=0;r<initRows;r++){
    const cols=r%2===0?COLS:COLS-1;
    const row=[];
    for(let c=0;c<cols;c++){
      row.push(Math.floor(Math.random()*NT));
    }
    grid.push(row);
  }
}

function randType(){return Math.floor(Math.random()*NT);}
function newBubble(){
  curType=nextType!==undefined?nextType:randType();
  nextType=randType();
  const nb=document.getElementById('g-next');
  if(nb){nb.textContent=TYPES[nextType].emoji;nb.style.background=TYPES[nextType].color+'33';nb.style.borderColor=TYPES[nextType].color;}
}

// ═══ DRAW ═══
function drawBubble(x,y,typeId,alpha,scale){
  if(typeId<0)return;
  const t=TYPES[typeId];
  alpha=alpha||1;scale=scale||1;
  ctx.save();
  ctx.globalAlpha=alpha;
  ctx.translate(x,y);
  ctx.scale(scale,scale);
  // glow
  ctx.shadowColor=t.glow;
  ctx.shadowBlur=8;
  // gradient circle
  const g=ctx.createRadialGradient(-R*.3,-R*.3,R*.1,0,0,R*.95);
  g.addColorStop(0,'#fff');
  g.addColorStop(0.3,t.color);
  g.addColorStop(1,t.dark);
  ctx.beginPath();
  ctx.arc(0,0,R*.92,0,Math.PI*2);
  ctx.fillStyle=g;
  ctx.fill();
  ctx.shadowBlur=0;
  // emoji
  ctx.font=`${R*.9}px serif`;
  ctx.textAlign='center';
  ctx.textBaseline='middle';
  ctx.fillText(t.emoji,0,R*.05);
  ctx.restore();
}

function drawShooter(){
  const sx=W/2, sy=H-R*2.5;
  // Arrow pointing up toward aim
  if(aiming){
    ctx.save();
    ctx.strokeStyle='rgba(255,0,128,0.5)';
    ctx.lineWidth=2;
    ctx.setLineDash([6,8]);
    // Draw trajectory with wall bounces
    let tx=sx,ty=sy,tdx=(aimX-sx),tdy=(aimY-sy);
    const len=Math.sqrt(tdx*tdx+tdy*tdy);
    if(len>0){tdx/=len;tdy/=len;}
    ctx.beginPath();ctx.moveTo(tx,ty);
    for(let i=0;i<200;i++){
      tx+=tdx*8;ty+=tdy*8;
      if(tx<R){tx=R;tdx*=-1;}
      if(tx>W-R){tx=W-R;tdx*=-1;}
      if(ty<0)break;
      ctx.lineTo(tx,ty);
    }
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();
  }
  // Shooter platform
  ctx.save();
  const grad=ctx.createLinearGradient(sx-30,sy-10,sx+30,sy+10);
  grad.addColorStop(0,'rgba(255,0,128,0.3)');
  grad.addColorStop(1,'rgba(200,160,212,0.3)');
  ctx.fillStyle=grad;
  ctx.beginPath();
  ctx.ellipse(sx,sy+R,R*1.8,R*.6,0,0,Math.PI*2);
  ctx.fill();
  ctx.restore();
  // Current bubble
  if(!flyBubble)drawBubble(sx,sy,curType,1,1);
}

function drawGrid(){
  for(let r=0;r<grid.length;r++){
    for(let c=0;c<grid[r].length;c++){
      if(grid[r][c]>=0){
        drawBubble(colX(c,r),rowY(r),grid[r][c]);
      }
    }
  }
}

function drawFly(){
  if(!flyBubble)return;
  drawBubble(flyBubble.x,flyBubble.y,flyBubble.typeId,1,1);
}

function drawDangerLine(){
  const dangerY=H*0.72;
  ctx.save();
  ctx.strokeStyle='rgba(255,0,80,0.25)';
  ctx.lineWidth=1.5;
  ctx.setLineDash([8,6]);
  ctx.beginPath();ctx.moveTo(0,dangerY);ctx.lineTo(W,dangerY);ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
}

function render(){
  ctx.clearRect(0,0,W,H);
  drawDangerLine();
  drawGrid();
  drawShooter();
  drawFly();
}

// ═══ PHYSICS ═══
let raf=null;
function gameLoop(){
  if(!gameActive)return;
  if(flyBubble){
    flyBubble.x+=flyBubble.dx;
    flyBubble.y+=flyBubble.dy;
    if(flyBubble.x<R){flyBubble.x=R;flyBubble.dx*=-1;}
    if(flyBubble.x>W-R){flyBubble.x=W-R;flyBubble.dx*=-1;}
    // Check collision with grid bubbles
    let hit=false;
    for(let r=0;r<grid.length&&!hit;r++){
      for(let c=0;c<grid[r].length&&!hit;c++){
        if(grid[r][c]<0)continue;
        const cx=colX(c,r),cy=rowY(r);
        const d=Math.sqrt((flyBubble.x-cx)**2+(flyBubble.y-cy)**2);
        if(d<R*1.85){hit=true;}
      }
    }
    // Hit top wall
    if(flyBubble.y<=R)hit=true;
    if(hit)landBubble();
  }
  render();
  raf=requestAnimationFrame(gameLoop);
}

function landBubble(){
  if(!flyBubble)return;
  const {r,c}=nearestCell(flyBubble.x,flyBubble.y);
  // Ensure grid rows exist
  while(grid.length<=r)grid.push(new Array(r%2===0?COLS:COLS-1).fill(-1));
  // Check bounds
  const maxC=r%2===0?COLS:COLS-1;
  const cc=Math.max(0,Math.min(c,maxC-1));
  // If cell occupied, try adjacent
  const placed=placeNear(r,cc,flyBubble.typeId);
  flyBubble=null;
  if(placed){
    const {pr,pc}=placed;
    checkMatches(pr,pc);
    checkGameOver();
  }
  newBubble();
}

function placeNear(r,c,typeId){
  // Try the target cell and neighbors
  const candidates=[[r,c],[r,c-1],[r,c+1],[r-1,c],[r+1,c]];
  for(const [tr,tc] of candidates){
    if(tr<0)continue;
    const maxC=tr%2===0?COLS:COLS-1;
    if(tc<0||tc>=maxC)continue;
    while(grid.length<=tr)grid.push(new Array(tr%2===0?COLS:COLS-1).fill(-1));
    if(grid[tr][tc]===-1){
      grid[tr][tc]=typeId;
      return{pr:tr,pc:tc};
    }
  }
  // Fallback: add to grid at top
  if(grid.length>0&&grid[0].length>0){
    for(let c2=0;c2<grid[0].length;c2++){
      if(grid[0][c2]===-1){grid[0][c2]=typeId;return{pr:0,pc:c2};}
    }
  }
  return null;
}

// ═══ MATCH LOGIC ═══
function getNeighbors(r,c){
  const nbrs=[];
  // neighbors depend on even/odd row
  const even=r%2===0;
  const candidates=[
    [r,c-1],[r,c+1],
    [r-1,even?c-1:c],[r-1,even?c:c+1],
    [r+1,even?c-1:c],[r+1,even?c:c+1],
  ];
  for(const[nr,nc] of candidates){
    if(nr<0||nr>=grid.length)continue;
    const maxC=nr%2===0?COLS:COLS-1;
    if(nc<0||nc>=maxC)continue;
    nbrs.push([nr,nc]);
  }
  return nbrs;
}

function bfs(startR,startC,matchType){
  const visited=new Set();
  const queue=[[startR,startC]];
  visited.add(`${startR},${startC}`);
  while(queue.length){
    const[r,c]=queue.shift();
    for(const[nr,nc] of getNeighbors(r,c)){
      const key=`${nr},${nc}`;
      if(visited.has(key))continue;
      if(nr<grid.length&&nc<grid[nr].length&&grid[nr][nc]===matchType){
        visited.add(key);
        queue.push([nr,nc]);
      }
    }
  }
  return [...visited].map(k=>k.split(',').map(Number));
}

function checkMatches(r,c){
  if(r>=grid.length||c>=grid[r].length||grid[r][c]<0)return;
  const typeId=grid[r][c];
  const matched=bfs(r,c,typeId);
  if(matched.length>=3){
    matched.forEach(([mr,mc])=>{
      spawnParticles(colX(mc,mr),rowY(mr),typeId);
      grid[mr][mc]=-1;
    });
    const pts=matched.length*10+(matched.length>3?(matched.length-3)*5:0);
    addScore(pts);
    removeFloaters();
  }
}

function removeFloaters(){
  // Find all bubbles connected to row 0
  const connected=new Set();
  const queue=[];
  for(let c=0;c<(grid[0]?grid[0].length:0);c++){
    if(grid[0][c]>=0){connected.add(`0,${c}`);queue.push([0,c]);}
  }
  while(queue.length){
    const[r,c]=queue.shift();
    for(const[nr,nc] of getNeighbors(r,c)){
      const key=`${nr},${nc}`;
      if(connected.has(key))continue;
      if(nr<grid.length&&nc<(grid[nr]?grid[nr].length:0)&&grid[nr][nc]>=0){
        connected.add(key);
        queue.push([nr,nc]);
      }
    }
  }
  // Remove unconnected
  let bonus=0;
  for(let r=0;r<grid.length;r++){
    for(let c=0;c<grid[r].length;c++){
      if(grid[r][c]>=0&&!connected.has(`${r},${c}`)){
        spawnParticles(colX(c,r),rowY(r),grid[r][c]);
        grid[r][c]=-1;
        bonus+=5;
      }
    }
  }
  if(bonus>0)addScore(bonus);
}

function checkGameOver(){
  const dangerRow=Math.floor(H*0.72/(R*1.73));
  for(let r=dangerRow;r<grid.length;r++){
    for(let c=0;c<grid[r].length;c++){
      if(grid[r][c]>=0){endGame();return;}
    }
  }
  // Check if all cleared
  let any=false;
  for(let r=0;r<grid.length;r++){
    if(grid[r].some(v=>v>=0)){any=true;break;}
  }
  if(!any){
    addScore(100);
    // Add new rows
    for(let r=0;r<3;r++){
      const cols=r%2===0?COLS:COLS-1;
      grid.unshift(Array.from({length:cols},()=>Math.floor(Math.random()*NT)));
    }
  }
}

// ═══ SCORE & GIFTS ═══
const GIFT_TIERS=[
  {threshold:100,emoji:'🎆',name:'烟花秀',color:'#ff6eb4',border:'#ff0080'},
  {threshold:150,emoji:'🏎️',name:'超级跑车',color:'#ffd700',border:'#cc9900'},
  {threshold:200,emoji:'🚀',name:'火箭',color:'#c8a0d4',border:'#9b59b6'},
  {threshold:250,emoji:'🏰',name:'梦幻城堡',color:'#ff0080',border:'#cc0066'},
];

function addScore(pts){
  score+=pts;
  const el=document.getElementById('g-score');
  if(el)el.textContent=score;
  // Check gift tiers
  for(const g of GIFT_TIERS){
    if(score>=g.threshold&&!giftsShown.has(g.threshold)){
      giftsShown.add(g.threshold);
      showGiftNotif(g);
    }
  }
}

let notifQueue=[],notifShowing=false;
function showGiftNotif(g){
  notifQueue.push(g);
  if(!notifShowing)processNotifQueue();
}
function processNotifQueue(){
  if(!notifQueue.length){notifShowing=false;return;}
  notifShowing=true;
  const g=notifQueue.shift();
  const el=document.createElement('div');
  el.className='gift-notif';
  el.style.borderColor=g.border;
  el.innerHTML=`<div class="gift-notif-icon">${g.emoji}</div><div class="gift-notif-text"><div class="gift-notif-name" style="color:${g.color}">${g.name}</div><div class="gift-notif-sub">汐弥收到了！× 1</div></div>`;
  document.body.appendChild(el);
  // Fireworks
  launchScreenFirework();
  setTimeout(()=>el.classList.add('show'),50);
  setTimeout(()=>{el.classList.remove('show');setTimeout(()=>{el.remove();processNotifQueue();},600);},3000);
}

function launchScreenFirework(){
  const wrap=document.getElementById('g-canvas-wrap');
  if(!wrap)return;
  const colors=['#ff0080','#ffd700','#ff6eb4','#c8a0d4','#00d4e8','#fff'];
  for(let f=0;f<3;f++){
    setTimeout(()=>{
      const fx=W*(.2+Math.random()*.6),fy=H*(.1+Math.random()*.4);
      for(let i=0;i<20;i++){
        const p=document.createElement('div');
        const angle=(i/20)*Math.PI*2,dist=50+Math.random()*60;
        const col=colors[Math.floor(Math.random()*colors.length)];
        const sz=4+Math.random()*5;
        p.className='particle';
        p.style.cssText=`width:${sz}px;height:${sz}px;background:${col};left:${fx}px;top:${fy}px;box-shadow:0 0 6px ${col};transition:all .7s ease;opacity:1;`;
        wrap.appendChild(p);
        requestAnimationFrame(()=>{
          p.style.left=(fx+Math.cos(angle)*dist)+'px';
          p.style.top=(fy+Math.sin(angle)*dist)+'px';
          p.style.opacity='0';
          p.style.transform='scale(0)';
        });
        setTimeout(()=>p.remove(),750);
      }
    },f*250);
  }
}

function spawnParticles(x,y,typeId){
  const wrap=document.getElementById('g-canvas-wrap');
  if(!wrap)return;
  const col=TYPES[typeId]?.color||'#ff0080';
  for(let i=0;i<8;i++){
    const p=document.createElement('div');
    const angle=(i/8)*Math.PI*2,dist=20+Math.random()*20;
    p.className='particle';
    p.style.cssText=`width:5px;height:5px;background:${col};left:${x}px;top:${y}px;box-shadow:0 0 4px ${col};transition:all .5s ease;opacity:1;`;
    wrap.appendChild(p);
    requestAnimationFrame(()=>{
      p.style.left=(x+Math.cos(angle)*dist)+'px';
      p.style.top=(y+Math.sin(angle)*dist)+'px';
      p.style.opacity='0';
    });
    setTimeout(()=>p.remove(),520);
  }
}

// ═══ INPUT ═══
function getCanvasXY(e){
  const rect=canvas.getBoundingClientRect();
  if(e.touches){
    return{x:e.touches[0].clientX-rect.left,y:e.touches[0].clientY-rect.top};
  }
  return{x:e.clientX-rect.left,y:e.clientY-rect.top};
}

function onPointerMove(e){
  if(!gameActive)return;
  const{x,y}=getCanvasXY(e);
  aimX=x;aimY=y;
  aiming=y<H-R*2;
}

function onPointerUp(e){
  if(!gameActive||flyBubble)return;
  const{x,y}=getCanvasXY(e);
  const sx=W/2,sy=H-R*2.5;
  const dx=x-sx,dy=y-sy;
  if(dy>-20)return; // must tap above shooter
  const len=Math.sqrt(dx*dx+dy*dy);
  if(len<5)return;
  const speed=8;
  flyBubble={x:sx,y:sy,dx:(dx/len)*speed,dy:(dy/len)*speed,typeId:curType};
  aiming=false;
}

// ═══ GAME CONTROL ═══
function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function startGame(){
  score=0;
  giftsShown=new Set();
  flyBubble=null;
  aiming=false;
  notifQueue=[];notifShowing=false;

  canvas=document.getElementById('g-canvas');
  const wrap=document.getElementById('g-canvas-wrap');
  W=wrap.clientWidth;
  H=wrap.clientHeight;
  canvas.width=W;canvas.height=H;
  ctx=canvas.getContext('2d');

  initGrid();
  nextType=randType();
  newBubble();

  document.getElementById('g-score').textContent='0';

  // Events
  canvas.onmousemove=onPointerMove;
  canvas.ontouchmove=(e)=>{e.preventDefault();onPointerMove(e);};
  canvas.onmouseup=onPointerUp;
  canvas.ontouchend=(e)=>{e.preventDefault();onPointerUp(e);};
  canvas.ontouchstart=(e)=>{e.preventDefault();const{x,y}=getCanvasXY(e);aimX=x;aimY=y;aiming=y<H-R*2;};

  show('sg');
  gameActive=true;
  if(raf)cancelAnimationFrame(raf);
  gameLoop();
}

function endGame(){
  gameActive=false;
  if(raf){cancelAnimationFrame(raf);raf=null;}
  document.getElementById('e-score').textContent=score;

  // Title and sub
  const titles=[
    [250,'传说！梦幻城堡已解锁','汐弥被你的礼物感动了 ✨'],
    [200,'太厉害了！火箭升空','满满的爱意送到主播啦 🚀'],
    [150,'超棒！超级跑车解锁','汐弥好开心！继续加油 🏎️'],
    [100,'不错！烟花秀解锁','汐弥收到你的礼物了 🎆'],
    [0,'加油！下次更好','汐弥依然爱你哦 💕'],
  ];
  const[,title,sub]=titles.find(([t])=>score>=t);
  document.getElementById('e-title').textContent=title;
  document.getElementById('e-sub').textContent=sub;

  // Gifts earned
  const giftsEl=document.getElementById('e-gifts');
  giftsEl.innerHTML='';
  for(const g of GIFT_TIERS){
    if(score>=g.threshold){
      const chip=document.createElement('div');
      chip.className='gift-chip';
      chip.style.cssText=`color:${g.color};border-color:${g.border};background:${g.border}22;`;
      chip.textContent=`${g.emoji} ${g.name}`;
      giftsEl.appendChild(chip);
    }
  }
  if(giftsEl.children.length===0){
    giftsEl.innerHTML='<div style="font-size:12px;color:#5a3050">继续努力解锁礼物！</div>';
  }

  show('se');
}

function goTitle(){
  gameActive=false;
  if(raf){cancelAnimationFrame(raf);raf=null;}
  show('st');
}

window.startGame=startGame;
window.goTitle=goTitle;
</script>
