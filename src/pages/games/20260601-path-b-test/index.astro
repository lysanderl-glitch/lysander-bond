<!-- Path B验证-记忆翻牌 v1.0 -->
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
  <title>记忆翻牌 · Path B验证</title>
  <style>
    :root{--pk:#FF0080;--pks:#F4A0C0;--lav:#C8A0D4;--dark:#0a0010;--dark2:#120018;--glow:rgba(255,0,128,0.5);}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--dark);color:#fde8f0;font-family:'PingFang SC','Microsoft YaHei',sans-serif;overflow:hidden;user-select:none;height:100vh;}
    @supports(height:100dvh){body{height:100dvh;}}

    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,0,128,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,0,128,0.05) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}
    body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.08) 2px,rgba(0,0,0,0.08) 4px);pointer-events:none;z-index:0;}

    .screen{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;padding:20px;z-index:10;}
    @supports(height:100dvh){.screen{height:100dvh;}}
    .screen.active{display:flex;animation:screenIn .5s ease both;}
    @keyframes screenIn{0%{opacity:0;filter:brightness(1.8) saturate(0);}100%{opacity:1;filter:brightness(1) saturate(1);}}

    .btn{padding:12px 36px;border:1.5px solid var(--pk);background:rgba(255,0,128,0.12);color:#fff;font-family:inherit;font-size:16px;letter-spacing:3px;cursor:pointer;border-radius:6px;transition:.2s;}
    .btn:hover,.btn:active{background:rgba(255,0,128,0.3);box-shadow:0 0 16px var(--glow);}

    /* TITLE SCREEN */
    #title-screen .icon{font-size:72px;margin-bottom:16px;animation:float 3s ease-in-out infinite;}
    @keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
    #title-screen h1{font-size:28px;font-weight:600;color:#fff;text-shadow:0 0 20px var(--glow);letter-spacing:6px;margin-bottom:8px;}
    #title-screen .sub{font-size:14px;color:var(--pks);letter-spacing:2px;margin-bottom:24px;}

    /* GAME SCREEN */
    #game-screen{padding:0;flex-direction:column;}
    .hud{flex-shrink:0;padding:12px 16px;background:rgba(10,0,16,0.9);border-bottom:1px solid rgba(255,0,128,0.25);z-index:20;display:flex;justify-content:space-between;align-items:center;width:100%;}
    .hud-item{text-align:center;}
    .hud-label{font-size:10px;color:#8a6070;letter-spacing:1px;text-transform:uppercase;}
    .hud-val{font-size:22px;font-weight:600;color:#fff;text-shadow:0 0 8px var(--glow);}

    .grid-wrap{flex:1;display:flex;align-items:center;justify-content:center;width:100%;padding:16px;}
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;width:100%;max-width:360px;aspect-ratio:1;}

    .card{position:relative;cursor:pointer;border-radius:10px;perspective:600px;-webkit-tap-highlight-color:transparent;}
    .card-inner{position:relative;width:100%;height:100%;transition:transform .4s ease;transform-style:preserve-3d;}
    .card.flipped .card-inner{transform:rotateY(180deg);}
    .card.matched .card-inner{transform:rotateY(180deg);}

    .card-face{position:absolute;inset:0;border-radius:10px;display:flex;align-items:center;justify-content:center;backface-visibility:hidden;-webkit-backface-visibility:hidden;}
    .card-front{background:linear-gradient(135deg,rgba(255,0,128,0.15),rgba(200,160,212,0.1));border:1.5px solid rgba(255,0,128,0.35);box-shadow:0 0 12px rgba(255,0,128,0.15);font-size:24px;color:var(--pk);}
    .card-front::after{content:'?';font-size:28px;font-weight:300;opacity:.6;}
    .card-back{background:linear-gradient(135deg,rgba(255,0,128,0.25),rgba(200,160,212,0.2));border:1.5px solid var(--pk);box-shadow:0 0 20px var(--glow);transform:rotateY(180deg);font-size:36px;}

    .card.matched{pointer-events:none;}
    .card.matched .card-back{border-color:var(--lav);box-shadow:0 0 20px rgba(200,160,212,0.5);animation:matchGlow .6s ease;}
    @keyframes matchGlow{0%{transform:rotateY(180deg) scale(1);}50%{transform:rotateY(180deg) scale(1.1);box-shadow:0 0 30px var(--glow);}100%{transform:rotateY(180deg) scale(1);}}

    /* END SCREEN */
    #end-screen .trophy{font-size:80px;margin-bottom:16px;animation:float 3s ease-in-out infinite;}
    #end-screen h1{font-size:26px;color:#fff;text-shadow:0 0 20px var(--glow);letter-spacing:4px;margin-bottom:8px;}
    #end-screen .stat{font-size:16px;color:var(--pks);margin-bottom:4px;}
    #end-screen .stat span{color:#fff;font-weight:600;font-size:20px;}
    #end-screen .btn{margin-top:20px;}

    /* particles */
    .particle{position:fixed;width:4px;height:4px;border-radius:50%;pointer-events:none;z-index:50;animation:particle-fly 1s ease forwards;}
    @keyframes particle-fly{0%{opacity:1;transform:translate(0,0) scale(1);}100%{opacity:0;transform:translate(var(--dx),var(--dy)) scale(0);}}
  </style>
</head>
<body>

  <!-- TITLE -->
  <div id="title-screen" class="screen active">
    <div class="icon">🃏</div>
    <h1>记忆翻牌</h1>
    <div class="sub">找到所有配对 · Path B验证</div>
    <button class="btn" id="btn-start">开始游戏</button>
  </div>

  <!-- GAME -->
  <div id="game-screen" class="screen">
    <div class="hud">
      <div class="hud-item"><div class="hud-label">翻牌</div><div class="hud-val" id="hud-flips">0</div></div>
      <div class="hud-item"><div class="hud-label">已配对</div><div class="hud-val" id="hud-pairs">0 / 8</div></div>
    </div>
    <div class="grid-wrap">
      <div class="grid" id="grid"></div>
    </div>
  </div>

  <!-- END -->
  <div id="end-screen" class="screen">
    <div class="trophy">🎉</div>
    <h1>恭喜通关！</h1>
    <div class="stat">总翻牌次数：<span id="end-flips">0</span></div>
    <div class="stat">配对完成：<span>8 / 8</span></div>
    <button class="btn" id="btn-restart">再来一局</button>
  </div>

  <script is:inline>
  document.addEventListener('DOMContentLoaded',()=>{
    const EMOJIS=['🌸','🌙','⚡','✨','💫','🌈','🎯','🎮'];
    let cards=[], flipped=[], locked=false, flips=0, pairs=0;

    const $=s=>document.querySelector(s);
    const show=id=>{document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));$(id).classList.add('active');};

    function shuffle(a){for(let i=a.length-1;i>0;i--){const j=Math.random()*i+1|0;[a[i],a[j]]=[a[j],a[i]];}return a;}

    function initGame(){
      flips=0;pairs=0;flipped=[];locked=false;
      $('#hud-flips').textContent='0';
      $('#hud-pairs').textContent='0 / 8';
      const deck=shuffle([...EMOJIS,...EMOJIS]);
      const grid=$('#grid');
      grid.innerHTML='';
      cards=[];
      deck.forEach((emoji,i)=>{
        const card=document.createElement('div');
        card.className='card';
        card.dataset.emoji=emoji;
        card.dataset.index=i;
        card.innerHTML=`<div class="card-inner"><div class="card-face card-front"></div><div class="card-face card-back">${emoji}</div></div>`;
        card.addEventListener('click',()=>flipCard(card));
        grid.appendChild(card);
        cards.push(card);
      });
      show('#game-screen');
    }

    function flipCard(card){
      if(locked||card.classList.contains('flipped')||card.classList.contains('matched'))return;
      card.classList.add('flipped');
      flipped.push(card);
      if(flipped.length===2){
        flips++;
        $('#hud-flips').textContent=flips;
        locked=true;
        const[a,b]=flipped;
        if(a.dataset.emoji===b.dataset.emoji){
          a.classList.add('matched');
          b.classList.add('matched');
          spawnParticles(a);
          spawnParticles(b);
          pairs++;
          $('#hud-pairs').textContent=pairs+' / 8';
          flipped=[];
          locked=false;
          if(pairs===8){setTimeout(endGame,600);}
        }else{
          setTimeout(()=>{a.classList.remove('flipped');b.classList.remove('flipped');flipped=[];locked=false;},800);
        }
      }
    }

    function spawnParticles(el){
      const rect=el.getBoundingClientRect();
      const cx=rect.left+rect.width/2, cy=rect.top+rect.height/2;
      for(let i=0;i<8;i++){
        const p=document.createElement('div');
        p.className='particle';
        const angle=Math.random()*Math.PI*2, dist=40+Math.random()*60;
        p.style.left=cx+'px';p.style.top=cy+'px';
        p.style.setProperty('--dx',Math.cos(angle)*dist+'px');
        p.style.setProperty('--dy',Math.sin(angle)*dist+'px');
        p.style.background=['#FF0080','#F4A0C0','#C8A0D4','#fff'][i%4];
        document.body.appendChild(p);
        setTimeout(()=>p.remove(),1000);
      }
    }

    function endGame(){
      $('#end-flips').textContent=flips;
      show('#end-screen');
    }

    $('#btn-start').addEventListener('click',initGame);
    $('#btn-restart').addEventListener('click',initGame);
  });
  </script>
</body>
</html>
