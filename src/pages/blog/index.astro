    <div class="space-y-6">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block p-6 bg-white/5 rounded-xl border border-white/10 hover:border-sky-500/50 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <time class="text-white/40 text-sm">{post.date}</time>
            <div class="flex gap-2">
              {post.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-sky-500/20 text-sky-400 rounded text-xs">{tag}</span>
              ))}
            </div>
          </div>
          <h2 class="text-xl font-semibold text-white group-hover:text-sky-400 transition-colors">
            {post.title}
          </h2>
          <p class="text-white/50 mt-2">{post.description}</p>
        </a>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700 text-center text-sm text-gray-500 dark:text-gray-400">
      如果你在构建 AI 工程团队，我们开源了 Synapse 框架 →
      <a href="https://github.com/lysanderl-glitch/synapse"
         class="text-blue-500 hover:text-blue-600 dark:text-blue-400 ml-1"
         target="_blank" rel="noopener noreferrer">
        synapse-core on GitHub
      </a>
    </div>
  </section>
</Layout>
