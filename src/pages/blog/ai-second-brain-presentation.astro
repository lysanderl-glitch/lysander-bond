---
import Layout from '../../layouts/Layout.astro';
---

<Layout title='如何用AI打造"第二大脑" - Claude Code实战分享 - Lysander' description='AI应用分享演示文稿：如何用Claude Code打造第二大脑，包含Software 2.0理念、Agent管家系统、自动决策机制'>
  <style>
    .presentation {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .slide {
      background: linear-gradient(180deg, #0d1117 0%, #161b22 100%);
      border-radius: 20px;
      padding: 50px 60px;
      margin: 40px auto;
      max-width: 1100px;
      border: 1px solid rgba(255,255,255,0.1);
      position: relative;
    }

    .slide-number {
      position: absolute;
      top: 20px;
      right: 30px;
      color: rgba(255,255,255,0.3);
      font-size: 14px;
    }

    .slide h2 {
      font-size: 2.2em;
      color: #00d9ff;
      margin-bottom: 35px;
      padding-bottom: 15px;
      border-bottom: 3px solid rgba(0,217,255,0.3);
    }

    .slide h3 {
      font-size: 1.4em;
      color: #00ff88;
      margin: 25px 0 15px;
    }

    .title-slide {
      text-align: center;
      padding: 80px 40px;
    }

    .title-slide h1 {
      font-size: 3.5em;
      background: linear-gradient(90deg, #00d9ff, #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 25px;
    }

    .title-slide .subtitle {
      font-size: 1.4em;
      color: rgba(255,255,255,0.7);
      margin-bottom: 50px;
    }

    .title-slide .meta {
      font-size: 1em;
      color: rgba(255,255,255,0.5);
    }

    .problem-box {
      background: rgba(255, 100, 100, 0.1);
      border: 1px solid rgba(255, 100, 100, 0.3);
      border-radius: 16px;
      padding: 35px 40px;
      text-align: center;
    }

    .problem-box .emoji {
      font-size: 3.5em;
      margin-bottom: 15px;
    }

    .problem-box h3 {
      font-size: 1.6em;
      color: #ff6b6b;
      margin-bottom: 15px;
    }

    .problem-box p {
      font-size: 1.1em;
      color: rgba(255,255,255,0.8);
      line-height: 1.8;
    }

    .flow-container {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .flow-item {
      background: rgba(0, 217, 255, 0.1);
      border: 1px solid rgba(0, 217, 255, 0.3);
      border-radius: 12px;
      padding: 25px 30px;
      text-align: center;
      min-width: 140px;
    }

    .flow-item .icon {
      font-size: 2.5em;
      margin-bottom: 10px;
    }

    .flow-item h4 {
      font-size: 1.1em;
      color: #00d9ff;
      margin-bottom: 8px;
    }

    .flow-item p {
      font-size: 0.9em;
      color: rgba(255,255,255,0.7);
    }

    .flow-arrow {
      font-size: 1.8em;
      color: rgba(0, 217, 255, 0.5);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 25px 0;
    }

    th {
      background: rgba(0, 217, 255, 0.15);
      color: #00d9ff;
      padding: 15px 20px;
      text-align: left;
      font-size: 1em;
    }

    td {
      padding: 15px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    tr:last-child td {
      border-bottom: none;
    }

    .old-way {
      color: rgba(255,255,255,0.5);
    }

    .new-way {
      color: #00ff88;
    }

    .arch-box {
      background: rgba(0, 255, 136, 0.05);
      border: 2px solid rgba(0, 255, 136, 0.3);
      border-radius: 16px;
      padding: 35px;
      text-align: center;
      margin-top: 25px;
    }

    .arch-box h3 {
      color: #00ff88;
      margin-bottom: 25px;
    }

    .arch-diagram {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .arch-node {
      background: linear-gradient(135deg, rgba(0, 217, 255, 0.2), rgba(0, 255, 136, 0.2));
      border: 1px solid rgba(0, 217, 255, 0.5);
      border-radius: 10px;
      padding: 15px 25px;
      font-size: 1em;
    }

    .arch-arrow {
      font-size: 1.5em;
      color: rgba(0, 255, 136, 0.6);
    }

    .category-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 15px;
      margin-top: 25px;
    }

    .category-card {
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 20px 15px;
      text-align: center;
    }

    .category-card .emoji {
      font-size: 2em;
      margin-bottom: 10px;
    }

    .category-card h4 {
      font-size: 1em;
      color: #00d9ff;
      margin-bottom: 8px;
    }

    .category-card p {
      font-size: 0.85em;
      color: rgba(255,255,255,0.6);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-top: 25px;
    }

    .stat-card {
      background: rgba(0, 217, 255, 0.1);
      border-radius: 12px;
      padding: 30px;
      text-align: center;
    }

    .stat-card.highlight {
      background: rgba(0, 255, 136, 0.12);
      border: 1px solid rgba(0, 255, 136, 0.3);
    }

    .stat-card .number {
      font-size: 3em;
      font-weight: bold;
      color: #00d9ff;
      display: block;
    }

    .stat-card.highlight .number {
      color: #00ff88;
    }

    .stat-card .label {
      font-size: 1em;
      color: rgba(255,255,255,0.7);
      margin-top: 8px;
    }

    .loop-box {
      background: rgba(0, 255, 136, 0.05);
      border: 2px dashed rgba(0, 255, 136, 0.4);
      border-radius: 16px;
      padding: 35px;
      margin-top: 25px;
    }

    .loop-title {
      font-size: 1.2em;
      color: #00ff88;
      text-align: center;
      margin-bottom: 25px;
    }

    .loop-steps {
      display: flex;
      justify-content: space-between;
      gap: 15px;
    }

    .loop-step {
      background: rgba(0, 217, 255, 0.15);
      border-radius: 10px;
      padding: 18px;
      text-align: center;
      flex: 1;
    }

    .loop-step .num {
      font-size: 1.8em;
      color: #00d9ff;
      font-weight: bold;
    }

    .loop-step .text {
      font-size: 0.9em;
      color: rgba(255,255,255,0.8);
      margin-top: 8px;
    }

    .agent-container {
      display: flex;
      gap: 30px;
      margin-top: 25px;
    }

    .butler-box {
      flex: 0 0 260px;
      background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 140, 0, 0.15));
      border: 2px solid rgba(255, 215, 0, 0.4);
      border-radius: 16px;
      padding: 25px;
      text-align: center;
    }

    .butler-box h4 {
      font-size: 1.3em;
      color: #ffd700;
      margin-bottom: 12px;
    }

    .butler-box .role {
      font-size: 2.5em;
      margin: 15px 0;
    }

    .butler-box p {
      font-size: 0.9em;
      color: rgba(255,255,255,0.7);
      line-height: 1.5;
    }

    .experts-grid {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      align-content: start;
    }

    .expert-card {
      background: rgba(0, 217, 255, 0.1);
      border: 1px solid rgba(0, 217, 255, 0.3);
      border-radius: 10px;
      padding: 18px;
      text-align: center;
    }

    .expert-card .icon {
      font-size: 1.8em;
      margin-bottom: 8px;
    }

    .expert-card h5 {
      font-size: 0.95em;
      color: #00d9ff;
    }

    .decision-levels {
      display: flex;
      gap: 20px;
      margin-top: 25px;
    }

    .level-card {
      flex: 1;
      border-radius: 14px;
      padding: 28px;
      text-align: center;
    }

    .level-card.l1 {
      background: rgba(0, 255, 136, 0.12);
      border: 1px solid rgba(0, 255, 136, 0.35);
    }

    .level-card.l2 {
      background: rgba(255, 215, 0, 0.12);
      border: 1px solid rgba(255, 215, 0, 0.35);
    }

    .level-card.l3 {
      background: rgba(255, 100, 100, 0.12);
      border: 1px solid rgba(255, 100, 100, 0.35);
    }

    .level-card .level {
      font-size: 2.2em;
      font-weight: bold;
    }

    .level-card.l1 .level { color: #00ff88; }
    .level-card.l2 .level { color: #ffd700; }
    .level-card.l3 .level { color: #ff6b6b; }

    .level-card h4 {
      font-size: 1.15em;
      margin: 10px 0;
    }

    .level-card.l1 h4 { color: #00ff88; }
    .level-card.l2 h4 { color: #ffd700; }
    .level-card.l3 h4 { color: #ff6b6b; }

    .level-card p {
      font-size: 0.95em;
      color: rgba(255,255,255,0.7);
      line-height: 1.5;
    }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 15px;
      margin-top: 25px;
    }

    .tool-card {
      background: rgba(255,255,255,0.05);
      border-radius: 12px;
      padding: 22px 15px;
      text-align: center;
    }

    .tool-card .logo {
      font-size: 2.5em;
      margin-bottom: 10px;
    }

    .tool-card h4 {
      font-size: 1em;
      color: #00d9ff;
      margin-bottom: 6px;
    }

    .tool-card p {
      font-size: 0.85em;
      color: rgba(255,255,255,0.6);
    }

    .effect-list {
      margin-top: 25px;
    }

    .effect-item {
      display: flex;
      align-items: center;
      gap: 20px;
      background: rgba(0, 255, 136, 0.1);
      border-left: 4px solid #00ff88;
      border-radius: 0 10px 10px 0;
      padding: 20px 25px;
      margin-bottom: 15px;
    }

    .effect-item .check {
      font-size: 1.8em;
      color: #00ff88;
    }

    .effect-item h4 {
      font-size: 1.2em;
      color: #00ff88;
      margin-bottom: 5px;
    }

    .effect-item p {
      font-size: 0.95em;
      color: rgba(255,255,255,0.7);
    }

    .end-slide {
      text-align: center;
      padding: 60px 40px;
    }

    .end-slide h2 {
      font-size: 2.8em;
      background: linear-gradient(90deg, #00d9ff, #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 30px;
      border: none;
      padding: 0;
    }

    .end-slide .quote {
      font-size: 1.5em;
      color: rgba(255,255,255,0.8);
      font-style: italic;
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .end-slide .links {
      margin-top: 50px;
      display: flex;
      justify-content: center;
      gap: 30px;
    }

    .end-slide .link {
      font-size: 1em;
      color: rgba(255,255,255,0.5);
    }

    @media (max-width: 768px) {
      .category-grid, .tools-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .stats-grid, .agent-container, .decision-levels, .loop-steps {
        flex-direction: column;
      }

      .flow-container {
        flex-direction: column;
      }

      .flow-arrow {
        transform: rotate(90deg);
      }
    }
  </style>

  <div class="presentation">
    <!-- Slide 1: 标题 -->
    <div class="slide title-slide">
      <span class="slide-number">1 / 13</span>
      <h1>如何用AI打造"第二大脑"</h1>
      <p class="subtitle">Claude Code对话知识提取实战</p>
      <p class="meta">Lysander | 2026.04</p>
    </div>

    <!-- Slide 2: 问题 -->
    <div class="slide">
      <span class="slide-number">2 / 13</span>
      <h2>我们面临的问题</h2>
      <div class="problem-box">
        <div class="emoji">💭</div>
        <h3>每天对话，知识流失</h3>
        <p>与Claude Code的对话中，蕴含着大量有价值的知识：<br>
        决策过程、问题解决方案、学习心得、项目经验<br>
        然而这些知识往往随着对话结束而流失</p>
      </div>
    </div>

    <!-- Slide 3: 解决方案 -->
    <div class="slide">
      <span class="slide-number">3 / 13</span>
      <h2>我们需要什么</h2>
      <div class="flow-container">
        <div class="flow-item">
          <div class="icon">💬</div>
          <h4>对话数据</h4>
          <p>Claude Code<br>全量对话记录</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-item">
          <div class="icon">🧠</div>
          <h4>知识提取</h4>
          <p>AI自动识别<br>高价值内容</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-item">
          <div class="icon">📚</div>
          <h4>自动分类</h4>
          <p>决策/概念/问题<br>学习/项目</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-item">
          <div class="icon">🔄</div>
          <h4>持续学习</h4>
          <p>形成闭环<br>不断优化</p>
        </div>
      </div>
    </div>

    <!-- Slide 4: Software 2.0 -->
    <div class="slide">
      <span class="slide-number">4 / 13</span>
      <h2>Software 2.0 理念</h2>
      <table>
        <tr>
          <th>维度</th>
          <th class="old-way">Software 1.0</th>
          <th class="new-way">Software 2.0</th>
        </tr>
        <tr>
          <td>标签管理</td>
          <td class="old-way">人工定义</td>
          <td class="new-way">AI从使用模式学习</td>
        </tr>
        <tr>
          <td>知识关联</td>
          <td class="old-way">手动建立</td>
          <td class="new-way">AI自动发现关联</td>
        </tr>
        <tr>
          <td>检索方式</td>
          <td class="old-way">关键词匹配</td>
          <td class="new-way">语义理解</td>
        </tr>
      </table>
    </div>

    <!-- Slide 5: 架构 -->
    <div class="slide">
      <span class="slide-number">5 / 13</span>
      <h2>系统架构</h2>
      <div class="arch-box">
        <h3>Claude Code 对话知识提取系统</h3>
        <div class="arch-diagram">
          <div class="arch-node">📥 对话数据</div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">🧠 知识提取</div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">📂 自动分类</div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">💾 Obsidian</div>
        </div>
        <p style="color: rgba(255,255,255,0.6); margin-top: 20px;">每天23:00自动执行，数据闭环运转</p>
      </div>
    </div>

    <!-- Slide 6: 知识分类 -->
    <div class="slide">
      <span class="slide-number">6 / 13</span>
      <h2>智能知识分类</h2>
      <div class="category-grid">
        <div class="category-card">
          <div class="emoji">✅</div>
          <h4>决策</h4>
          <p>批准、方案确定<br>"同意、执行"</p>
        </div>
        <div class="category-card">
          <div class="emoji">💡</div>
          <h4>概念</h4>
          <p>新知识、新方法<br>"Software 2.0"</p>
        </div>
        <div class="category-card">
          <div class="emoji">🔧</div>
          <h4>问题</h4>
          <p>遇到的问题<br>及解决方案</p>
        </div>
        <div class="category-card">
          <div class="emoji">📖</div>
          <h4>学习</h4>
          <p>新学到的东西<br>"理解、掌握"</p>
        </div>
        <div class="category-card">
          <div class="emoji">📁</div>
          <h4>项目</h4>
          <p>项目相关事项<br>"Butler、lysander"</p>
        </div>
      </div>
    </div>

    <!-- Slide 7: 统计数据 -->
    <div class="slide">
      <span class="slide-number">7 / 13</span>
      <h2>实施效果</h2>
      <div class="stats-grid">
        <div class="stat-card highlight">
          <span class="number">100%</span>
          <span class="label">对话覆盖率</span>
        </div>
        <div class="stat-card">
          <span class="number">526</span>
          <span class="label">单日高价值知识 (04-08)</span>
        </div>
        <div class="stat-card highlight">
          <span class="number">72</span>
          <span class="label">单日会话数</span>
        </div>
        <div class="stat-card">
          <span class="number">1272</span>
          <span class="label">单日消息数</span>
        </div>
      </div>
    </div>

    <!-- Slide 8: 自动化闭环 -->
    <div class="slide">
      <span class="slide-number">8 / 13</span>
      <h2>每日自动化闭环</h2>
      <div class="loop-box">
        <div class="loop-title">⏰ 每日23:00自动触发</div>
        <div class="loop-steps">
          <div class="loop-step">
            <div class="num">1</div>
            <div class="text">扫描全量<br>对话.jsonl</div>
          </div>
          <div class="loop-step">
            <div class="num">2</div>
            <div class="text">提取用户<br>意图和知识</div>
          </div>
          <div class="loop-step">
            <div class="num">3</div>
            <div class="text">分类存储<br>到OBS</div>
          </div>
          <div class="loop-step">
            <div class="num">4</div>
            <div class="text">AI持续学习<br>用户偏好</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 9: Agent管家 -->
    <div class="slide">
      <span class="slide-number">9 / 13</span>
      <h2>Agent 管家系统</h2>
      <div class="agent-container">
        <div class="butler-box">
          <h4>Butler Agent</h4>
          <div class="role">🎩</div>
          <p>担任调度协调角色<br>任务分配 / 决策判断<br>进度监控</p>
        </div>
        <div class="experts-grid">
          <div class="expert-card">
            <div class="icon">📝</div>
            <h5>微信运营专家</h5>
          </div>
          <div class="expert-card">
            <div class="icon">🌐</div>
            <h5>博客发布专家</h5>
          </div>
          <div class="expert-card">
            <div class="icon">💬</div>
            <h5>Slack通知专家</h5>
          </div>
          <div class="expert-card">
            <div class="icon">📊</div>
            <h5>n8n工作流专家</h5>
          </div>
        </div>
      </div>
    </div>

    <!-- Slide 10: 决策系统 -->
    <div class="slide">
      <span class="slide-number">10 / 13</span>
      <h2>自动决策机制</h2>
      <div class="decision-levels">
        <div class="level-card l1">
          <div class="level">L1</div>
          <h4>自动执行</h4>
          <p>例行操作<br>已验证流程<br><br>管家直接执行</p>
        </div>
        <div class="level-card l2">
          <div class="level">L2</div>
          <h4>管家审批</h4>
          <p>需要确认的方案<br>首次执行<br><br>审批后执行</p>
        </div>
        <div class="level-card l3">
          <div class="level">L3</div>
          <h4>上报用户</h4>
          <p>复杂/风险操作<br>不可逆操作<br><br>用户决策</p>
        </div>
      </div>
    </div>

    <!-- Slide 11: 工具链 -->
    <div class="slide">
      <span class="slide-number">11 / 13</span>
      <h2>工具链</h2>
      <div class="tools-grid">
        <div class="tool-card">
          <div class="logo">🤖</div>
          <h4>Claude Code</h4>
          <p>对话主体</p>
        </div>
        <div class="tool-card">
          <div class="logo">🐍</div>
          <h4>Python</h4>
          <p>对话解析</p>
        </div>
        <div class="tool-card">
          <div class="logo">📔</div>
          <h4>Obsidian</h4>
          <p>知识库存储</p>
        </div>
        <div class="tool-card">
          <div class="logo">🔄</div>
          <h4>n8n</h4>
          <p>自动化工作流</p>
        </div>
        <div class="tool-card">
          <div class="logo">🎩</div>
          <h4>Lysander</h4>
          <p>AI管理层</p>
        </div>
