---
import Layout from '../../layouts/Layout.astro';
---

<Layout title='AI应用实战分享 - Lysander' description='AI应用实战分享：构建我的AI工作与生活系统，包含cc-connect微信互联、个人日记体系、Harness Engineering、Agent管家系统、股票交易系统等'>
  <style>
    .sharing-page {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .section {
      background: linear-gradient(180deg, #0d1117 0%, #161b22 100%);
      border-radius: 20px;
      padding: 50px 60px;
      margin: 40px auto;
      max-width: 1100px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .section h2 {
      font-size: 2.2em;
      color: #00d9ff;
      margin-bottom: 35px;
      padding-bottom: 15px;
      border-bottom: 3px solid rgba(0,217,255,0.3);
    }

    .section h3 {
      font-size: 1.4em;
      color: #00ff88;
      margin: 30px 0 15px;
    }

    .section p {
      font-size: 1.1em;
      color: rgba(255,255,255,0.8);
      line-height: 1.8;
      margin-bottom: 15px;
    }

    .tag {
      display: inline-block;
      background: rgba(0,217,255,0.2);
      color: #00d9ff;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.9em;
      margin: 5px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      margin-top: 30px;
    }

    .card {
      background: rgba(255,255,255,0.05);
      border-radius: 16px;
      padding: 30px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .card.featured {
      background: rgba(0,255,136,0.1);
      border-color: rgba(0,255,136,0.3);
    }

    .card h4 {
      font-size: 1.3em;
      color: #00d9ff;
      margin-bottom: 15px;
    }

    .card.featured h4 { color: #00ff88; }

    .card .icon { font-size: 2.5em; margin-bottom: 15px; }

    .card ul { list-style: none; padding: 0; }

    .card li {
      padding: 8px 0;
      color: rgba(255,255,255,0.8);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .card li:last-child { border: none; }
    .card li::before { content: "→ "; color: #00d9ff; }

    .flow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      margin: 30px 0;
      flex-wrap: wrap;
    }

    .flow-node {
      background: rgba(0,217,255,0.15);
      border: 1px solid rgba(0,217,255,0.3);
      border-radius: 12px;
      padding: 18px 25px;
      text-align: center;
      min-width: 120px;
    }

    .flow-node .icon { font-size: 1.8em; margin-bottom: 8px; }
    .flow-node h5 { color: #00d9ff; margin-bottom: 5px; font-size: 1em; }
    .flow-node p { font-size: 0.85em; margin: 0; color: rgba(255,255,255,0.7); }

    .flow-arrow { font-size: 1.5em; color: rgba(0,217,255,0.5); }

    .stats-row {
      display: flex;
      gap: 15px;
      margin: 25px 0;
    }

    .stat-box {
      flex: 1;
      background: rgba(0,217,255,0.1);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
    }

    .stat-box.highlight {
      background: rgba(0,255,136,0.15);
      border: 1px solid rgba(0,255,136,0.3);
    }

    .stat-box .number {
      font-size: 1.8em;
      font-weight: bold;
      color: #00d9ff;
    }

    .stat-box.highlight .number { color: #00ff88; }
    .stat-box .label { color: rgba(255,255,255,0.7); margin-top: 5px; font-size: 0.9em; }

    .arch-diagram {
      background: rgba(0,255,136,0.05);
      border: 2px solid rgba(0,255,136,0.2);
      border-radius: 20px;
      padding: 35px;
      margin: 30px 0;
      text-align: center;
    }

    .arch-diagram h4 { color: #00ff88; margin-bottom: 20px; }

    .quote-box {
      background: linear-gradient(135deg, rgba(0,217,255,0.1), rgba(0,255,136,0.1));
      border-left: 4px solid #00ff88;
      padding: 25px 30px;
      margin: 25px 0;
      border-radius: 0 12px 12px 0;
    }

    .quote-box p {
      font-size: 1.1em;
      font-style: italic;
      color: rgba(255,255,255,0.9);
      margin: 0;
    }

    .team-org {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
      margin: 30px 0;
    }

    .team-level {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .team-node {
      background: rgba(0,217,255,0.1);
      border: 1px solid rgba(0,217,255,0.3);
      border-radius: 10px;
      padding: 12px 20px;
      text-align: center;
      min-width: 100px;
    }

    .team-node.main {
      background: rgba(255,215,0,0.15);
      border-color: rgba(255,215,0,0.4);
    }

    .team-node .name { color: #00d9ff; font-weight: bold; font-size: 0.95em; }
    .team-node.main .name { color: #ffd700; }
    .team-node .count { font-size: 0.8em; color: rgba(255,255,255,0.6); margin-top: 4px; }

    .title-section {
      text-align: center;
      padding: 60px 40px;
    }

    .title-section h1 {
      font-size: 3em;
      background: linear-gradient(90deg, #00d9ff, #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 20px;
    }

    .title-section .subtitle {
      font-size: 1.3em;
      color: rgba(255,255,255,0.7);
      margin-bottom: 30px;
    }

    .end-section {
      text-align: center;
      padding: 60px 40px;
    }

    .end-section h2 {
      font-size: 2.5em;
      background: linear-gradient(90deg, #00d9ff, #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      border: none;
      margin-bottom: 30px;
    }

    @media (max-width: 768px) {
      .section { padding: 35px 25px; margin: 25px 15px; }
      .title-section h1 { font-size: 2em; }
      .grid-2 { grid-template-columns: 1fr; }
      .stats-row { flex-direction: column; }
      .flow { flex-direction: column; }
      .flow-arrow { transform: rotate(90deg); }
    }
  </style>

  <div class="sharing-page">
    <!-- 标题 -->
    <div class="section title-section">
      <h1>AI应用实战分享</h1>
      <p class="subtitle">构建我的AI工作与生活系统</p>
      <div>
        <span class="tag">Claude Code</span>
        <span class="tag">n8n</span>
        <span class="tag">Multi-Agent</span>
        <span class="tag">自动化</span>
      </div>
      <p style="margin-top: 30px; color: rgba(255,255,255,0.5); font-size: 0.95em;">Lysander | 2026.04</p>
    </div>

    <!-- 今天分享什么 -->
    <div class="section">
      <h2>今天分享什么</h2>
      <div class="grid-2">
        <div class="card">
          <div class="icon">🎯</div>
          <h4>个人效率系统</h4>
          <ul>
            <li>cc-connect 微信互联</li>
            <li>个人日记体系</li>
            <li>Obsidian 第二大脑</li>
          </ul>
        </div>
        <div class="card featured">
          <div class="icon">🤖</div>
          <h4>AI自动化体系</h4>
          <ul>
            <li>Harness Engineering</li>
            <li>Agent 管家系统</li>
            <li>自主决策机制</li>
          </ul>
        </div>
        <div class="card">
          <div class="icon">📈</div>
          <h4>业务项目</h4>
          <ul>
            <li>股票交易系统</li>
            <li>自动化发布流水线</li>
            <li>团队协作架构</li>
          </ul>
        </div>
        <div class="card">
          <div class="icon">👥</div>
          <h4>AI团队管理</h4>
          <ul>
            <li>Graphify 智囊团</li>
            <li>多Agent协作</li>
            <li>知识管理体系</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 个人日记体系 -->
    <div class="section">
      <h2>个人日记体系</h2>
      <p>语音 / 图片 → 自动记录 → AI整理 → 知识沉淀</p>

      <div class="flow">
        <div class="flow-node">
          <div class="icon">🎤</div>
          <h5>语音输入</h5>
          <p>cc-connect 接收</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-node">
          <div class="icon">🔄</div>
          <h5>自动转换</h5>
          <p>Groq Whisper</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-node">
          <div class="icon">📝</div>
          <h5>记录到日记</h5>
          <p>daily_record.py</p>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-node">
          <div class="icon">🧠</div>
          <h5>Obsidian</h5>
          <p>知识沉淀</p>
        </div>
      </div>

      <div class="quote-box">
        <p>"语音已由 cc-connect + Groq Whisper 转为文字，自动记录为日记素材"</p>
      </div>
    </div>

    <!-- cc-connect -->
    <div class="section">
      <h2>cc-connect 微信互联</h2>
      <div class="grid-2">
        <div class="card">
          <h4>核心能力</h4>
          <ul>
            <li>接收微信消息和图片</li>
            <li>发送消息到微信</li>
            <li>Webhook 触发自动化</li>
            <li>与 n8n 集成</li>
          </ul>
        </div>
        <div class="card">
          <h4>应用场景</h4>
          <ul>
            <li>手机端随时发送内容</li>
            <li>图片自动存档</li>
            <li>微信通知推送</li>
            <li>多端消息同步</li>
          </ul>
        </div>
      </div>
      <div class="stats-row">
        <div class="stat-box">
          <div class="number">7x24</div>
          <div class="label">全天候接收</div>
        </div>
        <div class="stat-box">
          <div class="number">实时</div>
          <div class="label">消息同步</div>
        </div>
        <div class="stat-box highlight">
          <div class="number">Webhook</div>
          <div class="label">触发自动化</div>
        </div>
      </div>
    </div>

    <!-- Obsidian 第二大脑 -->
    <div class="section">
      <h2>Obsidian 第二大脑</h2>
      <div class="arch-diagram">
        <h4>知识管理架构</h4>
        <div class="flow">
          <div class="flow-node">
            <div class="icon">📥</div>
            <h5>对话数据</h5>
            <p>Claude Code</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">🧠</div>
            <h5>知识提取</h5>
            <p>AI 分类</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">📚</div>
            <h5>分类存储</h5>
            <p>决策/概念</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">🔍</div>
            <h5>语义检索</h5>
            <p>Software 2.0</p>
          </div>
        </div>
      </div>
      <h3>核心特点</h3>
      <div class="grid-2">
        <div class="card">
          <h4>Software 2.0 理念</h4>
          <p>AI从对话数据中自动学习隐式规则，不需要人工标注</p>
        </div>
        <div class="card">
          <h4>每日自动化</h4>
          <p>每天23:00自动执行，数据闭环运转</p>
        </div>
      </div>
    </div>

    <!-- Harness Engineering -->
    <div class="section">
      <h2>Harness Engineering</h2>
      <p>AI驱动的错误分析与自愈闭环系统</p>

      <div class="arch-diagram">
        <h4>系统架构</h4>
        <p style="color: rgba(255,255,255,0.8); margin: 15px 0;">错误发生 → Claude Code / Webhook → n8n Workflow → Python分析服务器 → Claude API</p>
        <div class="flow">
          <div class="flow-node">
            <div class="icon">🔍</div>
            <h5>错误分析</h5>
            <p>根因定位</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">💡</div>
            <h5>修复建议</h5>
            <p>置信度评估</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">🤖</div>
            <h5>自动执行</h5>
            <p>高置信度</p>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-node">
            <div class="icon">📢</div>
            <h5>Slack通知</h5>
            <p>低置信度</p>
          </div>
        </div>
      </div>

      <div class="stats-row">
        <div class="stat-box">
          <div class="number">≥90%</div>
          <div class="label">置信度自动执行</div>
        </div>
        <div class="stat-box">
          <div class="number">&lt;50%</div>
          <div class="label">需人工介入</div>
        </div>
        <div class="stat-box highlight">
          <div class="number">23:00</div>
          <div class="label">每日定时收集</div>
        </div>
      </div>
    </div>

    <!-- Agent 管家系统 -->
    <div class="section">
      <h2>Agent 管家系统</h2>
      <p>多Agent协作操作系统，实现任务自动调度与执行</p>

      <div class="grid-2" style="margin-top: 25px;">
        <div class="card featured">
          <div class="icon">🎩</div>
          <h4>Butler Agent</h4>
          <p style="color: rgba(255,255,255,0.7); font-size: 0.95em;">
            担任调度协调角色<br>
            任务分配 / 决策判断 / 进度监控
          </p>
        </div>
        <div class="card">
          <h4>专家 Agent 集群</h4>
          <ul>
            <li>📝 微信文章运营专家</li>
            <li>🌐 博客发布专家</li>
            <li>💬 Slack通知专家</li>
            <li>📊 n8n工作流专家</li>
          </ul>
        </div>
      </div>

      <h3 style="margin-top: 25px;">决策流程</h3>
      <div class="flow">
        <div class="flow-node"><h5>用户任务</h5></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><h5>Butler分析</h5><p>理解意图</p></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><h5>L1自动</h5><p>例行操作</p></div>
        <div class="flow-arrow">或</div>
        <div class="flow-node"><h5>L2审批</h5><p>管家判断</p></div>
        <div class="flow-arrow">或</div>
        <div class="flow-node"><h5>L3上报</h5><p>用户决策</p></div>
      </div>
    </div>

    <!-- 股票交易系统 -->
    <div class="section">
      <h2>股票交易系统</h2>
      <p>趋势智选 A股交易指导系统</p>

      <div class="grid-2" style="margin-top: 25px;">
        <div class="card">
          <h4>技术架构</h4>
          <ul>
            <li>FastAPI + Vue3</li>
            <li>Baostock API 数据源</li>
            <li>100万模拟资金</li>
            <li>多Agent协作</li>
          </ul>
        </div>
        <div class="card featured">
          <h4>交易策略</h4>
          <p style="color: rgba(255,255,255,0.8);">
            基于《炒股的智慧》<br>
            趋势跟随 + 止损纪律<br>
            仓位管理 + 分散投资
          </p>
        </div>
      </div>

      <h3>核心功能</h3>
      <div class="stats-row">
        <div class="stat-box"><div class="number">回测</div><div class="label">历史信号分析</div></div>
        <div class="stat-box"><div class="number">模拟交易</div><div class="label">100万资金</div></div>
        <div class="stat-box"><div class="number">自动化</div><div class="label">每日选股</div></div>
        <div class="stat-box highlight"><div class="number">7%</div><div class="label">动态止损</div></div>
      </div>
    </div>

    <!-- 团队架构 -->
    <div class="section">
      <h2>AI团队架构</h2>
      <p>全员AI团队，由 Lysander (CEO) 统一管理</p>

      <div class="team-org">
        <div class="team-level">
          <div class="team-node main">
            <div class="name">Lysander</div>
            <div class="count">CEO - 人类</div>
          </div>
        </div>
        <div class="flow-arrow" style="transform: rotate(90deg); font-size: 1.2em; color: rgba(255,255,255,0.3);">↓</div>
        <div class="team-level">
          <div class="team-node"><div class="name">Graphify</div><div class="count">智囊团 (4)</div></div>
          <div class="team-node"><div class="name">Butler</div><div class="count">管家 (7)</div></div>
          <div class="team-node"><div class="name">RD</div><div class="count">研发 (5)</div></div>
          <div class="team-node"><div class="name">OBS</div><div class="count">知识 (4)</div></div>
          <div class="team-node"><div class="name">Stock</div><div class="count">股票 (5)</div></div>
          <div class="team-node"><div class="name">Content</div><div class="count">内容 (4)</div></div>
        </div>
      </div>

      <div class="stats-row" style="margin-top: 30px;">
        <div class="stat-box highlight"><div class="number">29</div><div class="label">AI Agents 总数</div></div>
        <div class="stat-box"><div class="number">6</div><div class="label">专业团队</div></div>
        <div class="stat-box"><div class="number">1</div><div class="label">人类 CEO</div></div>
      </div>
    </div>

    <!-- Graphify 智囊团 -->
    <div class="section">
      <h2>Graphify 智囊团</h2>
      <p>第二大脑核心引擎，提供深度分析与洞察</p>

      <div class="arch-diagram">
        <h4>核心能力</h4>
        <div class="grid-2" style="margin-top: 20px;">
          <div class="card"><h4>🔮 战略分析师</h4><p>深度分析项目风险与机会</p></div>
          <div class="card"><h4>🔗 关联发现专家</h4><p>找到隐性知识连接</p></div>
          <div class="card"><h4>📈 趋势洞察师</h4><p>发现模式，预测未来</p></div>
          <div class="card"><h4>⚖️ 决策顾问</h4><p>量化利弊，给出建议</p></div>
        </div>
      </div>

      <div class="quote-box">
        <p>"你 → Graphify: '帮我分析这个项目有什么风险'<br>
        ↓<br>
        Graphify → 战略分析 + 关联发现 + 趋势洞察<br>
        ↓<br>
        你 ← Graphify: 完整分析报告 + 决策建议"</p>
      </div>
    </div>

    <!-- 自动化发布流水线 -->
    <div class="section">
      <h2>自动化发布流水线</h2>
      <p>博客 → 微信公众号全自动发布</p>

      <div class="flow" style="margin: 30px 0;">
        <div class="flow-node"><div class="icon">📝</div><h5>写文章</h5><p>本地 Markdown</p></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><div class="icon">🚀</div><h5>发布脚本</h5><p>harness-daily-publish</p></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><div class="icon">🌐</div><h5>Astro构建</h5><p>生成静态网站</p></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><div class="icon">🔄</div><h5>n8n</h5><p>Webhook</p></div>
        <div class="flow-arrow">→</div>
        <div class="flow-node"><div class="icon">📱</div><h5>微信草稿</h5><p>自动创建</p></div>
      </div>

      <div class="grid-2">
        <div class="card"><h4>定时任务</h4><ul><li>博客发布: 22:30 迪拜时间</li><li>微信草稿: 22:45 迪拜时间</li></ul></div>
        <div class="card"><h4>工具链</h4><ul><li>Markdown → Astro</li><li>n8n Workflow</li><li>微信公众号 API</li></ul></div>
      </div>
    </div>

    <!-- 核心成果 -->
    <div class="section">
      <h2>核心成果</h2>
      <div class="grid-2">
        <div class="card featured">
          <div class="icon">⚡</div>
