---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Synapse — AI Agent 团队协作运营体系 | Janus Digital">
  <!-- Hero: Dark section -->
  <section class="bg-[var(--color-dark)] text-white">
    <div class="max-w-5xl mx-auto px-6 pt-20 pb-16 text-center space-y-6">
      <p class="text-sm font-semibold tracking-widest text-[#FCAD2A] uppercase">Synapse by Janus Digital</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight">
        用 Harness Engineering<br />
        <span class="bg-gradient-to-r from-[#FCAD2A] to-[#028CDC] bg-clip-text text-transparent">构建可靠的 AI Agent 团队</span>
      </h1>
      <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
        Synapse 是经过真实企业验证的 AI 协作运营体系。<br>基于 2026 年 AI 工程新范式，帮助企业系统化管理 AI Agent 团队。
      </p>
      <div class="flex gap-4 justify-center pt-4">
        <a href="/services" class="px-8 py-3 bg-[#FCAD2A] text-[#0A1628] rounded-lg font-bold hover:opacity-90 transition-opacity text-sm">了解服务</a>
        <a href="/blog" class="px-8 py-3 border border-white/20 rounded-lg font-semibold hover:bg-white/5 transition-colors text-sm">阅读博客</a>
      </div>
    </div>
  </section>

  <!-- Formula: Light section -->
  <section class="max-w-5xl mx-auto px-6 py-14">
    <div class="bg-[#F7F8FA] border border-[var(--color-border)] rounded-2xl p-8 text-center">
      <p class="text-[var(--color-muted)] text-sm mb-2">Harness Engineering 核心公式</p>
      <p class="text-3xl font-bold text-[var(--color-text)]">Agent = Model + <span class="text-[#FCAD2A]">Harness</span></p>
      <p class="text-[var(--color-text-light)] mt-3 text-sm">模型人人可用。<strong class="text-[#013A7D]">Harness</strong>（环境、约束、反馈、组织）才是竞争壁垒。</p>
    </div>
  </section>

  <!-- Services: White with cards -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8 text-center">我们提供什么</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-6 bg-white rounded-xl border border-[var(--color-border)] hover:border-[#FCAD2A]/40 hover:shadow-lg transition-all">
        <div class="text-3xl font-black text-[#FCAD2A] opacity-30 mb-2">01</div>
        <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">Synapse Assessment</h3>
        <p class="text-[var(--color-text-light)] text-sm leading-relaxed">2天诊断评估，对标 Harness Engineering 行业标准，输出定制化落地路线图。</p>
      </div>
      <div class="p-6 bg-white rounded-xl border border-[var(--color-border)] hover:border-[#FCAD2A]/40 hover:shadow-lg transition-all">
        <div class="text-3xl font-black text-[#FCAD2A] opacity-30 mb-2">02</div>
        <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">Synapse Implementation</h3>
        <p class="text-[var(--color-text-light)] text-sm leading-relaxed">2-4周体系落地，包含执行链、决策体系、Agent团队、情报系统、HR审计全套交付。</p>
      </div>
      <div class="p-6 bg-white rounded-xl border border-[var(--color-border)] hover:border-[#FCAD2A]/40 hover:shadow-lg transition-all">
        <div class="text-3xl font-black text-[#FCAD2A] opacity-30 mb-2">03</div>
        <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">SCP 培训认证</h3>
        <p class="text-[var(--color-text-light)] text-sm leading-relaxed">Synapse Certified Practitioner — 8小时理论+实操，学员带走一套可运行的体系。</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-[#F7F8FA] py-14">
    <div class="max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center"><div class="text-4xl font-black text-[#013A7D]">10</div><div class="text-sm text-[var(--color-muted)] mt-1">专业团队</div></div>
      <div class="text-center"><div class="text-4xl font-black text-[#013A7D]">49</div><div class="text-sm text-[var(--color-muted)] mt-1">AI Agent</div></div>
      <div class="text-center"><div class="text-4xl font-black text-[#FCAD2A]">93.8</div><div class="text-sm text-[var(--color-muted)] mt-1">审计均分</div></div>
      <div class="text-center"><div class="text-4xl font-black text-[#028CDC]">24/7</div><div class="text-sm text-[var(--color-muted)] mt-1">自动运转</div></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="bg-[var(--color-dark)] rounded-2xl p-10 text-center">
      <h2 class="text-2xl font-bold text-white mb-3">准备好构建你的 AI 团队了吗？</h2>
      <p class="text-white/50 mb-6 text-sm">从评估诊断开始，2天了解你的 AI 管理现状和改进路径。</p>
      <a href="mailto:lysanderl@janusd.io?subject=Synapse%20咨询预约" class="inline-block px-8 py-3 bg-[#FCAD2A] text-[#0A1628] rounded-lg font-bold hover:opacity-90 transition-opacity text-sm">预约咨询</a>
    </div>
  </section>
</Layout>
