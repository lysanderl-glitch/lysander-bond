---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Synapse — AI Agent 团队协作运营体系">

  <!-- ════ Hero: Abstract gradient + geometric network ════ -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0A1628 0%, #0d1f3c 40%, #013A7D 100%); min-height: 520px;">
    <!-- Abstract synapse network SVG -->
    <svg class="absolute inset-0 w-full h-full opacity-20" viewBox="0 0 1200 600" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <circle cx="900" cy="200" r="3" fill="#FCAD2A"/><circle cx="1000" cy="300" r="2" fill="#028CDC"/><circle cx="800" cy="350" r="2.5" fill="#028CDC"/>
      <circle cx="950" cy="150" r="1.5" fill="#FCAD2A"/><circle cx="1050" cy="250" r="2" fill="#028CDC"/><circle cx="850" cy="100" r="1.5" fill="#FCAD2A"/>
      <circle cx="750" cy="250" r="2" fill="#028CDC"/><circle cx="1100" cy="180" r="1.5" fill="#FCAD2A"/><circle cx="700" cy="400" r="2" fill="#028CDC"/>
      <circle cx="980" cy="420" r="1.5" fill="#028CDC"/><circle cx="1080" cy="380" r="2" fill="#FCAD2A"/><circle cx="820" cy="480" r="1.5" fill="#028CDC"/>
      <line x1="900" y1="200" x2="1000" y2="300" stroke="#028CDC" stroke-width="0.5" opacity="0.6"/>
      <line x1="900" y1="200" x2="800" y2="350" stroke="#FCAD2A" stroke-width="0.5" opacity="0.4"/>
      <line x1="1000" y1="300" x2="1050" y2="250" stroke="#028CDC" stroke-width="0.5" opacity="0.5"/>
      <line x1="800" y1="350" x2="750" y2="250" stroke="#028CDC" stroke-width="0.5" opacity="0.4"/>
      <line x1="900" y1="200" x2="950" y2="150" stroke="#FCAD2A" stroke-width="0.5" opacity="0.5"/>
      <line x1="950" y1="150" x2="1100" y2="180" stroke="#FCAD2A" stroke-width="0.3" opacity="0.3"/>
      <line x1="1000" y1="300" x2="1080" y2="380" stroke="#FCAD2A" stroke-width="0.3" opacity="0.3"/>
      <line x1="800" y1="350" x2="700" y2="400" stroke="#028CDC" stroke-width="0.3" opacity="0.3"/>
      <line x1="1050" y1="250" x2="1100" y2="180" stroke="#028CDC" stroke-width="0.3" opacity="0.4"/>
      <line x1="700" y1="400" x2="820" y2="480" stroke="#028CDC" stroke-width="0.3" opacity="0.3"/>
      <line x1="980" y1="420" x2="1080" y2="380" stroke="#FCAD2A" stroke-width="0.3" opacity="0.3"/>
      <circle cx="900" cy="200" r="40" fill="#FCAD2A" opacity="0.03"/><circle cx="1000" cy="300" r="30" fill="#028CDC" opacity="0.04"/>
    </svg>

    <div class="max-w-5xl mx-auto px-6 pt-24 pb-20 relative z-10 text-white">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold tracking-widest text-[#FCAD2A] uppercase mb-6">Synapse Framework</p>
        <h1 class="text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.1] tracking-tight">
          构建可靠的<br>
          <span class="bg-gradient-to-r from-[#FCAD2A] to-[#028CDC] bg-clip-text text-transparent">AI 智能体团队</span>
        </h1>
        <p class="text-lg text-white/50 mt-6 leading-relaxed max-w-lg">
          基于 Harness Engineering 的 AI 协作运营体系。<br>10 个专业团队、44 个 Agent、24/7 自主运转。
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/services" class="px-7 py-3 bg-[#FCAD2A] text-[#0A1628] rounded-lg font-bold hover:opacity-90 transition-opacity text-sm">查看服务</a>
          <a href="/synapse" class="px-7 py-3 border border-[#FCAD2A]/40 bg-[#FCAD2A]/10 text-[#FCAD2A] rounded-lg font-semibold hover:bg-[#FCAD2A]/20 transition-colors text-sm">Synapse Forge →</a>
          <a href="/blog" class="px-7 py-3 border border-white/15 rounded-lg font-medium hover:bg-white/5 transition-colors text-sm text-white/70">阅读博客</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ Formula bar ════ -->
  <section class="border-b border-[var(--color-border)]">
    <div class="max-w-5xl mx-auto px-6 py-6 flex flex-col md:flex-row items-center justify-center gap-4 text-center">
      <p class="text-sm text-[var(--color-muted)]">Harness Engineering Core Principle</p>
      <p class="text-xl font-bold text-[var(--color-text)]">Agent = Model + <span class="text-[#FCAD2A]">Harness</span></p>
      <p class="text-sm text-[var(--color-muted)]">模型人人可用，Harness 才是壁垒</p>
    </div>
  </section>

  <!-- ════ Guides + Sensors ════ -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-[var(--color-text)]">Harness 的两大控制机制</h2>
      <p class="text-[var(--color-muted)] mt-2 text-sm">前馈引导 + 反馈检验，让 AI Agent 可靠运转</p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="p-6 bg-white rounded-xl border border-[var(--color-border)] card-glow" style="border-top: 2px solid #013A7D;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-md bg-[#013A7D]/8 flex items-center justify-center text-sm font-bold text-[#013A7D]">G</div>
          <h3 class="font-bold text-[var(--color-text)]">Guides — 前馈控制</h3>
        </div>
        <p class="text-[var(--color-text-light)] text-sm mb-4">在 AI 行动之前，引导它做正确的事</p>
        <div class="space-y-2.5 text-sm text-[var(--color-text-light)]">
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#013A7D] shrink-0"></span>CLAUDE.md — 角色、规则、流程配置</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#013A7D] shrink-0"></span>Decision Rules — 四级决策约束体系</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#013A7D] shrink-0"></span>Agent Profiles — 能力档案与路由规则</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#013A7D] shrink-0"></span>Team Dispatch — 强制派单制度</div>
        </div>
      </div>
      <div class="p-6 bg-white rounded-xl border border-[var(--color-border)] card-glow" style="border-top: 2px solid #028CDC;">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-md bg-[#028CDC]/8 flex items-center justify-center text-sm font-bold text-[#028CDC]">S</div>
          <h3 class="font-bold text-[var(--color-text)]">Sensors — 反馈控制</h3>
        </div>
        <p class="text-[var(--color-text-light)] text-sm mb-4">在 AI 行动之后，检查它是否做对了</p>
        <div class="space-y-2.5 text-sm text-[var(--color-text-light)]">
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#028CDC] shrink-0"></span>QA Auto Review — 四维度质量门禁</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#028CDC] shrink-0"></span>Chain Audit — 执行链完整性检查</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#028CDC] shrink-0"></span>Expert Panel — 多专家交叉评分</div>
          <div class="flex gap-2 items-center"><span class="w-1 h-1 rounded-full bg-[#028CDC] shrink-0"></span>HR Audit Engine — 全员能力定期评估</div>
        </div>
      </div>
    </div>
  </section>

  <div class="glow-line max-w-5xl mx-auto"></div>

  <!-- ════ Services ════ -->
  <section class="bg-[#F7F8FA] py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-[var(--color-text)]">服务</h2>
        <p class="text-[var(--color-muted)] mt-2 text-sm">从诊断到落地到持续进化</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group p-6 bg-white rounded-xl border border-[var(--color-border)] card-glow" style="border-top: 2px solid #FCAD2A;">
          <div class="text-xs font-bold text-[#FCAD2A] tracking-wider uppercase mb-3">Assessment</div>
          <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">Synapse Assessment</h3>
          <p class="text-[var(--color-text-light)] text-sm leading-relaxed mb-4">2天诊断评估，对标 Harness Engineering 行业标准，输出定制化路线图。</p>
          <p class="text-xs font-semibold text-[var(--color-muted)]">$5K — $10K · 2 Days</p>
        </div>
        <div class="group p-6 bg-white rounded-xl border border-[var(--color-border)] card-glow" style="border-top: 2px solid #028CDC;">
          <div class="text-xs font-bold text-[#028CDC] tracking-wider uppercase mb-3">Implementation</div>
          <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">Synapse Implementation</h3>
          <p class="text-[var(--color-text-light)] text-sm leading-relaxed mb-4">完整体系落地：执行链、决策体系、Agent 团队、情报系统、HR 审计。</p>
          <p class="text-xs font-semibold text-[var(--color-muted)]">$30K — $80K · 2—4 Weeks</p>
        </div>
        <div class="group p-6 bg-white rounded-xl border border-[var(--color-border)] card-glow" style="border-top: 2px solid #013A7D;">
          <div class="text-xs font-bold text-[#013A7D] tracking-wider uppercase mb-3">Certification</div>
          <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">SCP Training</h3>
          <p class="text-[var(--color-text-light)] text-sm leading-relaxed mb-4">8小时理论+实操，学员带走一套可运行的 AI Agent 运营体系。</p>
          <p class="text-xs font-semibold text-[var(--color-muted)]">$500 — $15K</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ Trust: Product preview + data ════ -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl font-bold text-[var(--color-text)]">真实数据，不只是概念</h2>
      <p class="text-[var(--color-muted)] mt-2 text-sm">来自 Synapse 体系真实运行环境的数据</p>
    </div>

    <!-- Browser window mockup showing operation.html -->
    <div class="mb-10 rounded-xl overflow-hidden border border-[var(--color-border)] shadow-lg">
      <div class="bg-[#f0f0f0] px-4 py-2.5 flex items-center gap-2 border-b border-[#e0e0e0]">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
        </div>
        <div class="flex-1 mx-4">
          <div class="bg-white rounded-md px-3 py-1 text-xs text-[#999] text-center">synapse-dashboard — Expert Review Panel · Score: 5.0/5.0</div>
        </div>
      </div>
      <div class="bg-[#0A1628] p-6 md:p-8">
        <div class="grid grid-cols-4 gap-3 mb-6">
          <div class="text-center p-3 bg-white/[0.04] rounded-lg border border-white/5">
            <div class="text-2xl font-black text-[#FCAD2A]">10</div>
            <div class="text-[10px] text-white/40 mt-1">Teams</div>
          </div>
          <div class="text-center p-3 bg-white/[0.04] rounded-lg border border-white/5">
            <div class="text-2xl font-black text-[#028CDC]">44</div>
            <div class="text-[10px] text-white/40 mt-1">Agents</div>
          </div>
          <div class="text-center p-3 bg-white/[0.04] rounded-lg border border-white/5">
            <div class="text-2xl font-black text-[#FCAD2A]">93.8</div>
            <div class="text-[10px] text-white/40 mt-1">Audit Score</div>
          </div>
          <div class="text-center p-3 bg-white/[0.04] rounded-lg border border-white/5">
            <div class="text-2xl font-black text-[#028CDC]">24/7</div>
            <div class="text-[10px] text-white/40 mt-1">Uptime</div>
          </div>
        </div>
        <div class="space-y-2">
          <div class="flex items-center gap-3 p-2.5 bg-white/[0.03] rounded-lg">
            <div class="w-6 h-6 rounded bg-[#FCAD2A]/20 flex items-center justify-center text-[10px] text-[#FCAD2A] font-bold">5</div>
            <div class="text-xs text-white/60">Strategist — 方案战略方向完全正确</div>
            <div class="ml-auto text-[10px] text-[#FCAD2A] font-mono">APPROVED</div>
          </div>
          <div class="flex items-center gap-3 p-2.5 bg-white/[0.03] rounded-lg">
            <div class="w-6 h-6 rounded bg-[#028CDC]/20 flex items-center justify-center text-[10px] text-[#028CDC] font-bold">5</div>
            <div class="text-xs text-white/60">Decision Advisor — 风险评估全面可控</div>
            <div class="ml-auto text-[10px] text-[#028CDC] font-mono">APPROVED</div>
          </div>
          <div class="flex items-center gap-3 p-2.5 bg-white/[0.03] rounded-lg">
            <div class="w-6 h-6 rounded bg-[#028CDC]/20 flex items-center justify-center text-[10px] text-[#028CDC] font-bold">5</div>
            <div class="text-xs text-white/60">Trend Watcher — 与行业趋势完全对齐</div>
            <div class="ml-auto text-[10px] text-[#028CDC] font-mono">APPROVED</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Quote -->
    <div class="bg-white border-l-3 border-[#FCAD2A] rounded-r-xl p-6 shadow-sm" style="border-left: 3px solid #FCAD2A;">
      <p class="text-[var(--color-text)] italic leading-relaxed">
        "从全员 64.1 分到 93.8 分，不合格从 11 人降到 0 — 不是换了更好的模型，是建立了 Harness。"
      </p>
      <p class="text-[var(--color-muted)] text-sm mt-2">— Synapse 体系实践数据</p>
    </div>
  </section>

  <div class="glow-line max-w-5xl mx-auto"></div>

  <!-- ════ Automation Pipeline ════ -->
  <section class="bg-[#F7F8FA] py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-[var(--color-text)]">全天候运行，无需人工触发</h2>
        <p class="text-[var(--color-muted)] mt-2 text-sm">总裁只在 Slack 上收到最终结果</p>
      </div>
      <div class="grid md:grid-cols-4 gap-4">
        <div class="group relative p-5 bg-white rounded-xl border border-[var(--color-border)] text-center card-glow">
          <div class="text-xs font-mono font-bold text-[#FCAD2A] mb-3">06:00</div>
          <h4 class="font-semibold text-[var(--color-text)] text-sm">任务恢复</h4>
          <p class="text-xs text-[var(--color-muted)] mt-2">检查未完成工作<br>自动续接执行</p>
          <div class="hidden md:block absolute -right-2 top-1/2 -translate-y-1/2 text-[var(--color-border)]">→</div>
        </div>
        <div class="group relative p-5 bg-white rounded-xl border border-[var(--color-border)] text-center card-glow">
          <div class="text-xs font-mono font-bold text-[#028CDC] mb-3">08:00</div>
          <h4 class="font-semibold text-[var(--color-text)] text-sm">情报采集</h4>
          <p class="text-xs text-[var(--color-muted)] mt-2">搜索 AI 前沿<br>筛选 3-5 条精华</p>
          <div class="hidden md:block absolute -right-2 top-1/2 -translate-y-1/2 text-[var(--color-border)]">→</div>
        </div>
        <div class="group relative p-5 bg-white rounded-xl border border-[var(--color-border)] text-center card-glow">
          <div class="text-xs font-mono font-bold text-[#013A7D] mb-3">10:00</div>
          <h4 class="font-semibold text-[var(--color-text)] text-sm">执行管线</h4>
          <p class="text-xs text-[var(--color-muted)] mt-2">评估 → 评审 → 执行<br>4 专家评分制</p>
          <div class="hidden md:block absolute -right-2 top-1/2 -translate-y-1/2 text-[var(--color-border)]">→</div>
        </div>
        <div class="group p-5 bg-white rounded-xl border border-[var(--color-border)] text-center card-glow">
          <div class="text-xs font-mono font-bold text-[#FCAD2A] mb-3">MON</div>
          <h4 class="font-semibold text-[var(--color-text)] text-sm">团队审计</h4>
          <p class="text-xs text-[var(--color-muted)] mt-2">全员质量评分<br>自动修复提升</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ CTA ════ -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="rounded-2xl p-10 text-center" style="background: linear-gradient(135deg, #0A1628 0%, #013A7D 100%);">
        <h2 class="text-2xl font-bold text-white mb-3">准备好构建你的 AI 团队了吗？</h2>
        <p class="text-white/40 mb-6 text-sm max-w-md mx-auto">从 2 天评估开始。理解你的 AI 管理成熟度，获取定制化的 Synapse 路线图。</p>
        <a href="mailto:lysanderl@janusd.io?subject=Synapse%20Inquiry" class="inline-block px-8 py-3 bg-[#FCAD2A] text-[#0A1628] rounded-lg font-bold hover:opacity-90 transition-opacity text-sm">立即联系</a>
      </div>
    </div>
  </section>
</Layout>
