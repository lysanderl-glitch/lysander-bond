---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  bordered?: boolean;
}
const { eyebrow, title, subtitle, bordered = false } = Astro.props;
---

<section class:list={[
  bordered ? 'border-y border-white/5 bg-white/2' : ''
]}>
  <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
    <div class="text-center mb-12 max-w-3xl mx-auto">
      {eyebrow && (
        <div class="text-[#FCAD2A] text-xs font-semibold tracking-wider uppercase mb-3">
          {eyebrow}
        </div>
      )}
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{title}</h2>
      {subtitle && (
        <p class="text-white/60 text-base md:text-lg leading-relaxed">{subtitle}</p>
      )}
    </div>
    <slot />
  </div>
</section>
