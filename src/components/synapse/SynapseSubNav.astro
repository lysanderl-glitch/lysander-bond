---
interface Props {
  active?: string;
  currentLang?: 'en' | 'zh';
}
const { active = '', currentLang = 'en' } = Astro.props;

const links = currentLang === 'zh'
  ? [
      { key: 'overview', label: '概览', href: '/synapse/' },
      { key: 'capabilities', label: '能力', href: '/synapse/capabilities' },
      { key: 'how-it-works', label: '工作原理', href: '/synapse/how-it-works' },
      { key: 'team', label: '团队', href: '/synapse/team' },
      { key: 'intelligence', label: '情报闭环', href: '/synapse/intelligence' },
      { key: 'get-started', label: '快速上手', href: '/synapse/get-started' },
    ]
  : [
      { key: 'overview', label: 'Overview', href: '/en/synapse/' },
      { key: 'capabilities', label: 'Capabilities', href: '/en/synapse/capabilities' },
      { key: 'how-it-works', label: 'How It Works', href: '/en/synapse/how-it-works' },
      { key: 'team', label: 'Team', href: '/en/synapse/team' },
      { key: 'intelligence', label: 'Intelligence', href: '/en/synapse/intelligence' },
      { key: 'get-started', label: 'Get Started', href: '/en/synapse/get-started' },
    ];
---

<style is:global>
  @import '../../styles/synapse.css';
</style>

<nav
  class="sticky z-40 border-b border-white/10 backdrop-blur-md"
  style="top: 64px; background: rgba(10,15,28,0.95);"
>
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-6 py-3 overflow-x-auto forge-subnav-scroll">
      {links.map((link) => {
        const isActive = link.key === active;
        return (
          <a
            href={link.href}
            class:list={[
              'whitespace-nowrap text-sm font-medium transition-colors pb-1',
              isActive
                ? 'forge-subnav-link-active'
                : 'text-white/60 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      {/*
        Language toggle removed from SynapseSubNav.
        It now lives globally in Layout.astro's Header (see <LangToggle />),
        so every page — Forge or not — exposes the same EN|中 switch.
      */}
    </div>
  </div>
</nav>
