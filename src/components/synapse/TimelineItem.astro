---
interface Props {
  step: number | string;
  title: string;
  body: string;
}
const { step, title, body } = Astro.props;
---

<div class="flex gap-5 items-start">
  <div class="forge-timeline-num">{step}</div>
  <div class="flex-1 pt-2">
    <h3 class="text-lg font-semibold text-white mb-2">{title}</h3>
    <p class="text-white/60 text-sm md:text-base leading-relaxed">{body}</p>
    <div class="mt-4">
      <slot />
    </div>
  </div>
</div>
