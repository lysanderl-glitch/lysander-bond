---
interface CTA {
  label: string;
  href: string;
  external?: boolean;
}
interface Props {
  tier: string;
  price: string;
  tagline: string;
  features: string[];
  cta: CTA;
  highlighted?: boolean;
}
const { tier, price, tagline, features, cta, highlighted = false } = Astro.props;
---

<div class:list={[
  'rounded-2xl p-8 flex flex-col h-full border transition-all',
  highlighted
    ? 'bg-gradient-to-b from-[#FCAD2A]/10 to-transparent border-[#FCAD2A]/50 shadow-xl shadow-[#FCAD2A]/10'
    : 'bg-gray-900/60 border-white/10 hover:border-white/20',
]}>
  {highlighted && (
    <div class="inline-block px-3 py-1 bg-[#FCAD2A] text-gray-900 text-xs font-bold rounded-full mb-4 self-start tracking-wider uppercase">
      Recommended
    </div>
  )}
  <h3 class="text-2xl font-bold text-white mb-2">{tier}</h3>
  <div class="text-3xl md:text-4xl font-extrabold text-[#FCAD2A] mb-2">{price}</div>
  <p class="text-white/60 text-sm mb-6">{tagline}</p>

  <ul class="space-y-3 mb-8 flex-1">
    {features.map((feature) => (
      <li class="flex items-start gap-3 text-white/70 text-sm leading-relaxed">
        <svg class="w-4 h-4 text-[#FCAD2A] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span>{feature}</span>
      </li>
    ))}
  </ul>

  <a
    href={cta.href}
    target={cta.external ? '_blank' : undefined}
    rel={cta.external ? 'noopener noreferrer' : undefined}
    class:list={[
      'block text-center px-6 py-3 font-semibold rounded-xl transition-all',
      highlighted
        ? 'bg-[#FCAD2A] text-gray-900 hover:bg-[#FCAD2A]/90'
        : 'bg-white/5 text-white border border-white/10 hover:bg-white/10',
    ]}
  >
    {cta.label}
  </a>
</div>
