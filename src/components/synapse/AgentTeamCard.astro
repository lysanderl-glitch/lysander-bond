---
interface Props {
  team: string;
  memberCount: number | string;
  description: string;
  members?: string[];
  accent?: 'amber' | 'sky' | 'purple';
}
const { team, memberCount, description, members = [], accent = 'amber' } = Astro.props;

const accentBar = {
  amber: 'text-[#FCAD2A]',
  sky: 'text-sky-400',
  purple: 'text-purple-400',
}[accent];

const accentClass = {
  amber: 'forge-card-amber',
  sky: 'forge-card-sky',
  purple: 'forge-card-purple',
}[accent];
---

<div class:list={[
  'bg-gray-900/60 border border-white/10 rounded-2xl p-6 transition-colors h-full flex flex-col',
  accentClass,
]}>
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-bold text-white leading-tight">{team}</h3>
    <span class:list={['text-sm font-mono font-semibold shrink-0 ml-3', accentBar]}>
      {memberCount}
    </span>
  </div>
  <p class="text-white/60 text-sm leading-relaxed flex-1">{description}</p>
  {members.length > 0 && (
    <div class="mt-4 pt-4 border-t border-white/5">
      <div class="flex flex-wrap gap-1.5">
        {members.map((m) => (
          <span class="px-2 py-0.5 bg-white/5 text-white/50 rounded text-xs">{m}</span>
        ))}
      </div>
    </div>
  )}
</div>
