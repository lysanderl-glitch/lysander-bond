---
// Global language toggle (EN | 中)
// - Visual style mirrors the EN|中 toggle that used to live inside SynapseSubNav.
// - Post-Stage-4 URL architecture:
//   * Chinese is the DEFAULT locale served at `/...` (no prefix).
//   * English lives under `/en/...`.
// - Behavior:
//   * On /en/<slug>         -> clicking 中 navigates to /<slug> (strip /en prefix)
//   * On /<slug>            -> clicking EN navigates to /en/<slug> IF that page exists;
//                              otherwise the EN button is disabled with a tooltip.
// - Server-rendered current-language highlight is driven by the `currentLang` prop.
// - TODO(main-site-bilingual): When /, /services, /academy, /blog etc gain English
//   versions under /en/, expand HAS_EN_VERSION below. Until then the disabled UX
//   provides graceful degradation.
interface Props {
  currentLang?: 'en' | 'zh';
}
const { currentLang = 'zh' } = Astro.props;
---

<div
  class="flex items-center gap-1 text-xs font-semibold whitespace-nowrap"
  data-lang-toggle
>
  <a
    href="#"
    data-forge-lang="en"
    aria-label={currentLang === 'zh' ? '切换到英文' : 'Switch to English'}
    class:list={[
      'lang-toggle-btn px-2 py-0.5 rounded transition-colors',
      currentLang === 'en'
        ? 'bg-[#FCAD2A]/20 text-[#FCAD2A]'
        : 'text-white/50 hover:text-white',
    ]}
  >
    EN
  </a>
  <span class="text-white/20">|</span>
  <a
    href="#"
    data-forge-lang="zh"
    aria-label={currentLang === 'zh' ? '切换到中文' : 'Switch to Chinese'}
    class:list={[
      'lang-toggle-btn px-2 py-0.5 rounded transition-colors',
      currentLang === 'zh'
        ? 'bg-[#FCAD2A]/20 text-[#FCAD2A]'
        : 'text-white/50 hover:text-white',
    ]}
  >
    中
  </a>
</div>

<style>
  /* Disabled state for language toggle when current page has no peer in target language */
  [data-lang-toggle] a.lang-toggle-btn[data-ineligible="true"] {
    color: rgba(255, 255, 255, 0.3) !important;
    cursor: not-allowed;
  }
  [data-lang-toggle] a.lang-toggle-btn[data-ineligible="true"]:hover {
    color: rgba(255, 255, 255, 0.3) !important;
    background-color: transparent !important;
  }

  /* Toast for mobile tap fallback (desktop uses native title tooltip) */
  #lang-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 10px 18px;
    border-radius: 6px;
    font-size: 14px;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    max-width: min(90vw, 420px);
    text-align: center;
  }
  #lang-toast.visible {
    opacity: 1;
  }
</style>

<script>
  (function () {
    // Pages that have an English version under /en/.
    // Keys are the normalized ZH path (no trailing slash, leading slash kept).
    // Must be kept in sync with src/pages/en/**/*.astro on disk.
    //
    // Stage 4 Step 2-4 (2026-04-24): initial whitelist covers the 8 Forge pages.
    // Expand when main-site pages (/, /services, /academy, /blog, /about, ...)
    // gain English versions under /en/.
    const HAS_EN_VERSION = new Set<string>([
      '/synapse',
      '/synapse/capabilities',
      '/synapse/how-it-works',
      '/synapse/team',
      '/synapse/intelligence',
      '/synapse/pricing',
      '/synapse/get-started',
      '/synapse/beta',
    ]);

    // Tooltip copy for disabled state (localized to the page the user is viewing).
    const TOOLTIP_EN_DISABLED =
      'English version coming soon — explore our English content on Synapse Forge';
    const TOOLTIP_ZH_DISABLED = '此页面暂无中文版';

    function normalizePath(path: string): string {
      // Strip trailing slash; keep '/' for root.
      const p = path.replace(/\/$/, '');
      return p === '' ? '/' : p;
    }

    function isEnPath(path: string): boolean {
      // /en, /en/, /en/anything
      return path === '/en' || path.startsWith('/en/');
    }

    function stripEnPrefix(path: string): string {
      // '/en'        -> '/'
      // '/en/foo'    -> '/foo'
      // '/en/foo/bar'-> '/foo/bar'
      if (path === '/en') return '/';
      if (path.startsWith('/en/')) return path.slice(3) || '/';
      return path;
    }

    function detectCurrentLang(): 'en' | 'zh' {
      const htmlLang = (document.documentElement.lang || '').toLowerCase();
      if (htmlLang.startsWith('zh')) return 'zh';
      if (htmlLang.startsWith('en')) return 'en';
      // Fallback: infer from path.
      return isEnPath(normalizePath(window.location.pathname)) ? 'en' : 'zh';
    }

    function computeTargetUrl(targetLang: 'en' | 'zh'): string | null {
      const path = normalizePath(window.location.pathname);
      const currentIsEn = isEnPath(path);

      // Same-language click: stay (no navigation needed)
      if (currentIsEn && targetLang === 'en') return null;
      if (!currentIsEn && targetLang === 'zh') return null;

      if (targetLang === 'zh') {
        // Going from EN to ZH: strip /en prefix.
        // Every /en/* page has a ZH peer at the unprefixed path (ZH is default).
        return stripEnPrefix(path);
      }

      // targetLang === 'en', currentIsEn === false
      // Check whitelist for EN version.
      // path is normalized (no trailing slash), e.g. '/synapse' or '/synapse/capabilities'.
      if (HAS_EN_VERSION.has(path)) {
        return path === '/' ? '/en/' : `/en${path}`;
      }

      // No EN peer — disabled state.
      return null;
    }

    function tooltipFor(targetLang: 'en' | 'zh'): string {
      // Localize tooltip to the language of the currently viewed page.
      const activeLang = detectCurrentLang();
      if (targetLang === 'en' && activeLang === 'zh') return TOOLTIP_EN_DISABLED;
      if (targetLang === 'zh' && activeLang === 'en') return TOOLTIP_ZH_DISABLED;
      // Fallbacks
      return activeLang === 'zh' ? TOOLTIP_EN_DISABLED : TOOLTIP_ZH_DISABLED;
    }

    function markIneligibleState() {
      const buttons = document.querySelectorAll<HTMLAnchorElement>(
        '[data-lang-toggle] [data-forge-lang]'
      );
      buttons.forEach((btn) => {
        const lang = btn.getAttribute('data-forge-lang') as 'en' | 'zh';
        const target = computeTargetUrl(lang);

        // computeTargetUrl returns null for two cases:
        //  1. Same-language click (stay). This is the ACTIVE button — don't mark ineligible.
        //  2. Cross-language click with no peer page. Mark ineligible.
        const path = normalizePath(window.location.pathname);
        const currentIsEn = isEnPath(path);
        const isSameLangClick =
          (currentIsEn && lang === 'en') || (!currentIsEn && lang === 'zh');

        const ineligible = target === null && !isSameLangClick;

        if (ineligible) {
          btn.setAttribute('data-ineligible', 'true');
          btn.setAttribute('aria-disabled', 'true');
          btn.setAttribute('title', tooltipFor(lang));
        } else {
          btn.removeAttribute('data-ineligible');
          btn.removeAttribute('aria-disabled');
          btn.removeAttribute('title');
        }
      });
    }

    function showToast(msg: string) {
      let toast = document.getElementById('lang-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'lang-toast';
        document.body.appendChild(toast);
      }
      toast.textContent = msg;
      // Force reflow so transition re-triggers.
      void toast.offsetWidth;
      toast.classList.add('visible');
      window.setTimeout(() => {
        toast!.classList.remove('visible');
      }, 3000);
    }

    function bindHandlers() {
      document
        .querySelectorAll<HTMLAnchorElement>('[data-lang-toggle] [data-forge-lang]')
        .forEach((el) => {
          el.addEventListener('click', (ev) => {
            ev.preventDefault();
            const lang = el.getAttribute('data-forge-lang') as 'en' | 'zh';

            // Ineligible button: show toast (mobile) / rely on native title (desktop).
            if (el.getAttribute('data-ineligible') === 'true') {
              const msg = el.getAttribute('title') || tooltipFor(lang);
              showToast(msg);
              return;
            }

            const target = computeTargetUrl(lang);
            if (target && target !== window.location.pathname) {
              window.location.href = target;
            }
          });
        });
    }

    function init() {
      markIneligibleState();
      bindHandlers();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
