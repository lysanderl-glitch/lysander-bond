---
import Layout from './Layout.astro';
import SynapseSubNav from '../components/synapse/SynapseSubNav.astro';

interface AltLang {
  lang: 'en' | 'zh';
  href: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  subNavActive?: string;
  currentLang?: 'en' | 'zh';
  altLang?: AltLang;
}

const {
  title,
  description,
  ogImage,
  subNavActive = '',
  currentLang = 'en',
  altLang,
} = Astro.props;
const fullTitle = `${title} | Synapse`;
const selfLang = currentLang === 'zh' ? 'zh-CN' : 'en';
// hreflang now injected globally by Layout.astro from Astro.url.pathname
---

<Layout title={fullTitle} description={description} darkContent={true} lang={selfLang}>
  <SynapseSubNav active={subNavActive} currentLang={currentLang} />
  <slot />
</Layout>

<style is:global>
  @import '../styles/synapse.css';
</style>
