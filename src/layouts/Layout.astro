---
interface Props {
  title?: string;
  description?: string;
  darkContent?: boolean;
}

const {
  title = 'Synapse by Janus Digital',
  description = 'Synapse — AI Agent 团队协作运营体系 | Harness Engineering 实践 | Janus Digital',
  darkContent = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Synapse, Harness Engineering, AI Agent, Multi-Agent, Janus Digital, Claude Code" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Dark header -->
    <header class="bg-[var(--color-dark)] sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35 44" width="22" height="28">
            <path d="M24.39.09C25.4-.32 26.42.73 26.42 2.18V41.44c0 1.45-1.02 2.49-2.03 2.08L9.71 39.63l8.53-1.03c.51-.08.98-.35 1.31-.77.34-.42.53-.96.53-1.51V7.32c0-.56-.19-1.09-.53-1.51-.34-.42-.81-.69-1.31-.77L9.63 4 24.39.09Z" fill="white"/>
            <path d="M2.45 38.84L16.61 37.33c.51-.08.97-.33 1.31-.73.34-.39.53-.9.53-1.42V8.42c0-.52-.19-1.03-.53-1.42-.34-.39-.8-.64-1.31-.71L2.45 4.77c-.3-.05-.61-.02-.9.06-.3.09-.57.24-.8.44s-.42.45-.55.73c-.13.28-.2.59-.2.9v29.79c0 .31.07.62.2.9.13.28.3.53.54.73.23.2.51.35.8.44.29.09.61.11.91.06Z" fill="#FCAD2A"/>
            <path d="M31.87 7.93L28.1 7.52v28.57l3.77-.38V7.93Z" fill="#013A7D"/>
            <path d="M33.13 8.05v27.52c.98-.21 1.68-.77 1.68-1.51V9.55c0-.73-.7-1.29-1.68-1.5Z" fill="#028CDC"/>
          </svg>
          <span class="text-lg font-bold text-[#FCAD2A]">Synapse</span>
        </a>
        <div class="hidden md:flex gap-5 text-sm font-medium">
          <a href="/services" class="text-white/70 hover:text-[#FCAD2A] transition-colors">服务</a>
          <a href="/training" class="text-white/70 hover:text-[#FCAD2A] transition-colors">培训</a>
          <a href="/blog" class="text-white/70 hover:text-[#FCAD2A] transition-colors">博客</a>
          <a href="/intelligence" class="text-white/70 hover:text-[#FCAD2A] transition-colors">情报</a>
          <a href="/about" class="text-white/70 hover:text-[#FCAD2A] transition-colors">关于</a>
        </div>
      </nav>
    </header>

    <!-- Main content area -->
    <main class:list={["flex-1", darkContent ? "bg-[var(--color-dark)]" : "bg-white"]}>
      <slot />
    </main>

    <!-- Dark footer -->
    <footer class="bg-[var(--color-dark)]">
      <div class="max-w-5xl mx-auto px-6 py-10">
        <div class="flex flex-col md:flex-row justify-between items-start gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35 44" width="18" height="22">
                <path d="M24.39.09C25.4-.32 26.42.73 26.42 2.18V41.44c0 1.45-1.02 2.49-2.03 2.08L9.71 39.63l8.53-1.03c.51-.08.98-.35 1.31-.77.34-.42.53-.96.53-1.51V7.32c0-.56-.19-1.09-.53-1.51-.34-.42-.81-.69-1.31-.77L9.63 4 24.39.09Z" fill="white"/>
                <path d="M2.45 38.84L16.61 37.33c.51-.08.97-.33 1.31-.73.34-.39.53-.9.53-1.42V8.42c0-.52-.19-1.03-.53-1.42-.34-.39-.8-.64-1.31-.71L2.45 4.77c-.3-.05-.61-.02-.9.06-.3.09-.57.24-.8.44s-.42.45-.55.73c-.13.28-.2.59-.2.9v29.79c0 .31.07.62.2.9.13.28.3.53.54.73.23.2.51.35.8.44.29.09.61.11.91.06Z" fill="#FCAD2A"/>
                <path d="M31.87 7.93L28.1 7.52v28.57l3.77-.38V7.93Z" fill="#013A7D"/>
                <path d="M33.13 8.05v27.52c.98-.21 1.68-.77 1.68-1.51V9.55c0-.73-.7-1.29-1.68-1.5Z" fill="#028CDC"/>
              </svg>
              <span class="font-bold text-[#FCAD2A]">Synapse</span>
              <span class="text-white/40 text-sm">by Janus Digital</span>
            </div>
            <p class="text-white/40 text-sm max-w-xs">AI Agent 团队协作运营体系<br>Harness Engineering 实践者</p>
          </div>
          <div class="flex gap-12 text-sm">
            <div>
              <h4 class="font-semibold text-white mb-3">服务</h4>
              <div class="flex flex-col gap-2 text-white/40">
                <a href="/services" class="hover:text-[#FCAD2A]">Synapse Assessment</a>
                <a href="/services" class="hover:text-[#FCAD2A]">Synapse Implementation</a>
                <a href="/training" class="hover:text-[#FCAD2A]">SCP 培训认证</a>
              </div>
            </div>
            <div>
              <h4 class="font-semibold text-white mb-3">资源</h4>
              <div class="flex flex-col gap-2 text-white/40">
                <a href="/blog" class="hover:text-[#FCAD2A]">博客</a>
                <a href="/intelligence" class="hover:text-[#FCAD2A]">AI 情报日报</a>
                <a href="/about" class="hover:text-[#FCAD2A]">关于我们</a>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t border-white/5 mt-8 pt-6 flex flex-col md:flex-row justify-between items-center text-xs text-white/30 gap-2">
          <p>&copy; 2026 Janus Digital. Powered by Synapse.</p>
          <p>lysanderl@janusd.io</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
