---
import LangToggle from '../components/LangToggle.astro';

interface Props {
  title?: string;
  description?: string;
  darkContent?: boolean;
  lang?: string;
}

const {
  title = 'Synapse — AI Agent 协作运营体系',
  description = 'Synapse — 基于 Harness Engineering 的 AI Agent 团队协作运营体系',
  darkContent = false,
  lang = 'zh-CN',
} = Astro.props;

// Normalize: any value of `lang` that starts with "en" means English UI;
// everything else (zh, zh-CN, undefined) means Chinese UI.
const isEn = typeof lang === 'string' && lang.toLowerCase().startsWith('en');
const htmlLang = isEn ? 'en' : 'zh-CN';
const toggleLang: 'en' | 'zh' = isEn ? 'en' : 'zh';

// Header / Footer copy tables
const t = isEn
  ? {
      navServices: 'Services',
      navTraining: 'Training',
      navBlog: 'Blog',
      navIntelligence: 'Intelligence',
      navAbout: 'About',
      navForge: 'Forge',
      navAcademy: 'Academy',
      brandTag: 'AI Agent Operating System',
      footerTagline: 'AI agent team operations system.<br>Harness Engineering in practice.',
      footerColServices: 'Services',
      footerSvcAssessment: 'Synapse Assessment',
      footerSvcImplementation: 'Synapse Implementation',
      footerSvcTraining: 'SCP Training & Certification',
      footerColAcademy: 'Academy',
      footerAcademyHome: 'Academy Home',
      footerAcademyGet: 'Get Synapse',
      footerAcademyTeam: 'AI Team Roster',
      footerAcademySkills: 'Skills Workflow',
      footerAcademyLearn: 'Harness Methodology',
      footerColResources: 'Resources',
      footerResBlog: 'Blog',
      footerResIntel: 'AI Intelligence Daily',
      footerResAbout: 'About Us',
      footerCopyright: '© 2026 Synapse. Harness Engineering for AI Teams.',
    }
  : {
      navServices: '服务',
      navTraining: '培训',
      navBlog: '博客',
      navIntelligence: '情报',
      navAbout: '关于',
      navForge: 'Forge',
      navAcademy: '学院',
      brandTag: 'AI Agent 协作运营体系',
      footerTagline: 'AI Agent 团队协作运营体系<br>Harness Engineering 实践者',
      footerColServices: '服务',
      footerSvcAssessment: 'Synapse Assessment',
      footerSvcImplementation: 'Synapse Implementation',
      footerSvcTraining: 'SCP 培训认证',
      footerColAcademy: '学院',
      footerAcademyHome: '学院首页',
      footerAcademyGet: '获取 Synapse',
      footerAcademyTeam: 'AI 团队名录',
      footerAcademySkills: 'Skills 工作流',
      footerAcademyLearn: 'Harness 方法论',
      footerColResources: '资源',
      footerResBlog: '博客',
      footerResIntel: 'AI 情报日报',
      footerResAbout: '关于我们',
      footerCopyright: '© 2026 Synapse. Harness Engineering for AI Teams.',
    };
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={isEn ? "Synapse, Harness Engineering, AI Agent, Multi-Agent, Claude Code, AI Team Management" : "Synapse, Harness Engineering, AI Agent, Multi-Agent, Claude Code, AI团队管理"} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Dark header -->
    <header class="bg-gray-900/95 backdrop-blur-md border-b border-[#FCAD2A]/30 sticky top-0 z-50">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35 44" width="22" height="28">
            <path d="M24.39.09C25.4-.32 26.42.73 26.42 2.18V41.44c0 1.45-1.02 2.49-2.03 2.08L9.71 39.63l8.53-1.03c.51-.08.98-.35 1.31-.77.34-.42.53-.96.53-1.51V7.32c0-.56-.19-1.09-.53-1.51-.34-.42-.81-.69-1.31-.77L9.63 4 24.39.09Z" fill="white"/>
            <path d="M2.45 38.84L16.61 37.33c.51-.08.97-.33 1.31-.73.34-.39.53-.9.53-1.42V8.42c0-.52-.19-1.03-.53-1.42-.34-.39-.8-.64-1.31-.71L2.45 4.77c-.3-.05-.61-.02-.9.06-.3.09-.57.24-.8.44s-.42.45-.55.73c-.13.28-.2.59-.2.9v29.79c0 .31.07.62.2.9.13.28.3.53.54.73.23.2.51.35.8.44.29.09.61.11.91.06Z" fill="#FCAD2A"/>
            <path d="M31.87 7.93L28.1 7.52v28.57l3.77-.38V7.93Z" fill="#013A7D"/>
            <path d="M33.13 8.05v27.52c.98-.21 1.68-.77 1.68-1.51V9.55c0-.73-.7-1.29-1.68-1.5Z" fill="#028CDC"/>
          </svg>
          <span class="text-lg font-bold text-[#FCAD2A]">Synapse</span>
        </a>
        <div class="hidden md:flex items-center gap-5 text-sm font-medium">
          <a href="/services" class="text-white/70 hover:text-[#FCAD2A] transition-colors">{t.navServices}</a>
          <a href="/training" class="text-white/70 hover:text-[#FCAD2A] transition-colors">{t.navTraining}</a>
          <a href="/blog" class="text-white/70 hover:text-[#FCAD2A] transition-colors">{t.navBlog}</a>
          <a href="/intelligence" class="text-white/70 hover:text-[#FCAD2A] transition-colors">{t.navIntelligence}</a>
          <a href="/about" class="text-white/70 hover:text-[#FCAD2A] transition-colors">{t.navAbout}</a>
          <a href="/synapse" class="px-3 py-1 bg-[#FCAD2A]/15 text-[#FCAD2A] border border-[#FCAD2A]/30 rounded-full hover:bg-[#FCAD2A]/25 transition-colors font-semibold">{t.navForge}</a>
          <a href="/academy" class="px-3 py-1 bg-[#FCAD2A]/15 text-[#FCAD2A] border border-[#FCAD2A]/30 rounded-full hover:bg-[#FCAD2A]/25 transition-colors font-semibold">{t.navAcademy}</a>
          <LangToggle currentLang={toggleLang} />
        </div>
      </nav>
    </header>

    <!-- Main content area -->
    <main class:list={["flex-1", darkContent ? "bg-[var(--color-dark)]" : "bg-white"]}>
      <slot />
    </main>

    <!-- Dark footer -->
    <footer class="bg-[var(--color-dark)]">
      <div class="max-w-5xl mx-auto px-6 py-10">
        <div class="flex flex-col md:flex-row justify-between items-start gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35 44" width="18" height="22">
                <path d="M24.39.09C25.4-.32 26.42.73 26.42 2.18V41.44c0 1.45-1.02 2.49-2.03 2.08L9.71 39.63l8.53-1.03c.51-.08.98-.35 1.31-.77.34-.42.53-.96.53-1.51V7.32c0-.56-.19-1.09-.53-1.51-.34-.42-.81-.69-1.31-.77L9.63 4 24.39.09Z" fill="white"/>
                <path d="M2.45 38.84L16.61 37.33c.51-.08.97-.33 1.31-.73.34-.39.53-.9.53-1.42V8.42c0-.52-.19-1.03-.53-1.42-.34-.39-.8-.64-1.31-.71L2.45 4.77c-.3-.05-.61-.02-.9.06-.3.09-.57.24-.8.44s-.42.45-.55.73c-.13.28-.2.59-.2.9v29.79c0 .31.07.62.2.9.13.28.3.53.54.73.23.2.51.35.8.44.29.09.61.11.91.06Z" fill="#FCAD2A"/>
                <path d="M31.87 7.93L28.1 7.52v28.57l3.77-.38V7.93Z" fill="#013A7D"/>
                <path d="M33.13 8.05v27.52c.98-.21 1.68-.77 1.68-1.51V9.55c0-.73-.7-1.29-1.68-1.5Z" fill="#028CDC"/>
              </svg>
              <span class="font-bold text-[#FCAD2A]">Synapse</span>
              <span class="text-white/40 text-sm">{t.brandTag}</span>
            </div>
            <p class="text-white/40 text-sm max-w-xs" set:html={t.footerTagline}></p>
          </div>
          <div class="flex gap-12 text-sm">
            <div>
              <h4 class="font-semibold text-white mb-3">{t.footerColServices}</h4>
              <div class="flex flex-col gap-2 text-white/40">
                <a href="/services" class="hover:text-[#FCAD2A]">{t.footerSvcAssessment}</a>
                <a href="/services" class="hover:text-[#FCAD2A]">{t.footerSvcImplementation}</a>
                <a href="/training" class="hover:text-[#FCAD2A]">{t.footerSvcTraining}</a>
              </div>
            </div>
            <div>
              <h4 class="font-semibold text-white mb-3">{t.footerColAcademy}</h4>
              <div class="flex flex-col gap-2 text-white/40">
                <a href="/academy" class="hover:text-[#FCAD2A]">{t.footerAcademyHome}</a>
                <a href="/academy/get-synapse" class="hover:text-[#FCAD2A]">{t.footerAcademyGet}</a>
                <a href="/academy/team" class="hover:text-[#FCAD2A]">{t.footerAcademyTeam}</a>
                <a href="/academy/skills" class="hover:text-[#FCAD2A]">{t.footerAcademySkills}</a>
                <a href="/academy/learn" class="hover:text-[#FCAD2A]">{t.footerAcademyLearn}</a>
              </div>
            </div>
            <div>
              <h4 class="font-semibold text-white mb-3">{t.footerColResources}</h4>
              <div class="flex flex-col gap-2 text-white/40">
                <a href="/blog" class="hover:text-[#FCAD2A]">{t.footerResBlog}</a>
                <a href="/intelligence" class="hover:text-[#FCAD2A]">{t.footerResIntel}</a>
                <a href="/about" class="hover:text-[#FCAD2A]">{t.footerResAbout}</a>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t border-white/5 mt-8 pt-6 flex flex-col md:flex-row justify-between items-center text-xs text-white/30 gap-2">
          <p>{t.footerCopyright}</p>
          <p>lysanderl@janusd.io</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
